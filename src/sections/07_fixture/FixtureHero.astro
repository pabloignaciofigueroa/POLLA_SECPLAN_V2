---
---

<header class="fixture-hero">
  <p class="eyebrow">etapa 2 / llave eliminatoria</p>
  <h1>
    <span class="mark" aria-hidden="true"></span>
    <span>LLAVE</span>
    <span class="mark mark-right" aria-hidden="true"></span>
  </h1>
  <p class="subtitle">Pronostica los 16 cruces de dieciseisavos: marcador y quién avanza.</p>
  <span class="fifa-mark" aria-label="Dieciseisavos · Mundial 2026">
    <img
      src="/assets/brand/fifa/fifa-world-cup-2026-hosts-logo.webp"
      alt=""
      aria-hidden="true"
      width="160"
      height="160"
      loading="lazy"
      decoding="async"
    />
    <span>Dieciseisavos · Mundial 2026</span>
  </span>
</header>

<style>
  .fixture-hero {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    text-align: left;
  }

  .eyebrow {
    margin: 0;
    padding: 0.25rem 0.8rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(255, 241, 214, 0.96), rgba(255, 228, 232, 0.9));
    color: var(--pm-orange-600);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 950;
    line-height: 0.86;
    text-transform: uppercase;
    background: linear-gradient(135deg, var(--pm-orange-500) 0%, var(--pm-red-500) 58%, var(--pm-yellow-600) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 2px 0 rgba(6, 19, 38, 0.18)) drop-shadow(0 10px 20px rgba(255, 64, 88, 0.2));
  }

  .mark {
    position: relative;
    width: clamp(1.8rem, 3.6vw, 3rem);
    height: 1rem;
    flex: 0 0 auto;
  }

  .mark::before,
  .mark::after {
    content: "";
    position: absolute;
    left: 0;
    height: 0.16rem;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--pm-orange-500), var(--pm-red-500));
  }

  .mark::before {
    top: 0.18rem;
    width: 100%;
  }

  .mark::after {
    right: 0;
    bottom: 0.12rem;
    width: 58%;
  }

  .mark-right {
    transform: scaleX(-1);
  }

  .subtitle {
    margin: 0;
    color: var(--pm-blue-900);
    font-size: clamp(0.8rem, 1.05vw, 0.92rem);
    font-weight: 600;
    max-width: 40ch;
  }

  .fifa-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.1rem;
    padding: 0.24rem 0.62rem;
    border: 1px solid rgba(7, 23, 53, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.56rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .fifa-mark img {
    width: 1.25rem;
    height: 1.25rem;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 720px) {
    h1 {
      gap: 0.3rem;
    }

    .mark {
      display: none;
    }
  }
</style>
