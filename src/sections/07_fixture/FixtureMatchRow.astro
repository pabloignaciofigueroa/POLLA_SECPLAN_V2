---
import type { FixtureMatch, MatchStatusVisual } from "./fixture.logic";
import { getStatusLabel } from "./fixture.logic";

interface Props {
  match: FixtureMatch;
  status: MatchStatusVisual;
  selected: boolean;
  timeChile: string;
}

const { match, status, selected, timeChile } = Astro.props;
const statusLabel = getStatusLabel(status);
const matchNumberLabel = String(match.matchNumber).padStart(2, "0");
const groupKey = (match.groupId ?? "").toLowerCase();
---

<button
  type="button"
  class="match-row"
  data-match-row={match.id}
  data-status={status}
  data-selected={selected ? "true" : "false"}
  data-group-key={groupKey}
  aria-pressed={selected ? "true" : "false"}
>
  <span class="match-number">{matchNumberLabel}</span>
  <span class="time" data-row-time>{timeChile}</span>

  <span class="team home" data-row-home>
    <span class="flag" aria-hidden="true" data-row-home-flag>
      <img src={`/assets/flags/${match.homeTeam.id}.svg`} alt="" loading="lazy" decoding="async" width="48" height="36" />
    </span>
    <span class="team-name" data-row-home-name>{match.homeTeam.name}</span>
  </span>

  <span class="separator" data-row-separator>VS</span>

  <span class="team away" data-row-away>
    <span class="team-name" data-row-away-name>{match.awayTeam.name}</span>
    <span class="flag" aria-hidden="true" data-row-away-flag>
      <img src={`/assets/flags/${match.awayTeam.id}.svg`} alt="" loading="lazy" decoding="async" width="48" height="36" />
    </span>
  </span>

  <span class="group-badge" data-row-group>{match.groupLabel.replace("Grupo ", "G ")}</span>

  <span class="status-pill" data-row-status>{statusLabel}</span>
</button>

<style>
  .match-row {
    position: relative;
    display: grid;
    grid-template-columns: 1.55rem 2.55rem minmax(0, 1fr) auto minmax(0, 1fr) 3rem 3.55rem;
    gap: 0.32rem;
    align-items: center;
    width: 100%;
    padding: 0.3rem 0.48rem 0.3rem 0.72rem;
    border: 1px solid var(--pm-border-soft);
    border-radius: 0.62rem;
    background: rgba(255, 255, 255, 0.9);
    color: var(--pm-blue-900);
    font-size: 0.66rem;
    text-align: left;
    cursor: pointer;
    transition: border-color var(--pm-transition-fast),
      background var(--pm-transition-fast),
      box-shadow var(--pm-transition-fast);
  }

  .match-row::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 3px;
    background: var(--row-accent, transparent);
    border-radius: 0.62rem 0 0 0.62rem;
  }

  .match-row:hover {
    border-color: var(--pm-blue-400);
    background: rgba(241, 249, 255, 0.96);
  }

  .match-row:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
    border-color: var(--pm-blue-500);
  }

  .match-row[data-selected="true"] {
    --row-accent: linear-gradient(180deg, var(--pm-cyan-500), var(--pm-blue-500));
    border-color: var(--pm-blue-500);
    background: rgba(232, 247, 255, 0.95);
    box-shadow: 0 0 0 1px var(--pm-cyan-500) inset;
  }

  .match-number {
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 900;
  }

  .time {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 900;
  }

  .team {
    display: flex;
    align-items: center;
    gap: 0.28rem;
    min-width: 0;
  }

  .team.away {
    justify-content: flex-end;
    text-align: right;
  }

  .flag {
    display: inline-block;
    width: 1.36rem;
    height: 1rem;
    overflow: hidden;
    border: 1px solid var(--pm-border-soft);
    border-radius: 0.26rem;
    background: rgba(255, 255, 255, 0.85);
    flex: 0 0 auto;
    line-height: 0;
  }

  .flag img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .team-name {
    min-width: 0;
    overflow: hidden;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-weight: 800;
    text-overflow: ellipsis;
    text-transform: uppercase;
    white-space: nowrap;
    font-size: 0.66rem;
  }

  .separator {
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 900;
    text-align: center;
  }

  .group-badge {
    padding: 0.13rem 0.28rem;
    border: 1px solid var(--group-color, var(--pm-blue-500));
    border-radius: 999px;
    background: var(--group-color, var(--pm-blue-500));
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  .match-row[data-group-key="c"] .group-badge,
  .match-row[data-group-key="e"] .group-badge,
  .match-row[data-group-key="g"] .group-badge,
  .match-row[data-group-key="i"] .group-badge,
  .match-row[data-group-key="l"] .group-badge {
    color: var(--pm-blue-900);
  }

  .match-row[data-group-key="a"] { --group-color: var(--pm-group-a); }
  .match-row[data-group-key="b"] { --group-color: var(--pm-group-b); }
  .match-row[data-group-key="c"] { --group-color: var(--pm-group-c); }
  .match-row[data-group-key="d"] { --group-color: var(--pm-group-d); }
  .match-row[data-group-key="e"] { --group-color: var(--pm-group-e); }
  .match-row[data-group-key="f"] { --group-color: var(--pm-group-f); }
  .match-row[data-group-key="g"] { --group-color: var(--pm-group-g); }
  .match-row[data-group-key="h"] { --group-color: var(--pm-group-h); }
  .match-row[data-group-key="i"] { --group-color: var(--pm-group-i); }
  .match-row[data-group-key="j"] { --group-color: var(--pm-group-j); }
  .match-row[data-group-key="k"] { --group-color: var(--pm-group-k); }
  .match-row[data-group-key="l"] { --group-color: var(--pm-group-l); }

  .status-pill {
    padding: 0.15rem 0.3rem;
    border: 1px solid var(--pm-border-soft);
    border-radius: 999px;
    background: rgba(241, 245, 249, 0.7);
    color: var(--pm-text-soft);
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  .match-row[data-status="live"] .status-pill {
    background: var(--pm-state-live-bg);
    color: var(--pm-state-live-text);
    border-color: var(--pm-state-live-border);
    box-shadow: 0 0 10px rgba(255, 64, 88, 0.45);
  }

  .match-row[data-status="today"] .status-pill {
    background: var(--pm-state-upcoming-bg);
    color: var(--pm-state-upcoming-text);
    border-color: var(--pm-state-upcoming-border);
  }

  .match-row[data-status="finished"] .status-pill {
    background: var(--pm-state-finished-bg);
    color: var(--pm-state-finished-text);
    border-color: var(--pm-state-finished-border);
  }

  @media (max-width: 900px) {
    .match-row {
      grid-template-columns: 1.55rem 2.45rem minmax(0, 1fr) auto minmax(0, 1fr) 3rem;
    }

    .status-pill {
      grid-column: 1 / -1;
      justify-self: end;
    }
  }

  @media (max-width: 560px) {
    .match-row {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      row-gap: 0.28rem;
    }

    .match-number,
    .time,
    .group-badge {
      grid-column: 1 / -1;
      justify-self: start;
    }

    .group-badge {
      justify-self: end;
    }
  }
</style>
