---
import FixtureDayGroup from "./FixtureDayGroup.astro";
import type { FixtureMatch } from "./fixture.logic";
import { groupMatchesByDate } from "./fixture.logic";

interface Props {
  matches: FixtureMatch[];
  selectedId: string;
  stageHeading: string;
}

const { matches, selectedId, stageHeading } = Astro.props;
const grouped = groupMatchesByDate(matches);
const firstDayKey = grouped[0]?.dateKey;
---

<aside class="list-panel" aria-label="Lista de partidos">
  <header class="list-header">
    <span class="list-eyebrow">Fixture table</span>
    <h2 class="list-title" data-list-heading>{stageHeading}</h2>
  </header>

  <div class="day-stack" data-day-stack>
    {grouped.length === 0 ? (
      <div class="empty-state" data-empty-state>
        <p class="empty-title">Sin partidos para este filtro</p>
        <p class="empty-hint">Cambia la etapa o el grupo para volver a ver el calendario.</p>
      </div>
    ) : (
      grouped.map(({ dateKey, matches: dayMatches }) => (
        <FixtureDayGroup
          dateKey={dateKey}
          matches={dayMatches}
          selectedId={selectedId}
          stageLabel={dateKey === firstDayKey ? stageHeading : undefined}
        />
      ))
    )}
  </div>
</aside>

<style>
  .list-panel {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.8rem;
    border: 1px solid color-mix(in srgb, var(--pm-sec-fixture-a) 36%, transparent);
    border-radius: 1rem;
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-sec-fixture-a) 18%, transparent),
        color-mix(in srgb, var(--pm-sec-fixture-b) 24%, transparent)
      ),
      var(--pm-panel-soft);
    box-shadow: 0 16px 34px rgba(7, 23, 53, 0.08);
  }

  .list-header {
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgba(7, 23, 53, 0.1);
  }

  .list-eyebrow {
    color: var(--pm-blue-700);
    font-size: 0.56rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .list-title {
    margin: 0;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.16rem);
    font-weight: 900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .day-stack {
    display: flex;
    max-height: 56vh;
    flex-direction: column;
    gap: 0.54rem;
    overflow-y: auto;
    padding-right: 0.2rem;
  }

  .empty-state {
    padding: 1.2rem 1rem;
    border: 1px dashed rgba(7, 23, 53, 0.18);
    border-radius: 0.8rem;
    text-align: center;
  }

  .empty-title {
    margin: 0 0 0.25rem;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .empty-hint {
    margin: 0;
    color: var(--pm-blue-700);
    font-size: 0.76rem;
  }

  @media (max-width: 720px) {
    .day-stack {
      max-height: none;
    }
  }

  :global([data-section="fixture"] .day-stack .day-group) {
    display: flex;
    flex-direction: column;
    gap: 0.26rem;
  }

  :global([data-section="fixture"] .day-stack .day-header) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.36rem;
    align-items: baseline;
    padding-bottom: 0.14rem;
    border-bottom: 1px solid rgba(7, 23, 53, 0.1);
  }

  :global([data-section="fixture"] .day-stack .stage-label) {
    color: var(--pm-blue-700);
    font-size: 0.52rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  :global([data-section="fixture"] .day-stack .day-label) {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  :global([data-section="fixture"] .day-stack .day-rows) {
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global([data-section="fixture"] .day-stack .match-row) {
    display: grid;
    grid-template-columns: 1.55rem 2.55rem minmax(0, 1fr) auto minmax(0, 1fr) 3rem 3.55rem;
    gap: 0.32rem;
    align-items: center;
    width: 100%;
    padding: 0.3rem 0.48rem 0.3rem 0.72rem;
    border: 1px solid var(--pm-border-soft);
    border-radius: 0.62rem;
    background: rgba(255, 255, 255, 0.9);
    color: var(--pm-blue-900);
    font-size: 0.66rem;
    text-align: left;
    cursor: pointer;
    box-sizing: border-box;
  }

  :global([data-section="fixture"] .day-stack .match-row:hover),
  :global([data-section="fixture"] .day-stack .match-row[data-selected="true"]) {
    border-color: var(--pm-blue-400);
    background: rgba(241, 249, 255, 0.96);
  }

  :global([data-section="fixture"] .day-stack .match-row[data-selected="true"]) {
    box-shadow: inset 3px 0 0 var(--pm-blue-500);
  }

  :global([data-section="fixture"] .day-stack .match-number),
  :global([data-section="fixture"] .day-stack .time),
  :global([data-section="fixture"] .day-stack .separator) {
    font-family: var(--font-display);
    font-weight: 900;
  }

  :global([data-section="fixture"] .day-stack .match-number),
  :global([data-section="fixture"] .day-stack .separator) {
    color: var(--pm-blue-700);
    font-size: 0.66rem;
  }

  :global([data-section="fixture"] .day-stack .time) {
    color: var(--pm-blue-900);
    font-size: 0.7rem;
  }

  :global([data-section="fixture"] .day-stack .team) {
    display: flex;
    align-items: center;
    gap: 0.28rem;
    min-width: 0;
  }

  :global([data-section="fixture"] .day-stack .team.away) {
    justify-content: flex-end;
    text-align: right;
  }

  :global([data-section="fixture"] .day-stack .flag) {
    display: inline-block;
    width: 1.36rem;
    height: 1rem;
    overflow: hidden;
    border: 1px solid var(--pm-border-soft);
    border-radius: 0.26rem;
    background: rgba(255, 255, 255, 0.85);
    flex: 0 0 auto;
    line-height: 0;
  }

  :global([data-section="fixture"] .day-stack .flag img) {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  :global([data-section="fixture"] .day-stack .team-name) {
    min-width: 0;
    overflow: hidden;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 800;
    text-overflow: ellipsis;
    text-transform: uppercase;
    white-space: nowrap;
  }

  :global([data-section="fixture"] .day-stack .group-badge),
  :global([data-section="fixture"] .day-stack .status-pill) {
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  :global([data-section="fixture"] .day-stack .status-pill[data-consensus="unanimous"]) {
    border-color: var(--pm-mint-500);
    background: color-mix(in srgb, var(--pm-mint-500) 18%, white);
    color: var(--pm-green-700);
  }

  :global([data-section="fixture"] .day-stack .status-pill[data-consensus="divided"]) {
    border-color: var(--pm-red-500);
    background: color-mix(in srgb, var(--pm-red-500) 13%, white);
    color: var(--pm-red-600);
  }

  :global([data-section="fixture"] .day-stack .group-badge) {
    padding: 0.13rem 0.28rem;
    border-radius: 999px;
  }

  :global([data-section="fixture"] .day-stack .status-pill) {
    padding: 0.15rem 0.3rem;
    border: 1px solid var(--pm-border-soft);
    border-radius: 999px;
    background: rgba(241, 245, 249, 0.7);
  }

  @media (max-width: 900px) {
    :global([data-section="fixture"] .day-stack .match-row) {
      grid-template-columns: 1.55rem 2.45rem minmax(0, 1fr) auto minmax(0, 1fr) 3rem;
    }

    :global([data-section="fixture"] .day-stack .status-pill) {
      grid-column: 1 / -1;
      justify-self: end;
    }
  }

  @media (max-width: 560px) {
    :global([data-section="fixture"] .day-stack .match-row) {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      row-gap: 0.28rem;
    }

    :global([data-section="fixture"] .day-stack .match-number),
    :global([data-section="fixture"] .day-stack .time),
    :global([data-section="fixture"] .day-stack .group-badge) {
      grid-column: 1 / -1;
      justify-self: start;
    }

    :global([data-section="fixture"] .day-stack .group-badge) {
      justify-self: end;
    }
  }
</style>
