---
// Leyenda compacta de estados de la llave. Reusa el lenguaje de color de los nodos.
const items = [
  { label: "Por jugar", cls: "is-open" },
  { label: "Bloqueado", cls: "is-locked" },
  { label: "Completo", cls: "is-complete" },
  { label: "Por definir", cls: "is-pending" },
];
---

<ul class="ko-legend" aria-label="Estados de la llave">
  {items.map((it) => (
    <li class={`ko-legend-item ${it.cls}`}><span class="dot" aria-hidden="true"></span>{it.label}</li>
  ))}
</ul>

<style>
  .ko-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ko-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.64rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--pm-text-soft);
  }
  .ko-legend-item .dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    border: 2px solid var(--pm-border-blue);
    background: var(--pm-white);
  }
  .is-locked .dot { background: var(--pm-purple-200); border-color: var(--pm-purple-400); }
  .is-complete .dot { background: var(--pm-green-100); border-color: var(--pm-state-completed-border, #16a34a); }
  .is-pending .dot { background: var(--pm-blue-50, rgba(18, 109, 255, 0.08)); border-style: dashed; }
</style>
