---
// Seccion 07_fixture — LLAVE ELIMINATORIA completa (R32 -> Final) en modo SOLO LECTURA.
// SSR resuelve el bracket con el SEED (knockout-results.json); el cliente lo re-resuelve con
// los resultados VIVOS de localStorage (admin) y parchea: equipos resueltos, ganadores,
// desbloqueo y el pronostico guardado del jugador. 100% local.
import styles from "./FixtureSection.module.css";
import BracketTree from "./BracketTree.astro";

import knockoutData from "../../data/knockout-matches.json";
import teamsData from "../../data/teams.json";
import seed from "../../data/knockout-results.json";
import { sortBySlot } from "../../lib/knockout/model";
import type { KnockoutMatch } from "../../lib/knockout/model";
import { buildTeamsByCode } from "../../lib/knockout/canPredict.js";
import { resolveBracket } from "../../lib/knockout/bracket.js";
import { buildBracketTree } from "../../lib/knockout/bracketTree.js";

const teamsByCode = buildTeamsByCode(teamsData as any[]);
const allMatches = sortBySlot(knockoutData.matches as KnockoutMatch[]);
const resolved = resolveBracket(allMatches, {
  assignments: (seed as any).slotAssignments ?? {},
  results: (seed as any).results ?? [],
  teamsByCode,
});
const tree = buildBracketTree(allMatches);

// Payload mínimo para resolver en cliente.
const teamsLite = (teamsData as any[]).map((t) => ({ code: t.shortCode, name: t.name, shortCode: t.shortCode, flag: t.flag }));
const clientPayload = {
  matches: allMatches,
  teams: teamsLite,
  seedAssignments: (seed as any).slotAssignments ?? {},
  seedResults: (seed as any).results ?? [],
};
---

<section class={styles.fixtureArcadeStage} id="fixture" data-section="fixture">
  <div class={styles.contentShell}>
    <BracketTree tree={tree} items={resolved} />
    <div class={styles.bottomHud} data-bottom-hud aria-hidden="true">
      <span>Vive la pasión</span>
      <strong>SECPLAN 2026</strong>
      <span>Tu pronóstico hace historia</span>
    </div>
  </div>

  <script type="application/json" data-knockout-readonly set:html={JSON.stringify(clientPayload)} />
  <script>
    import "./fixture.bracket.client.js";
    import "./bracket-tree.client.js";
  </script>
</section>
