---
import type { FixtureMatch, MatchStatusVisual } from "./fixture.logic";
import { formatChileTime, getMatchStatusVisual, getStatusLabel, isSameChileDay } from "./fixture.logic";

interface Props {
  agendaMatches: FixtureMatch[];
  selectedDateChile: string;
}

const { agendaMatches, selectedDateChile } = Astro.props;
const now = new Date();
const isTodayAgenda = isSameChileDay(selectedDateChile, now);
const agendaCountLabel = isTodayAgenda
  ? `${agendaMatches.length} partidos hoy`
  : `${agendaMatches.length} partidos`;
---

<section class="agenda-panel" data-agenda-panel aria-label="Agenda del dia">
  <header class="agenda-header">
    <span class="icon" aria-hidden="true">
      <img src="/assets/polla-mundialera/sections/07_fixture/icon-circle-calendar-blue.webp" alt="" width="264" height="274" loading="lazy" decoding="async" />
    </span>
    <h3>Agenda del dia</h3>
    <span class="count" data-agenda-count>{agendaCountLabel}</span>
  </header>

  <ul class="agenda-rows" data-agenda-rows role="list">
    {agendaMatches.length === 0 ? (
      <li class="empty">
        <span>Sin partidos programados para esta fecha.</span>
      </li>
    ) : (
      agendaMatches.slice(0, 5).map((match) => {
        const status: MatchStatusVisual = getMatchStatusVisual(match, now);
        return (
          <li>
            <span class="time">{formatChileTime(match.dateUtc)}</span>
            <span class="matchline">
              <span class="team home">{match.homeTeam.name}</span>
              <span class="vs" aria-hidden="true">vs</span>
              <span class="team away">{match.awayTeam.name}</span>
              <span class="group">{match.groupLabel.replace("Grupo ", "G ")}</span>
            </span>
            <span class="status" data-status={status}>{getStatusLabel(status)}</span>
          </li>
        );
      })
    )}
  </ul>
</section>

<style>
  .agenda-panel {
    display: flex;
    flex-direction: column;
    gap: 0.58rem;
    min-height: 14rem;
    padding: 0.72rem;
    border: 1px solid color-mix(in srgb, var(--pm-sec-fixture-a) 26%, transparent);
    border-radius: 0.72rem;
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-sec-fixture-a) 15%, transparent),
        color-mix(in srgb, var(--pm-sec-fixture-b) 18%, transparent)
      ),
      var(--pm-panel-soft);
  }

  .agenda-header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.32rem;
    align-items: center;
    padding-bottom: 0.34rem;
    border-bottom: 1px solid rgba(7, 23, 53, 0.1);
  }

  .icon {
    display: grid;
    place-items: center;
    min-width: 1.35rem;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 0.45rem;
  }

  .icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  h3 {
    margin: 0;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .count {
    color: var(--pm-blue-700);
    font-size: 0.54rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .agenda-rows {
    display: flex;
    flex-direction: column;
    gap: 0.34rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .agenda-rows li {
    display: grid;
    grid-template-columns: 2.45rem minmax(0, 1fr) 3.25rem;
    gap: 0.42rem;
    align-items: center;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(7, 23, 53, 0.08);
    font-size: 0.68rem;
  }

  .agenda-rows li:last-child {
    border-bottom: 0;
  }

  .agenda-rows li.empty {
    display: block;
    padding: 0.45rem 0;
    color: var(--pm-blue-700);
    text-align: center;
  }

  .time {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-weight: 900;
  }

  .matchline {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.24rem;
    overflow: hidden;
  }

  .team {
    color: var(--pm-blue-900);
    font-weight: 800;
    text-transform: uppercase;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .team.away {
    text-align: left;
  }

  .vs {
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 800;
    text-align: center;
  }

  .group,
  .status {
    padding: 0.14rem 0.26rem;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  .group {
    border: 1px solid var(--pm-border-soft);
    color: var(--pm-blue-700);
  }

  .status {
    border: 1px solid var(--pm-border-soft);
    background: rgba(241, 245, 249, 0.7);
    color: var(--pm-blue-700);
  }

  .status[data-status="live"] {
    background: var(--pm-state-live-bg);
    color: var(--pm-state-live-text);
    border-color: var(--pm-state-live-border);
  }

  .status[data-status="finished"] {
    color: var(--pm-text-soft);
  }

  :global([data-section="fixture"] [data-agenda-rows]) {
    display: flex;
    flex-direction: column;
    gap: 0.34rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global([data-section="fixture"] [data-agenda-rows] li) {
    display: grid;
    grid-template-columns: 2.45rem minmax(0, 1fr) 3.25rem;
    gap: 0.42rem;
    align-items: center;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(7, 23, 53, 0.08);
    font-size: 0.68rem;
  }

  :global([data-section="fixture"] [data-agenda-rows] li:last-child) {
    border-bottom: 0;
  }

  :global([data-section="fixture"] [data-agenda-rows] li.empty) {
    display: block;
    padding: 0.45rem 0;
    color: var(--pm-blue-700);
    text-align: center;
  }

  :global([data-section="fixture"] [data-agenda-rows] .time) {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-weight: 900;
  }

  :global([data-section="fixture"] [data-agenda-rows] .matchline) {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.24rem;
    overflow: hidden;
  }

  :global([data-section="fixture"] [data-agenda-rows] .team) {
    min-width: 0;
    overflow: hidden;
    color: var(--pm-blue-900);
    font-weight: 800;
    text-overflow: ellipsis;
    text-transform: uppercase;
    white-space: nowrap;
  }

  :global([data-section="fixture"] [data-agenda-rows] .vs) {
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 800;
    text-align: center;
  }

  :global([data-section="fixture"] [data-agenda-rows] .group),
  :global([data-section="fixture"] [data-agenda-rows] .status) {
    padding: 0.14rem 0.26rem;
    border: 1px solid var(--pm-border-soft);
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  :global([data-section="fixture"] [data-agenda-rows] .group) {
    color: var(--pm-blue-700);
  }

  :global([data-section="fixture"] [data-agenda-rows] .status) {
    background: rgba(241, 245, 249, 0.7);
    color: var(--pm-blue-700);
  }

  :global([data-section="fixture"] [data-agenda-rows] .status[data-status="live"]) {
    background: var(--pm-state-live-bg);
    color: var(--pm-state-live-text);
    border-color: var(--pm-state-live-border);
  }

  :global([data-section="fixture"] [data-agenda-rows] .status[data-status="finished"]) {
    color: var(--pm-text-soft);
  }

  @media (max-width: 720px) {
    .agenda-rows li {
      grid-template-columns: 2.45rem minmax(0, 1fr);
      row-gap: 0.15rem;
    }

    .agenda-rows li > .status {
      grid-column: 1 / -1;
      justify-self: end;
    }

    :global([data-section="fixture"] [data-agenda-rows] li) {
      grid-template-columns: 2.45rem minmax(0, 1fr);
      row-gap: 0.15rem;
    }

    :global([data-section="fixture"] [data-agenda-rows] li > .status) {
      grid-column: 1 / -1;
      justify-self: end;
    }
  }
</style>
