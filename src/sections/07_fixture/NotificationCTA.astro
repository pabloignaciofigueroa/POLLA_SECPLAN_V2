---
---

<aside class="notification-cta" role="note">
  <div class="copy">
    <span class="bell" aria-hidden="true">♪</span>
    <div>
      <p class="primary">Recibe alertas de tus partidos favoritos</p>
      <p class="hint">Funcionalidad disponible en próxima fase.</p>
    </div>
  </div>

  <button type="button" class="cta" data-notification-cta disabled aria-disabled="true">
    ACTIVAR NOTIFICACIONES <span aria-hidden="true">›</span>
  </button>
</aside>

<style>
  .notification-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: center;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.78);
  }

  .copy {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.6rem;
    align-items: center;
    min-width: 0;
  }

  .bell {
    display: grid;
    place-items: center;
    width: 1.8rem;
    height: 1.8rem;
    border: 1px dashed var(--color-muted);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 900;
  }

  .primary {
    margin: 0;
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .hint {
    margin: 0.05rem 0 0;
    color: var(--color-muted);
    font-size: 0.66rem;
    font-weight: 700;
  }

  .cta {
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(241, 245, 249, 0.7);
    color: var(--color-text);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: not-allowed;
    opacity: 0.78;
  }

  @media (max-width: 720px) {
    .notification-cta {
      grid-template-columns: 1fr;
    }
  }
</style>
