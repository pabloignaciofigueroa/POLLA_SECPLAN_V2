---
interface StageOption {
  id: string;
  label: string;
  available: boolean;
}

interface GroupOption {
  id: string;
  label: string;
}

interface Props {
  stages: StageOption[];
  groups: GroupOption[];
  initialStage: string;
  initialGroup: string;
}

const { stages, groups, initialStage, initialGroup } = Astro.props;
---

<div class="filters" role="region" aria-label="Filtros del fixture">
  <div class="stage-tabs" role="tablist" aria-label="Filtros por etapa">
    {stages.map((stage) => (
      <button
        type="button"
        class="stage-tab"
        data-stage-tab={stage.id}
        data-active={stage.id === initialStage ? "true" : "false"}
        data-available={stage.available ? "true" : "false"}
        aria-pressed={stage.id === initialStage ? "true" : "false"}
      >
        {stage.label}
      </button>
    ))}
  </div>

  <div class="group-select">
    <div class="select-shell">
      <span class="select-prefix" aria-hidden="true">FIL</span>
      <span class="select-icon" aria-hidden="true">▾</span>
      <select id="fixture-group-select" data-group-select aria-label="Filtrar por grupo">
        <option value="all" selected={initialGroup === "all"}>Todos los grupos</option>
        {groups.map((group) => (
          <option value={group.id} selected={initialGroup === group.id}>{group.label}</option>
        ))}
      </select>
    </div>
  </div>
</div>

<style>
  .filters {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(0.55rem, 1vw, 0.9rem);
    align-items: center;
    padding: 0.55rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: var(--pm-shadow-soft);
  }

  .stage-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.32rem;
    min-width: 0;
  }

  .stage-tab {
    padding: 0.35rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--pm-blue-500) 18%, transparent);
    border-radius: 999px;
    background: transparent;
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color var(--pm-transition-fast),
      background var(--pm-transition-fast),
      color var(--pm-transition-fast),
      box-shadow var(--pm-transition-fast);
  }

  .stage-tab:hover {
    border-color: var(--pm-blue-400);
    background: rgba(255, 255, 255, 0.75);
  }

  .stage-tab:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  .stage-tab[data-active="true"] {
    background: linear-gradient(135deg, var(--pm-cyan-500), var(--pm-blue-500));
    color: var(--pm-white);
    border-color: var(--pm-blue-500);
    box-shadow: var(--pm-shadow-cyan);
  }

  .stage-tab[data-available="false"] {
    color: var(--pm-purple-500);
    border-style: dashed;
    border-color: color-mix(in srgb, var(--pm-purple-500) 45%, transparent);
  }

  .group-select {
    min-width: 13rem;
  }

  .select-shell {
    position: relative;
    display: flex;
    align-items: center;
    min-width: 0;
    border: 1px solid color-mix(in srgb, var(--pm-blue-500) 24%, transparent);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
  }

  .select-prefix {
    padding-left: 0.65rem;
    color: var(--pm-blue-500);
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .select-icon {
    position: absolute;
    right: 0.8rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--pm-blue-600);
    font-size: 0.72rem;
    font-weight: 900;
  }

  select {
    appearance: none;
    width: 100%;
    padding: 0.5rem 2rem 0.5rem 0.55rem;
    border: 0;
    background: transparent;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
  }

  select:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
    border-radius: 999px;
  }

  @media (max-width: 920px) {
    .filters {
      grid-template-columns: 1fr;
    }

    .group-select {
      min-width: 0;
    }
  }

  @media (max-width: 720px) {
    .stage-tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.15rem;
      -webkit-overflow-scrolling: touch;
    }

    .stage-tab {
      flex-shrink: 0;
    }
  }
</style>
