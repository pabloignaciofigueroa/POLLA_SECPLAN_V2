---
interface Team {
  id: string;
  name: string;
  shortCode: string;
}

interface Props {
  place: "first" | "second";
  label: string;
  teams: Team[];
}

const { place, label, teams } = Astro.props;
---

<label class="qualified-select">
  <span data-qualified-label={place}>{label}</span>
  <select data-qualified-select={place} aria-label={label}>
    <option value="">Selecciona equipo</option>
    {teams.map((team) => (
      <option value={team.id}>{team.name}</option>
    ))}
  </select>
</label>

<style>
  .qualified-select {
    display: grid;
    gap: 0.35rem;
  }

  span {
    color: var(--color-text);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  select {
    width: 100%;
    min-height: 3.05rem;
    padding: 0 0.85rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.78);
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: 850;
  }

  select[data-error="true"] {
    border-color: var(--color-text);
    box-shadow: inset 3px 0 0 var(--color-text);
  }
</style>
