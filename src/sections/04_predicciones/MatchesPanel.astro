---
import MatchPredictionRow from "./MatchPredictionRow.astro";

interface Team {
  id: string;
  name: string;
  shortCode: string;
}

interface Match {
  id: string;
  groupId: string;
  matchNumber: number;
  homeTeam: Team;
  awayTeam: Team;
}

interface Props {
  matches: Match[];
  activeGroupId: string;
}

const { matches, activeGroupId } = Astro.props;
const groupIds = [...new Set(matches.map((match) => match.groupId))];
---

<section class="matches-panel" aria-labelledby="matches-title">
  <div class="panel-header">
    <h2 id="matches-title" data-matches-title>GRUPO {activeGroupId}</h2>
    <span>match-predictions-table</span>
  </div>

  <div class="table-head" aria-hidden="true">
    <span></span>
    <span>LOCAL</span>
    <span>MARCADOR</span>
    <span>VISITANTE</span>
    <span></span>
  </div>

  {groupIds.map((groupId) => (
    <div class="match-group" data-match-group={groupId} hidden={groupId !== activeGroupId}>
      {matches
        .filter((match) => match.groupId === groupId)
        .map((match, index) => <MatchPredictionRow match={match} rowNumber={index + 1} />)}
    </div>
  ))}
</section>

<style>
  .matches-panel {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--pm-sec-predicciones-a) 36%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-sec-predicciones-a) 14%, transparent),
        color-mix(in srgb, var(--pm-sec-predicciones-b) 18%, transparent)
      ),
      var(--pm-panel-soft);
    box-shadow: 0 18px 45px rgba(7, 23, 53, 0.08);
  }

  @media (max-width: 640px) {
    .matches-panel {
      background:
        linear-gradient(
          135deg,
          color-mix(in srgb, var(--pm-sec-predicciones-a) 9%, transparent),
          color-mix(in srgb, var(--pm-sec-predicciones-b) 12%, transparent)
        ),
        var(--pm-panel-soft);
    }
  }

  .panel-header,
  .table-head {
    display: grid;
    grid-template-columns: 4rem minmax(10rem, 1fr) minmax(11rem, 0.7fr) minmax(10rem, 1fr) 3rem;
    align-items: center;
    gap: 0.6rem;
  }

  .panel-header {
    padding: 0.62rem 0.85rem;
    border-bottom: 1px solid color-mix(in srgb, var(--pm-sec-predicciones-a) 30%, transparent);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--pm-sec-predicciones-a) 20%, transparent),
      color-mix(in srgb, var(--pm-cyan-500) 16%, transparent)
    );
  }

  h2 {
    grid-column: 1 / 3;
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .panel-header span {
    grid-column: 3 / -1;
    justify-self: end;
    color: var(--color-muted);
    font-size: 0.62rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .table-head {
    padding: 0.38rem 0.85rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-text);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .table-head span:nth-child(3) {
    text-align: center;
  }

  .table-head span:nth-child(4) {
    text-align: right;
  }

  .match-group[hidden] {
    display: none;
  }

  @media (max-width: 760px) {
    .table-head {
      display: none;
    }

    .panel-header {
      display: flex;
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }
  }
</style>
