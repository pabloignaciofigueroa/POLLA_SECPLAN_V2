<button class="back-button" type="button" data-back-group>
  <span aria-hidden="true">←</span>
  ATRÁS
</button>

<style>
  .back-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    min-height: 3.35rem;
    width: 100%;
    border: 2px solid var(--pm-blue-600);
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--pm-blue-600), var(--pm-cyan-500));
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 950;
    box-shadow: var(--pm-shadow-blue);
    cursor: pointer;
    transition: transform var(--pm-transition-fast), box-shadow var(--pm-transition-fast);
  }

  .back-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 30px rgba(18, 109, 255, 0.32);
  }

  .back-button:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }
</style>
