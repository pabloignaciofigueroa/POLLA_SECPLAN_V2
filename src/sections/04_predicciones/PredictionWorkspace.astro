---
import MatchesPanel from "./MatchesPanel.astro";
import QualifiedPanel from "./QualifiedPanel.astro";
import RandomResultsButton from "./RandomResultsButton.astro";
import HelpCard from "./HelpCard.astro";

interface Team {
  id: string;
  name: string;
  shortCode: string;
}

interface Match {
  id: string;
  groupId: string;
  matchNumber: number;
  homeTeam: Team;
  awayTeam: Team;
}

interface Group {
  id: string;
  label: string;
  teams: Team[];
}

interface Props {
  matches: Match[];
  groups: Group[];
  activeGroupId: string;
}

const { matches, groups, activeGroupId } = Astro.props;
const activeGroup = groups.find((group) => group.id === activeGroupId) ?? groups[0];
const showDevTools = import.meta.env.DEV;
---

<div class="prediction-workspace" data-animate="fade-up" style="--i:2">
  <MatchesPanel matches={matches} activeGroupId={activeGroupId} />

  <aside class="side-panel">
    <QualifiedPanel group={activeGroup} />
    {showDevTools && <RandomResultsButton />}
    <HelpCard />
  </aside>
</div>

<style>
  .prediction-workspace {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(17rem, 0.34fr);
    gap: clamp(0.85rem, 1.6vw, 1.25rem);
    align-items: start;
    min-width: 0;
  }

  .side-panel {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: clamp(0.55rem, 1vw, 0.75rem);
  }

  @media (max-width: 1080px) {
    .prediction-workspace {
      grid-template-columns: 1fr;
    }
  }
</style>
