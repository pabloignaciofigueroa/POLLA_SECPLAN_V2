---
import QualifiedSelect from "./QualifiedSelect.astro";

interface Team {
  id: string;
  name: string;
  shortCode: string;
}

interface Group {
  id: string;
  label: string;
  teams: Team[];
}

interface Props {
  group: Group;
}

const { group } = Astro.props;
---

<section class="qualified-panel" aria-labelledby="qualified-title">
  <div class="panel-title">
    <span class="trophy-icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
        <path d="M10 13.5c-3.5 0-6-2.5-6-6V3h12v4.5c0 3.5-2.5 6-6 6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        <path d="M4 5H2a1 1 0 00-1 1v1.5C1 9 2.5 10.5 4 10.5M16 5h2a1 1 0 011 1v1.5c0 1.5-1.5 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M7.5 17h5M10 13.5V17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M6.5 19h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </span>
    <h2 id="qualified-title">CLASIFICADOS</h2>
  </div>

  <QualifiedSelect place="first" label={`1° del ${group.label}`} teams={group.teams} />
  <QualifiedSelect place="second" label={`2° del ${group.label}`} teams={group.teams} />

  <p class="error-message" data-qualified-error hidden>El 1° y 2° clasificado deben ser equipos distintos.</p>
</section>

<style>
  .qualified-panel {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0.85rem;
    border: 1px solid var(--pm-border-blue);
    border-radius: var(--radius-lg);
    background: var(--pm-white);
    box-shadow: 0 18px 45px rgba(7, 23, 53, 0.08);
  }

  .panel-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .trophy-icon {
    display: grid;
    width: 2rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, var(--pm-yellow-500), var(--pm-orange-400, #f97316));
    color: var(--pm-white);
  }

  h2,
  .error-message {
    margin: 0;
  }

  h2 {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 950;
  }

  .error-message {
    padding: 0.55rem 0.65rem;
    border: 1px solid var(--color-text);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.35;
  }
</style>
