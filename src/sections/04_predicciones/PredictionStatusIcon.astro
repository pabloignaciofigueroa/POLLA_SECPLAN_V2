<span class="status-icon" data-status-icon aria-label="Predicción vacía">—</span>

<style>
  .status-icon {
    display: grid;
    width: 2rem;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 950;
  }

  :global([data-match-row][data-status="complete"]) .status-icon {
    border-color: var(--pm-green-500, #16a34a);
    background: color-mix(in srgb, var(--pm-green-500, #16a34a) 10%, white);
    padding: 2px;
  }

  /* Asset inyectado por client.js debe obedecer el holder (SSR + hidratación). */
  :global([data-section="predicciones"] [data-status-icon] img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
