---
interface Props {
  kind: "general" | "group" | "groups" | "qualified";
  title: string;
  current: number;
  total: number;
  percentage: number;
  subtitle?: string;
}

const { kind, title, current, total, percentage, subtitle = "PARTIDOS COMPLETOS" } = Astro.props;
---

<article class="progress-card" data-progress-card={kind} data-kind={kind}>
  <div class="label-row">
    <span class="icon" aria-hidden="true">
      {kind === "general" ? (
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M1.5 8h13M8 1.5C6.5 4 5.5 6 5.5 8s1 4 2.5 6.5M8 1.5C9.5 4 10.5 6 10.5 8s-1 4-2.5 6.5" stroke="currentColor" stroke-width="1.2"/>
        </svg>
      ) : kind === "groups" ? (
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="1.5" y="1.5" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.4"/>
          <rect x="9" y="1.5" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.4"/>
          <rect x="1.5" y="9" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.4"/>
          <rect x="9" y="9" width="5.5" height="5.5" rx="1" stroke="currentColor" stroke-width="1.4"/>
        </svg>
      ) : kind === "qualified" ? (
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 1l1.9 3.85 4.25.62-3.07 3 .72 4.23L8 11.7l-3.8 2 .72-4.23-3.07-3 4.25-.62L8 1z"/>
        </svg>
      ) : (
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="5.5" cy="5" r="2.2" stroke="currentColor" stroke-width="1.4"/>
          <circle cx="10.5" cy="5" r="2.2" stroke="currentColor" stroke-width="1.4"/>
          <path d="M1 13.5c0-2.5 2-4 4.5-4M15 13.5c0-2.5-2-4-4.5-4M5.5 13.5c0-2 1.1-3.5 2.5-3.5s2.5 1.5 2.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      )}
    </span>
    <h2 data-progress-title={kind}>{title}</h2>
  </div>
  <p>
    <strong data-progress-current={kind}>{current}</strong>
    <span class="total-slash">/ <span data-progress-total={kind}>{total}</span></span>
  </p>
  <p class="subtitle">{subtitle}</p>
  <div class="meter" aria-hidden="true">
    <span data-progress-meter={kind} style={`width: ${percentage}%`}></span>
  </div>
  <small data-progress-percent={kind}>{percentage}%</small>
</article>

<style>
  .progress-card {
    position: relative;
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
    min-height: 5.8rem;
    padding: 0.65rem;
    border: 1px solid var(--pm-border-blue);
    border-radius: var(--pm-radius-lg);
    background: var(--pm-white);
    box-shadow: var(--pm-shadow-blue);
    overflow: hidden;
  }

  .progress-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--pm-blue-500), var(--pm-cyan-500), var(--pm-green-500));
  }

  .progress-card[data-kind="group"]::before {
    background: linear-gradient(90deg, var(--pm-purple-500), var(--pm-pink-500));
  }

  .label-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .icon {
    display: grid;
    width: 1.75rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--pm-blue-500), var(--pm-cyan-500));
    color: var(--pm-white);
  }

  .progress-card[data-kind="group"] .icon {
    background: linear-gradient(135deg, var(--pm-purple-500), var(--pm-pink-500));
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 900;
    line-height: 1.1;
    text-transform: uppercase;
  }

  p {
    display: flex;
    gap: 0.35rem;
    align-items: baseline;
    color: var(--pm-blue-900);
    font-variant-numeric: tabular-nums;
  }

  .subtitle {
    color: var(--pm-blue-600);
    font-size: 0.58rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-top: -0.2rem;
  }

  .total-slash {
    color: var(--pm-blue-600);
    font-size: 0.9rem;
  }

  strong {
    font-family: var(--font-score);
    font-size: clamp(1.8rem, 2.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1;
    min-width: 2ch;
    background: linear-gradient(135deg, var(--pm-blue-500), var(--pm-cyan-500));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .progress-card[data-kind="group"] strong {
    background: linear-gradient(135deg, var(--pm-purple-500), var(--pm-pink-500));
    -webkit-background-clip: text;
    background-clip: text;
  }

  .meter {
    overflow: hidden;
    height: 0.5rem;
    border: 1px solid var(--pm-border-blue);
    border-radius: 999px;
    background: var(--pm-panel-soft);
  }

  .meter span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--pm-blue-500), var(--pm-cyan-500), var(--pm-green-500));
    transition: width var(--pm-transition-base);
  }

  .progress-card[data-kind="group"] .meter span {
    background: linear-gradient(90deg, var(--pm-purple-500), var(--pm-pink-500), var(--pm-green-500));
  }

  /* GRUPOS (x/12) — acento verde */
  .progress-card[data-kind="groups"]::before {
    background: linear-gradient(90deg, var(--pm-green-500), var(--pm-mint-500));
  }
  .progress-card[data-kind="groups"] .icon {
    background: linear-gradient(135deg, var(--pm-green-600), var(--pm-mint-500));
  }
  .progress-card[data-kind="groups"] strong {
    background: linear-gradient(135deg, var(--pm-green-600), var(--pm-mint-500));
    -webkit-background-clip: text;
    background-clip: text;
  }
  .progress-card[data-kind="groups"] .meter span {
    background: linear-gradient(90deg, var(--pm-green-600), var(--pm-mint-500));
  }

  /* CLASIFICADOS (x/24) — acento oro */
  .progress-card[data-kind="qualified"]::before {
    background: linear-gradient(90deg, var(--pm-gold-500), var(--pm-yellow-500));
  }
  .progress-card[data-kind="qualified"] .icon {
    background: linear-gradient(135deg, var(--pm-gold-700), var(--pm-gold-500));
  }
  .progress-card[data-kind="qualified"] strong {
    background: linear-gradient(135deg, var(--pm-gold-700), var(--pm-gold-500));
    -webkit-background-clip: text;
    background-clip: text;
  }
  .progress-card[data-kind="qualified"] .meter span {
    background: linear-gradient(90deg, var(--pm-gold-500), var(--pm-yellow-500));
  }

  small {
    align-self: flex-end;
    color: var(--pm-blue-700);
    font-size: 0.7rem;
    font-weight: 850;
  }
</style>
