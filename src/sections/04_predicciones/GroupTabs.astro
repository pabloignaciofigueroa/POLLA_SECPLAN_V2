---
import GroupTab from "./GroupTab.astro";

interface Group {
  id: string;
  label: string;
}

interface Props {
  groups: Group[];
  activeGroupId: string;
}

const { groups, activeGroupId } = Astro.props;
---

<div class="tabs-shell" data-animate="fade-up" style="--i:1">
  <nav class="group-tabs" aria-label="Grupos del Mundial">
    {groups.map((group) => (
      <GroupTab group={group} active={group.id === activeGroupId} />
    ))}
  </nav>
</div>

<style>
  .tabs-shell {
    background: rgba(255, 255, 255, 0.75);
    border: 1px solid var(--pm-border-blue);
    border-radius: var(--pm-radius-md);
    padding: 0.3rem 0.4rem;
  }

  .group-tabs {
    display: grid;
    grid-template-columns: repeat(12, minmax(3.2rem, 1fr));
    gap: 0.45rem;
    overflow-x: auto;
    padding: 0.1rem 0.05rem;
    scrollbar-width: thin;
  }

  @media (max-width: 900px) {
    .group-tabs {
      grid-template-columns: repeat(12, minmax(3.8rem, 1fr));
    }
  }
</style>
