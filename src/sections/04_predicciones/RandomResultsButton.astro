---

<button class="random-button" type="button" data-random-results>
  <span class="rnd-icon" aria-hidden="true">
    <img src="/assets/polla-mundialera/sections/04_predicciones/icon-circle-refresh-blue.webp" alt="" width="259" height="265" loading="lazy" decoding="async" />
  </span>
  RESULTADOS RANDOM
</button>

<style>
  .random-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 3.25rem;
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--pm-purple-400);
    border-radius: var(--pm-radius-md);
    background: var(--pm-purple-200);
    color: var(--pm-purple-700);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 950;
    cursor: pointer;
    text-transform: uppercase;
    transition:
      background var(--pm-transition-fast),
      border-color var(--pm-transition-fast),
      color var(--pm-transition-fast),
      transform var(--pm-transition-fast),
      box-shadow var(--pm-transition-fast);
  }

  .random-button:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring-pink);
  }

  .rnd-icon {
    display: grid;
    width: 1.9rem;
    aspect-ratio: 1;
    place-items: center;
  }

  .rnd-icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (hover: hover) and (pointer: fine) {
    .random-button:hover {
      background: linear-gradient(135deg, var(--pm-purple-500), var(--pm-cyan-500));
      border-color: var(--pm-purple-600);
      color: var(--pm-white);
      transform: translateY(-1px);
      box-shadow: var(--pm-shadow-purple);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .random-button,
    .random-button:hover {
      transform: none;
    }
  }
</style>
