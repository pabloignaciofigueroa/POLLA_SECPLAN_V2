---
// Seccion 13_tabla — CARRERA SECPLAN. Tabla dinámica de jugadores. 100% local.
// IZQ: PODIO (top-3 con foto+medalla) + ESCALERA (ranking con barra de progreso + movimiento).
// DER: PARTIDO EN CURSO (live card) + PREDICCIONES DE JUGADORES + LEYENDA.
// Puntúa contra los resultados vivos del admin (pre-torneo: 0 pts / "--"). El marcador EN VIVO
// suma provisional (cambia con cada gol) pero NO avanza el cuadro.
// Hooks preservados: data-tabla-{row,cell,body,note,count,move,podium,cruce*,pred*}.
import playersData from "../../data/players.json";
import knockoutData from "../../data/knockout-matches.json";
import teamsData from "../../data/teams.json";
import seed from "../../data/knockout-results.json";
import submissionsData from "../../data/knockout-predictions.json";

const players = (playersData as any[]).map((p) => ({ id: p.id, name: p.name, avatar: p.avatar, avatarThumb: p.avatarThumb ?? p.avatar }));
const teamsLite = (teamsData as any[]).map((t) => ({ code: t.shortCode, name: t.name, shortCode: t.shortCode, flag: t.flag }));
const clientPayload = {
  players,
  matches: (knockoutData as any).matches,
  teams: teamsLite,
  seedAssignments: (seed as any).slotAssignments ?? {},
  seedResults: (seed as any).results ?? [],
  submissions: (submissionsData as any).submissions ?? [],
};

// Podio: orden visual 2º · 1º · 3º (el 1º al centro y más alto).
const podiumOrder = [2, 1, 3] as const;
---

<section class="tk" id="tabla" data-section="tabla">
  <div class="tk-shell">
    <header class="tk-hero" data-animate="fade-up" style="--i:0">
      <div class="tk-hero-main">
        <p class="tk-eyebrow">⚡ ranking en vivo · podio · drama mundialero</p>
        <h1 class="tk-title">Carrera <span class="tk-title-accent">SECPLAN</span></h1>
      </div>
      <span class="tk-status" data-tabla-note>Torneo no iniciado</span>
    </header>

    <div class="tk-grid">
      <!-- ===== IZQ: PODIO + RANKING ===== -->
      <section class="tk-col tk-col--rank" aria-label="Podio y ranking">
        <!-- PODIO TOP-3 -->
        <ol class="tk-podium" data-tabla-podium data-started="false" aria-label="Podio top 3">
          {podiumOrder.map((slot) => (
            <li class={`tk-pod tk-pod--${slot}`} data-podium={slot}>
              <span class="tk-pod-rank">{slot}</span>
              <span class="tk-pod-avatar"><img data-podium-avatar src="" alt="" width="72" height="72" loading="lazy" /></span>
              <span class="tk-pod-name" data-podium-name>—</span>
              <span class="tk-pod-pts"><b data-podium-pts>0</b> pts</span>
            </li>
          ))}
        </ol>

        <h2 class="tk-col-title">Ranking <span data-tabla-count>{players.length}</span></h2>
        <ol class="tk-ladder" data-tabla-body data-started="false" data-stagger>
          {players.map((p, i) => (
            <li
              class="tk-card"
              data-tabla-row={p.id}
              data-leader="false"
              data-change="same"
              data-animate="fade-up"
              style={`--i:${Math.min(i + 1, 8)}`}
              role="button"
              tabindex="0"
              aria-expanded="false"
              aria-label={`Ver cómo sumó puntos ${p.name}`}
            >
              <span class="tk-rank" data-cell="pos">{i + 1}</span>
              <span class="tk-avatar">{p.avatarThumb ? <img src={p.avatarThumb} alt="" width="40" height="40" loading="lazy" /> : null}</span>
              <div class="tk-id">
                <span class="tk-name">{p.name}</span>
                <span class="tk-bar" aria-hidden="true"><span class="tk-bar-fill" data-cell="bar" style="width:0%"></span></span>
              </div>
              <span class="tk-pts"><b data-cell="total">0</b><small>pts</small></span>
              <span class="tk-move" data-tabla-move></span>
              <span class="tk-caret" aria-hidden="true">▾</span>
              <div class="tk-history" data-tabla-history hidden></div>
            </li>
          ))}
        </ol>
      </section>

      <!-- ===== DER: LIVE + IMPACTO + LEYENDA ===== -->
      <section class="tk-col tk-col--live" aria-label="Partido en curso y predicciones">
        <h2 class="tk-col-title">Partido en curso</h2>
        <div class="tk-live" data-tabla-cruce data-state="pending">
          <span class="tk-live-when" data-tabla-cruce-when>Por definir</span>
          <div class="tk-live-vs">
            <div class="tk-live-team">
              <span class="tk-live-flag" data-tabla-cruce-home-flag data-empty="true" aria-hidden="true"></span>
              <span class="tk-live-name" data-tabla-cruce-home>—</span>
            </div>
            <span class="tk-live-score" data-tabla-cruce-score>– : –</span>
            <div class="tk-live-team tk-live-team--away">
              <span class="tk-live-flag" data-tabla-cruce-away-flag data-empty="true" aria-hidden="true"></span>
              <span class="tk-live-name" data-tabla-cruce-away>—</span>
            </div>
          </div>
          <span class="tk-live-state" data-tabla-cruce-state>Por jugar</span>
        </div>

        <!-- PODIO MUNDIAL: se arma en vivo con P103 (3o/4o) y P104 (campeon/subcampeon).
             data-live="true" en un slot = provisional (partido en curso, cambia con cada gol). -->
        <h2 class="tk-col-title">Podio mundial <span class="tk-wpod-tag" data-wpodium-tag hidden>en vivo</span></h2>
        <ol class="tk-wpod" data-tabla-wpodium aria-label="Podio del mundial">
          {[
            { slot: "champion", medal: "🥇", label: "Campeón", pts: "+5" },
            { slot: "runnerUp", medal: "🥈", label: "Subcampeón", pts: "+3" },
            { slot: "third", medal: "🥉", label: "Tercero", pts: "+1" },
            { slot: "fourth", medal: "4º", label: "Cuarto", pts: "+1" },
          ].map((s) => (
            <li class="tk-wpod-slot" data-wpod={s.slot} data-live="false" data-set="false">
              <span class="tk-wpod-medal">{s.medal}</span>
              <span class="tk-wpod-flag" data-wpod-flag data-empty="true" aria-hidden="true"></span>
              <span class="tk-wpod-team" data-wpod-team>—</span>
              <span class="tk-wpod-meta">{s.label} <b>{s.pts}</b></span>
            </li>
          ))}
        </ol>

        <!-- Una fila por jugador con TODO: su apuesta del partido (marcador/avanza/pts),
             su podio apostado por puesto, los puntos de podio y el TOTAL parcial. -->
        <h2 class="tk-col-title">Predicciones de jugadores</h2>
        <div class="tk-preds-head" aria-hidden="true">
          <span>Jugador</span><span>Marcador</span><span>Avanza</span><span>Pts</span>
          <span>🥇</span><span>🥈</span><span>🥉</span><span>4º</span><span>Podio</span><span>Total</span>
        </div>
        <ul class="tk-preds" data-tabla-preds>
          {players.map((p) => (
            <li class="tk-pred-row" data-tabla-pred={p.id}>
              <span class="tk-pred-name">{p.name}</span>
              <span class="tk-pred-marker">
                <span class="tk-pred-flag" data-pred-flag data-empty="true" aria-hidden="true"></span>
                <span class="tk-pred-score" data-pred-score>– : –</span>
              </span>
              <span class="tk-pred-adv" data-pred-adv>–</span>
              <span class="tk-pred-pts" data-pred-pts>–</span>
              <span class="tk-wpred-pick" data-wpick="champion" data-state="pending">—</span>
              <span class="tk-wpred-pick" data-wpick="runnerUp" data-state="pending">—</span>
              <span class="tk-wpred-pick" data-wpick="third" data-state="pending">—</span>
              <span class="tk-wpred-pick" data-wpick="fourth" data-state="pending">—</span>
              <span class="tk-wpred-pts" data-wpick-pts>–</span>
              <span class="tk-pred-total" data-pred-total>0</span>
            </li>
          ))}
        </ul>

        <div class="tk-leyenda" aria-label="Leyenda de puntos">
          <span class="tk-ley tk-ley--exact">🎯 Exacto <b>+5/+3</b></span>
          <span class="tk-ley tk-ley--win">✓ Ganador <b>+1</b></span>
          <span class="tk-ley tk-ley--pod">🏆 Podio <b>+5/+3/+1/+1</b></span>
        </div>
      </section>
    </div>
  </div>

  <script type="application/json" data-tabla-payload set:html={JSON.stringify(clientPayload)} />
  <script>
    import "./tabla.knockout.client.js";
  </script>
</section>

<style>
  .tk {
    --section-accent: var(--pm-sec-tabla-a);
    --section-accent-2: var(--pm-sec-tabla-b);
    position: relative;
    min-height: calc(100svh - var(--layout-header-height));
    padding: clamp(0.7rem, 1.6vw, 1.3rem);
    background-image: image-set(
      url("/assets/backgrounds/avif/05_tabla_background.avif") type("image/avif"),
      url("/assets/backgrounds/webp/05_tabla_background.webp") type("image/webp"));
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--pm-text-main);
    font-family: var(--font-ui);
  }
  .tk-shell { width: min(100% - 1rem, 82rem); margin-inline: auto; display: flex; flex-direction: column; gap: clamp(0.5rem, 1vw, 0.85rem); }

  .tk-hero { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .tk-hero-main { display: flex; flex-direction: column; align-items: flex-start; gap: 0.2rem; }
  .tk-eyebrow {
    margin: 0; padding: 0.26rem 0.85rem; border-radius: 999px;
    background: color-mix(in srgb, var(--section-accent) 18%, var(--pm-white));
    border: 1px solid color-mix(in srgb, var(--section-accent) 42%, var(--pm-white));
    color: var(--pm-text-main); font-family: var(--font-display); font-weight: 900;
    font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase;
  }
  .tk-title { margin: 0; font-family: var(--font-display); font-weight: 950; font-size: clamp(1.6rem, 3.6vw, 2.7rem); text-transform: uppercase; line-height: 0.95; color: var(--pm-blue-900); }
  .tk-title-accent { background: linear-gradient(100deg, var(--pm-sec-tabla-a), var(--pm-sec-tabla-b)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .tk-status {
    font-family: var(--font-display); font-weight: 800; font-size: 0.66rem; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--pm-blue-800);
    padding: 0.3rem 0.75rem; border-radius: 999px; background: rgba(255, 255, 255, 0.78);
    border: 1px solid var(--pm-border-soft); box-shadow: var(--pm-shadow-soft);
  }

  /* ===== Grid 2 columnas ===== */
  .tk-grid { display: grid; grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr); gap: clamp(0.6rem, 1.4vw, 1.1rem); align-items: start; }
  .tk-col { min-width: 0; display: flex; flex-direction: column; gap: 0.5rem; min-height: 0; }
  .tk-col-title { margin: 0; font-family: var(--font-display); font-weight: 900; font-size: 0.82rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--pm-blue-900); }
  .tk-col-title span { color: var(--pm-cyan-600); }

  /* ===== PODIO ===== */
  .tk-podium { list-style: none; margin: 0; padding: 0.2rem 0 0; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.5rem; align-items: end; }
  .tk-pod {
    position: relative; display: flex; flex-direction: column; align-items: center; gap: 0.15rem;
    padding: 0.4rem 0.5rem 0.4rem; border-radius: var(--pm-radius-md);
    background: linear-gradient(160deg, color-mix(in srgb, var(--pod-color, var(--pm-blue-500)) 24%, var(--pm-white)), var(--pm-white) 78%);
    border: 1px solid color-mix(in srgb, var(--pod-color, var(--pm-blue-500)) 36%, var(--pm-border-soft));
    box-shadow: 0 14px 30px color-mix(in srgb, var(--pod-color, var(--pm-blue-500)) 28%, transparent), inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }
  .tk-pod--1 { --pod-color: var(--pm-rank-gold); transform: translateY(-0.4rem); padding-top: 0.6rem; }
  .tk-pod--2 { --pod-color: var(--pm-rank-silver); }
  .tk-pod--3 { --pod-color: var(--pm-rank-bronze); }
  .tk-pod-rank {
    position: absolute; top: -0.5rem; left: 50%; transform: translateX(-50%);
    width: 1.45rem; height: 1.45rem; display: grid; place-items: center; border-radius: 999px;
    font-family: var(--font-display); font-weight: 950; font-size: 0.78rem; color: #3a2a00;
    background: linear-gradient(135deg, #fff, var(--pod-color, var(--pm-blue-500)));
    box-shadow: 0 4px 10px color-mix(in srgb, var(--pod-color, var(--pm-blue-500)) 50%, transparent);
  }
  .tk-pod-avatar {
    width: clamp(2.4rem, 5vw, 3.1rem); aspect-ratio: 1; border-radius: 999px; overflow: hidden;
    display: grid; place-items: center; margin-top: 0.35rem;
    background: var(--pm-panel-soft); border: 3px solid color-mix(in srgb, var(--pod-color, var(--pm-blue-500)) 70%, #fff);
    box-shadow: 0 6px 14px rgba(7, 23, 53, 0.22);
  }
  .tk-pod--1 .tk-pod-avatar { width: clamp(2.8rem, 6vw, 3.7rem); }
  .tk-pod-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .tk-pod-name { font-family: var(--font-display); font-weight: 900; font-size: 0.82rem; text-transform: uppercase; color: var(--pm-blue-900); max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .tk-pod-pts { font-family: var(--font-display); font-weight: 800; font-size: 0.62rem; text-transform: uppercase; color: var(--pm-text-soft); }
  .tk-pod-pts b { font-family: var(--font-score); font-size: 0.95rem; color: var(--pm-blue-700); }
  .tk-podium[data-started="true"] .tk-pod--1 .tk-pod-pts b { color: var(--pm-gold-700); }
  @media (prefers-reduced-motion: no-preference) {
    .tk-podium[data-started="true"] .tk-pod--1 { animation: floatBob 4.5s ease-in-out infinite; }
  }

  /* ===== ESCALERA (ranking) ===== */
  .tk-ladder { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.18rem; }
  .tk-card {
    display: grid;
    grid-template-columns: 1.6rem 1.7rem minmax(0, 1fr) auto auto 1rem;
    align-items: center; gap: 0.45rem;
    padding: 0.2rem 0.6rem; border-radius: var(--pm-radius-md);
    background: linear-gradient(100deg, color-mix(in srgb, var(--section-accent) 14%, var(--pm-white)), var(--pm-white) 62%);
    box-shadow: inset 4px 0 0 var(--section-accent), var(--pm-shadow-soft);
    transition: box-shadow var(--pm-transition-base);
    cursor: pointer;
  }
  .tk-card:hover { box-shadow: inset 4px 0 0 var(--section-accent), var(--pm-shadow-cyan); }
  .tk-card:focus-visible { outline: none; box-shadow: inset 4px 0 0 var(--section-accent), var(--pm-focus-ring); }
  .tk-rank {
    font-family: var(--font-score); font-weight: 800; font-size: 0.8rem; color: #fff; text-align: center;
    width: 1.45rem; height: 1.45rem; display: grid; place-items: center; margin-inline: auto; border-radius: 999px;
    background: linear-gradient(135deg, var(--pm-blue-500), var(--pm-cyan-500));
    box-shadow: 0 3px 8px rgba(18, 109, 255, 0.32);
  }
  .tk-avatar { width: 1.7rem; height: 1.7rem; border-radius: 999px; overflow: hidden; background: var(--pm-blue-50, rgba(18, 109, 255, 0.08)); display: inline-grid; place-items: center; flex: 0 0 auto; border: 2px solid var(--pm-cyan-400, #46f1ff); box-shadow: 0 2px 6px rgba(7, 23, 53, 0.18); }
  .tk-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .tk-id { display: flex; flex-direction: column; gap: 0.14rem; min-width: 0; }
  .tk-name { font-family: var(--font-display); font-weight: 900; font-size: 0.84rem; text-transform: uppercase; color: var(--pm-blue-900); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; line-height: 1; }
  .tk-bar { display: block; width: 100%; height: 0.32rem; border-radius: 999px; background: color-mix(in srgb, var(--pm-blue-500) 12%, var(--pm-ice)); overflow: hidden; }
  .tk-bar-fill {
    display: block; height: 100%; width: 0%; border-radius: 999px;
    background: linear-gradient(90deg, var(--pm-blue-500), var(--pm-cyan-500));
    transition: width 480ms var(--ease-out);
  }
  .tk-pts { display: flex; flex-direction: column; align-items: flex-end; line-height: 0.85; }
  .tk-pts b { font-family: var(--font-score); font-variant-numeric: tabular-nums; font-weight: 800; font-size: 1.05rem; color: var(--pm-blue-600); }
  .tk-pts small { font-family: var(--font-display); font-weight: 800; font-size: 0.5rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--pm-text-soft); }
  .tk-move {
    font-family: var(--font-display); font-weight: 900; font-size: 0.54rem; letter-spacing: 0.04em; text-transform: uppercase;
    min-width: 2.9rem; text-align: center; padding: 0.12rem 0.36rem; border-radius: 999px;
    color: var(--pm-text-soft); background: color-mix(in srgb, var(--pm-text-soft) 12%, var(--pm-white));
  }
  .tk-card[data-change="up"] .tk-move { color: var(--pm-green-700); background: var(--pm-green-100); }
  .tk-card[data-change="down"] .tk-move { color: var(--pm-red-600); background: var(--pm-red-100); }
  .tk-move:empty { visibility: hidden; }

  /* ===== Caret + HISTORIAL de puntos (se despliega al clickear la fila) ===== */
  .tk-caret { font-size: 0.7rem; color: var(--pm-text-soft); text-align: center; transition: transform var(--pm-transition-fast); }
  .tk-card[aria-expanded="true"] .tk-caret { transform: rotate(180deg); color: var(--pm-cyan-700, #0e7490); }
  .tk-history { grid-column: 1 / -1; }
  .tk-history[hidden] { display: none; }
  .tk-card[aria-expanded="true"] .tk-history { margin-top: 0.3rem; padding-top: 0.4rem; border-top: 1px dashed var(--pm-border-soft); }
  .tk-hist-empty { font-family: var(--font-display); font-weight: 700; font-size: 0.72rem; color: var(--pm-text-soft); padding: 0.15rem 0; }
  .tk-hist-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.22rem; }
  .tk-hist-item { display: grid; grid-template-columns: minmax(0, 1fr) auto auto; align-items: center; gap: 0.5rem; padding: 0.28rem 0.55rem; border-radius: var(--pm-radius-sm); background: rgba(255, 255, 255, 0.74); border: 1px solid var(--pm-border-soft); }
  .tk-hist-item[data-live="true"] { border-color: color-mix(in srgb, var(--pm-red-500) 38%, var(--pm-border-soft)); }
  .tk-hist-match { display: flex; flex-direction: column; gap: 0.05rem; min-width: 0; }
  .tk-hist-teams { font-family: var(--font-display); font-weight: 900; font-size: 0.72rem; text-transform: uppercase; color: var(--pm-blue-900); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .tk-hist-detail { font-family: var(--font-ui); font-size: 0.62rem; color: var(--pm-text-soft); }
  .tk-hist-badge { font-family: var(--font-display); font-weight: 800; font-size: 0.55rem; letter-spacing: 0.03em; text-transform: uppercase; padding: 0.12rem 0.44rem; border-radius: 999px; color: var(--pm-text-soft); background: color-mix(in srgb, var(--pm-text-soft) 12%, var(--pm-white)); white-space: nowrap; }
  .tk-hist-badge[data-hit="lone_wolf"] { color: #b45309; background: #fff0d1; }
  .tk-hist-badge[data-hit="exact"] { color: var(--pm-green-700, #15803d); background: var(--pm-green-100); }
  .tk-hist-badge[data-hit="tendency"] { color: var(--pm-blue-700); background: color-mix(in srgb, var(--pm-blue-500) 12%, #fff); }
  .tk-hist-pts { font-family: var(--font-score); font-variant-numeric: tabular-nums; font-weight: 800; font-size: 0.82rem; color: var(--pm-blue-700); text-align: right; min-width: 1.9rem; }
  /* Desglose del PODIO MUNDIAL dentro del historial desplegable de cada jugador. */
  .tk-pod-block { margin-top: 0.4rem; padding-top: 0.34rem; border-top: 1px dashed var(--pm-border-soft); }
  .tk-pod-head { margin: 0 0 0.2rem; font-family: var(--font-display); font-weight: 900; font-size: 0.55rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--pm-text-soft, #64748b); }
  .tk-pod-lines { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.12rem; }
  .tk-pod-line { display: grid; grid-template-columns: auto 1fr auto auto; align-items: center; gap: 0.4rem; padding: 0.16rem 0.3rem; border-radius: var(--pm-radius-sm); background: color-mix(in srgb, var(--pm-text-soft) 5%, transparent); }
  .tk-pod-line[data-state="hit"] { background: var(--pm-green-100); }
  .tk-pod-line[data-live="true"] { outline: 1px dashed var(--pm-red-500); }
  .tk-pod-slot { font-family: var(--font-display); font-weight: 800; font-size: 0.58rem; letter-spacing: 0.02em; text-transform: uppercase; color: var(--pm-blue-900); white-space: nowrap; }
  .tk-pod-detail { font-size: 0.56rem; color: var(--pm-text-soft, #64748b); }
  .tk-pod-mark { font-size: 0.66rem; font-weight: 900; color: var(--pm-text-soft, #64748b); }
  .tk-pod-line[data-state="hit"] .tk-pod-mark { color: var(--pm-green-700, #15803d); }
  .tk-pod-line[data-state="miss"] .tk-pod-mark { color: color-mix(in srgb, var(--pm-red-500) 70%, #fff); }
  .tk-pod-pts { font-family: var(--font-score); font-variant-numeric: tabular-nums; font-weight: 800; font-size: 0.72rem; color: var(--pm-blue-700); text-align: right; min-width: 1.6rem; }

  .tk-hist-foot { display: flex; justify-content: space-between; align-items: baseline; gap: 0.5rem; margin-top: 0.32rem; font-family: var(--font-display); font-weight: 900; font-size: 0.66rem; letter-spacing: 0.03em; text-transform: uppercase; color: var(--pm-blue-900); }
  .tk-hist-foot b { font-family: var(--font-score); font-size: 0.95rem; color: var(--pm-cyan-700, #0e7490); }

