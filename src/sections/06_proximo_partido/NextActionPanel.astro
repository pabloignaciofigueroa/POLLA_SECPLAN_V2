---
import { INLINE } from "../../lib/ui-assets/uiAssets";

interface Props {
  homeTeamName: string;
  awayTeamName: string;
  groupId: string;
}

const { homeTeamName, awayTeamName, groupId } = Astro.props;
---

<section class="action-panel" aria-labelledby="action-title">
  <div class="panel-head">
    <span class="panel-icon" aria-hidden="true">
      <img src={INLINE.player.src} alt="" width={INLINE.player.width} height={INLINE.player.height} loading="lazy" decoding="async" />
    </span>
    <h2 id="action-title">Completa tu carton</h2>
  </div>
  <p class="panel-sub" data-action-copy>
    {homeTeamName} vs {awayTeamName} ya esta listo para pronosticar.
  </p>

  <a class="prediction-cta" href="/predicciones" data-prediction-cta data-prediction-group={groupId}>
    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 4.5h12M3 9h12M3 13.5h7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="m12 12 2 2 3-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <strong>Predecir este grupo</strong>
    <span aria-hidden="true">→</span>
  </a>

  <a class="stats-cta" href="/estadisticas">
    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="11" width="3" height="5" rx="1" fill="currentColor"/><rect x="7.5" y="7" width="3" height="9" rx="1" fill="currentColor"/><rect x="13" y="3" width="3" height="13" rx="1" fill="currentColor"/></svg>
    <strong>Ver estadisticas</strong>
    <span aria-hidden="true">→</span>
  </a>
</section>

<style>
  .action-panel {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 0.9rem;
    border-radius: var(--pm-radius-lg);
    background: linear-gradient(160deg, var(--pm-blue-700), var(--pm-purple-700));
    color: var(--pm-white);
    box-shadow: 0 8px 32px rgba(75, 24, 184, 0.35);
  }

  .panel-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .panel-icon {
    display: grid;
    width: 2rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: 999px;
    flex-shrink: 0;
  }

  .panel-icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .panel-sub {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .prediction-cta,
  .stats-cta {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.6rem;
    min-height: 3rem;
    padding: 0.6rem 0.9rem;
    border-radius: var(--pm-radius-md);
    text-decoration: none;
    transition: transform var(--pm-transition-fast), box-shadow var(--pm-transition-fast);
  }

  .prediction-cta {
    border: 2px solid var(--pm-cta-border);
    background: var(--pm-cta-bg);
    color: var(--pm-cta-text);
    box-shadow: var(--pm-cta-shadow);
  }

  .stats-cta {
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.08);
    color: var(--pm-white);
  }

  .prediction-cta:hover,
  .stats-cta:hover {
    transform: translateY(-1px);
  }

  .prediction-cta:hover {
    background: var(--pm-cta-bg-hover);
    box-shadow: var(--pm-cta-shadow-hover);
  }

  .stats-cta:hover {
    border-color: rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.14);
  }

  .prediction-cta:focus-visible,
  .stats-cta:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring-yellow);
  }

  .prediction-cta strong,
  .stats-cta strong {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.8vw, 1.1rem);
    font-weight: 950;
    text-align: left;
  }

  .prediction-cta > span,
  .stats-cta > span {
    font-size: 1.2rem;
    font-weight: 950;
  }
</style>
