---
import TeamMatchCard from "./TeamMatchCard.astro";
import VersusCenter from "./VersusCenter.astro";

interface Team {
  id: string;
  name: string;
  shortCode: string;
}

interface Match {
  homeTeam: Team;
  awayTeam: Team;
}

interface Props {
  match: Match;
  homeInfo?: Record<string, unknown>;
  awayInfo?: Record<string, unknown>;
  h2hInfo?: Record<string, unknown> | null;
}

const { match, homeInfo, awayInfo, h2hInfo = null } = Astro.props;
---

<section class="featured-match-layout" data-featured-single aria-label="Selecciones enfrentadas">
  <TeamMatchCard team={match.homeTeam} teamInfo={homeInfo} side="home" />
  <VersusCenter h2hInfo={h2hInfo} />
  <TeamMatchCard team={match.awayTeam} teamInfo={awayInfo} side="away" />
</section>

<style>
  .featured-match-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(14rem, 0.52fr) minmax(0, 1fr);
    gap: clamp(0.9rem, 2vw, 1.4rem);
    align-items: center;
    /* Contiene el slide horizontal del "versus intro" (GSAP x:±60) para que no
       genere scroll horizontal transitorio en viewports angostos. clip no rompe
       el sticky del header (está fuera de este contenedor). */
    overflow-x: clip;
  }

  @media (max-width: 980px) {
    .featured-match-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
