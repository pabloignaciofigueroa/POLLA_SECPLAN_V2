---
// Centro de definicion de grupo (F6). Shell SSR oculto por defecto (data-active="false");
// el client lo activa SOLO cuando un grupo tiene >=1 final de 3a fecha EN VIVO. Capa 1
// (un vistazo): cabecera + dos marcadores + tabla viva + tarjeta personal. Capa 2 (un
// toque): la matriz de 4 variables dentro de YourImpactCard. Cero regresion: si ningun
// grupo esta en definicion, no se ve nada y /proximo-partido queda igual que hoy.
import LiveMatchMini from "./LiveMatchMini.astro";
import LiveGroupStandings from "./LiveGroupStandings.astro";
import YourImpactCard from "./YourImpactCard.astro";
import WhatChangedFeed from "./WhatChangedFeed.astro";
---

<section
  class="gdc"
  data-group-definition-center
  data-active="false"
  aria-label="Centro de definicion de grupo"
>
  <header class="gdc-header" data-gdc-header>
    <div class="gdc-title">
      <span class="gdc-kicker">Definicion simultanea</span>
      <h2 class="gdc-h2">
        Grupo <span data-gdc-group>—</span>
        <span class="gdc-dash" aria-hidden="true">·</span>
        <span class="gdc-state">En definicion</span>
      </h2>
    </div>
    <span class="gdc-live" aria-label="En vivo">
      <span class="gdc-live-dot" aria-hidden="true"></span>En vivo
    </span>
  </header>

  <div class="gdc-body">
    <div class="gdc-boards" data-gdc-boards>
      <LiveMatchMini finalLabel="Final 1" />
      <LiveMatchMini finalLabel="Final 2" />
    </div>
    <div class="gdc-grid">
      <div class="gdc-standings" data-gdc-standings>
        <LiveGroupStandings />
      </div>
      <div class="gdc-impact" data-gdc-impact>
        <YourImpactCard />
      </div>
    </div>

    <!-- F8 Cronologia "Que cambio": debajo de la tabla viva, mismo recompute. -->
    <div class="gdc-feed" data-gdc-feed>
      <WhatChangedFeed />
    </div>
  </div>
</section>

<style>
  .gdc {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.7rem 0.85rem;
    border-radius: var(--pm-radius-lg);
    background: linear-gradient(150deg, rgba(18, 10, 40, 0.9), rgba(8, 12, 34, 0.9));
    border: 1px solid rgba(239, 68, 68, 0.32);
    box-shadow: 0 10px 32px rgba(8, 6, 26, 0.4);
  }

  .gdc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .gdc-title {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .gdc-kicker {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pm-text-muted);
  }

  .gdc-h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1rem, 2.4vw, 1.35rem);
    font-weight: 900;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--pm-white);
  }

  .gdc-dash { color: var(--pm-text-muted); margin: 0 0.15rem; }
  .gdc-state { color: var(--pm-orange-400, #fb923c); }

  .gdc-live {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.18rem 0.55rem;
    border-radius: var(--pm-radius-pill);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pm-white);
    background: var(--pm-red-500, #ef4444);
  }

  .gdc-live-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--pm-white);
    animation: gdc-pulse 1.4s ease-in-out infinite;
  }

  .gdc-body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .gdc-boards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .gdc-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.92fr);
    gap: 0.55rem;
    align-items: start;
  }

  @media (max-width: 860px) {
    .gdc-boards { grid-template-columns: 1fr; }
    .gdc-grid { grid-template-columns: 1fr; }
  }

  @keyframes gdc-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }
  @media (prefers-reduced-motion: reduce) {
    .gdc-live-dot { animation: none; }
  }
</style>
