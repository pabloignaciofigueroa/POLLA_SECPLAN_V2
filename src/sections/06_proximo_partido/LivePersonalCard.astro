---
// F10 - Barra personal fija en vivo (SOLO mobile). Presentacional: el client la
// alimenta desde el MISMO recompute de F6 (buildPointLedger.byPlayer[pid]); NUNCA
// calcula puntaje ni abre un segundo canal. Oculta por defecto (data-active="false")
// y por CSS en desktop (>=721px) -> cero regresion.
//
// Capa 1 (colapsada): "TU PUNTAJE EN VIVO" + proyectado protagonista + "N oficiales
// + M en juego". Toda la barra es el control que despliega la Capa 2.
// Capa 2 (un toque): desglose corto leido de me.lines (Partidos +X / Clasificacion
// +Y + hasta 4 lineas clave). Cerrada por defecto.
//
// Todo el markup es SSR-estatico: el client solo setea textContent / data-attributes
// (no inyecta nodos nuevos por innerHTML), asi que el CSS scoped de Astro aplica.
const matrixRows = [
  { key: "final1", label: "Final 1" },
  { key: "final2", label: "Final 2" },
  { key: "first", label: "Clasifica 1o" },
  { key: "second", label: "Clasifica 2o" },
];
---

<aside class="lpc" data-live-personal-card data-active="false" aria-hidden="true">
  <!-- Estado CTA: sin jugador elegido. -->
  <a class="lpc-cta" data-lpc-cta href="/jugador" hidden>
    <span class="lpc-cta-text">Elige tu jugador para ver tu puntaje en vivo</span>
    <span class="lpc-cta-chev" aria-hidden="true">&rsaquo;</span>
  </a>

  <!-- Barra principal (control que despliega el desglose). -->
  <button
    class="lpc-bar"
    type="button"
    data-lpc-toggle
    aria-expanded="false"
    aria-controls="lpc-detail"
    hidden
  >
    <span class="lpc-live" data-lpc-live hidden>
      <span class="lpc-live-dot" aria-hidden="true"></span>EN VIVO
    </span>
    <span class="lpc-figures">
      <span class="lpc-kicker">Tu puntaje en vivo</span>
      <span class="lpc-projected" data-lpc-projected>0</span>
    </span>
    <span class="lpc-body">
      <span class="lpc-subtext" data-lpc-subtext data-trend="flat" aria-live="polite">0 oficiales + 0 en juego</span>
      <span class="lpc-afford">
        <span class="lpc-afford-text">Ver por que cambio</span>
        <span class="lpc-chev" aria-hidden="true">&#9650;</span>
      </span>
    </span>
  </button>

  <!-- Capa 2: desglose corto (Paso B). Cerrado por defecto. -->
  <div class="lpc-detail" id="lpc-detail" data-lpc-detail hidden>
    <p class="lpc-note">Provisional: no entra al ranking oficial hasta el cierre del grupo.</p>

    <div class="lpc-summary">
      <span class="lpc-sum-cell">
        <span class="lpc-sum-cap">Partidos</span>
        <strong class="lpc-sum-val" data-lpc-sum-match>+0</strong>
      </span>
      <span class="lpc-sum-cell">
        <span class="lpc-sum-cap">Clasificacion</span>
        <strong class="lpc-sum-val" data-lpc-sum-group>+0</strong>
      </span>
    </div>

    <table class="lpc-matrix">
      <thead>
        <tr>
          <th class="lpc-th">Variable</th>
          <th class="lpc-th">Pronostico</th>
          <th class="lpc-th">Ahora</th>
          <th class="lpc-th">Tipo</th>
          <th class="lpc-th lpc-th--pts">Pts</th>
        </tr>
      </thead>
      <tbody>
        {matrixRows.map((row) => (
          <tr class="lpc-row" data-lpc-row={row.key}>
            <td class="lpc-var" data-lpc-var>{row.label}</td>
            <td class="lpc-pred" data-lpc-pred>—</td>
            <td class="lpc-now" data-lpc-now>—</td>
            <td class="lpc-type" data-lpc-type data-token="none">—</td>
            <td class="lpc-pts" data-lpc-pts>0</td>
          </tr>
        ))}
      </tbody>
    </table>

    <button class="lpc-chrono" type="button" data-lpc-chrono hidden>Ver cronologia de cambios</button>
  </div>
</aside>

<style>
  /* La barra solo existe en mobile. En desktop NO se muestra nunca (cero regresion). */
  .lpc {
    display: none;
  }

  @media (max-width: 720px) {
    .lpc[data-active="true"] {
      display: block;
      position: fixed;
      inset-inline: 0;
      bottom: 0;
      z-index: 60;
      padding: 0.5rem 0.7rem calc(0.5rem + env(safe-area-inset-bottom));
      background: linear-gradient(180deg, rgba(8, 12, 32, 0) 0%, rgba(8, 12, 32, 0.96) 28%);
      pointer-events: none;
    }
    .lpc[data-active="true"] > * {
      pointer-events: auto;
    }
  }

  /* CTA "elige tu jugador". */
  .lpc-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 0.7rem 0.9rem;
    border-radius: var(--pm-radius-lg);
    border: 1px solid rgba(139, 92, 246, 0.32);
    background: linear-gradient(160deg, rgba(37, 24, 92, 0.96), rgba(12, 18, 48, 0.96));
    color: var(--pm-white);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 800;
  }
  .lpc-cta-chev {
    font-size: 1.1rem;
    color: var(--pm-purple-200);
  }
  .lpc-cta:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring-yellow);
  }

  /* Barra principal: una cifra protagonista + subtexto. */
  .lpc-bar {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.2rem 0.7rem;
    width: 100%;
    padding: 0.55rem 0.8rem;
    border-radius: var(--pm-radius-lg);
    border: 1px solid rgba(139, 92, 246, 0.36);
    background: linear-gradient(160deg, rgba(37, 24, 92, 0.96), rgba(12, 18, 48, 0.96));
    box-shadow: 0 -6px 24px rgba(6, 9, 26, 0.55);
    color: var(--pm-white);
    text-align: left;
    cursor: pointer;
  }
  .lpc-bar:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring-yellow);
  }

  .lpc-live {
    grid-column: 1 / -1;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-display);
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pm-red-500);
  }
  .lpc-live-dot {
    width: 0.46rem;
    height: 0.46rem;
    border-radius: 999px;
    background: var(--pm-red-500);
    animation: lpc-pulse 1.4s ease-in-out infinite;
  }

  .lpc-figures {
    display: flex;
    flex-direction: column;
    gap: 0.02rem;
    align-items: flex-start;
  }
  .lpc-kicker {
    font-family: var(--font-display);
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--pm-purple-200);
  }
  .lpc-projected {
    font-family: var(--font-score);
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--pm-white);
  }

  .lpc-body {
    display: flex;
    flex-direction: column;
    gap: 0.16rem;
    align-items: flex-start;
    min-width: 0;
  }
  .lpc-subtext {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--pm-text-soft);
  }
  /* "en juego" rotulado por signo; delta 0 = gris (nada en juego ahora). */
  .lpc-subtext[data-trend="up"] { color: var(--pm-green-500, #22c55e); }
  .lpc-subtext[data-trend="down"] { color: var(--pm-red-500); }
  .lpc-subtext[data-trend="flat"] { color: var(--pm-text-muted); }
  .lpc-afford {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--pm-purple-200);
  }
  .lpc-chev {
    font-size: 0.6rem;
    transition: transform var(--pm-transition-fast);
  }
  .lpc-bar[aria-expanded="true"] .lpc-chev {
    transform: rotate(180deg);
  }

  /* Capa 2: desglose. */
  .lpc-detail {
    margin-top: 0.4rem;
    padding: 0.6rem 0.8rem 0.7rem;
    border-radius: var(--pm-radius-lg);
    border: 1px solid rgba(139, 92, 246, 0.28);
    background: linear-gradient(160deg, rgba(28, 18, 74, 0.97), rgba(10, 15, 40, 0.97));
    box-shadow: 0 -4px 18px rgba(6, 9, 26, 0.5);
    max-height: 52vh;
    overflow-y: auto;
    animation: lpc-reveal 220ms ease both;
  }

  .lpc-note {
    margin: 0 0 0.45rem;
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--pm-text-muted);
  }

  .lpc-summary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .lpc-sum-cell {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.35rem 0.5rem;
    border-radius: var(--pm-radius-md);
    background: rgba(255, 255, 255, 0.05);
  }
  .lpc-sum-cap {
    font-family: var(--font-ui);
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--pm-text-muted);
  }
  .lpc-sum-val {
    font-family: var(--font-score);
    font-size: 1.1rem;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    color: var(--pm-white);
  }

  .lpc-matrix {
    width: 100%;
    border-collapse: collapse;
  }
  .lpc-th {
    font-family: var(--font-ui);
    font-size: 0.52rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--pm-text-muted);
    text-align: left;
    padding: 0.18rem 0.28rem;
  }
  .lpc-th--pts {
    text-align: right;
  }
  .lpc-row {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .lpc-var {
    font-family: var(--font-ui);
    font-size: 0.66rem;
    font-weight: 800;
    color: var(--pm-white);
    padding: 0.24rem 0.28rem;
  }
  .lpc-pred,
  .lpc-now {
    font-family: var(--font-score);
    font-size: 0.68rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--pm-text-soft);
    padding: 0.24rem 0.28rem;
  }
  .lpc-type {
    font-family: var(--font-ui);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.24rem 0.28rem;
  }
  .lpc-type[data-token="lone_wolf"] { color: var(--pm-purple-400, #a78bfa); }
  .lpc-type[data-token="exact_shared"] { color: var(--pm-blue-400, #60a5fa); }
  .lpc-type[data-token="tendency"] { color: var(--pm-green-500, #22c55e); }
  .lpc-type[data-token="group_first"] { color: var(--pm-gold-500, #f5c518); }
  .lpc-type[data-token="group_second"] { color: var(--pm-blue-400, #60a5fa); }
  .lpc-type[data-token="none"],
  .lpc-type[data-token="group_miss"],
  .lpc-type[data-token="locked"] { color: var(--pm-text-muted); }
  .lpc-pts {
    font-family: var(--font-score);
    font-size: 0.74rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    text-align: right;
    color: var(--pm-white);
    padding: 0.24rem 0.28rem;
  }

  .lpc-chrono {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--pm-purple-200);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .lpc-chrono:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring-yellow);
    border-radius: var(--pm-radius-sm);
  }

  @keyframes lpc-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.82); }
  }
  @keyframes lpc-reveal {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .lpc-detail { animation: none; }
    .lpc-chev { transition: none; }
    .lpc-live-dot { animation: none; }
  }
</style>
