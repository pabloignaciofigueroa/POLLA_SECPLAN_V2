---
import MatchMetaStrip from "./MatchMetaStrip.astro";

interface Match {
  groupLabel: string;
  stage: string;
  dateChile: string;
  timeChile: string;
  location: string;
}

interface Props {
  match: Match;
  displayMode: string;
}

const { match, displayMode } = Astro.props;
---

<header class="match-hero" aria-labelledby="proximo-partido-title" data-animate="fade-up">
  <div class="title-block">
    <h1 id="proximo-partido-title">
      <span class="deco-left" aria-hidden="true">
        <svg width="48" height="12" viewBox="0 0 48 12" fill="none"><rect x="0" y="4" width="32" height="4" rx="2" fill="currentColor" opacity=".9"/><rect x="36" y="0" width="12" height="12" rx="2" fill="currentColor" opacity=".6"/></svg>
      </span>
      <span class="title-main">Próximo</span>
      <span class="title-accent">Partido</span>
      <span class="deco-right" aria-hidden="true">
        <svg width="48" height="12" viewBox="0 0 48 12" fill="none"><rect x="16" y="4" width="32" height="4" rx="2" fill="currentColor" opacity=".9"/><rect x="0" y="0" width="12" height="12" rx="2" fill="currentColor" opacity=".6"/></svg>
      </span>
    </h1>
    <span class="lead">Un duelo clave. Dos selecciones. Todo en juego.</span>
  </div>
  <MatchMetaStrip match={match} displayMode={displayMode} />
</header>

<style>
  .match-hero {
    display: flex;
    flex-direction: column;
    gap: clamp(0.4rem, 0.9vw, 0.65rem);
    align-items: center;
    text-align: center;
  }

  .title-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    max-width: 1100px;
  }

  h1,
  .lead {
    margin: 0;
  }

  h1 {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.1em 0.35em;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6.5vw, 5.2rem);
    font-weight: 950;
    letter-spacing: -0.01em;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .deco-left,
  .deco-right {
    display: inline-flex;
    align-items: center;
    color: var(--pm-orange-500);
    opacity: 0.85;
    flex-shrink: 0;
  }

  .deco-left svg,
  .deco-right svg {
    width: clamp(1.8rem, 3.5vw, 3rem);
    height: auto;
  }

  .title-main {
    background: linear-gradient(135deg, var(--pm-blue-500), var(--pm-blue-700));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .title-accent {
    background: linear-gradient(135deg, var(--pm-orange-500), var(--pm-red-500));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .lead {
    color: var(--pm-blue-900);
    font-size: clamp(0.82rem, 1.2vw, 1rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
