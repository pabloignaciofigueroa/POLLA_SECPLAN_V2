---
import { INLINE } from "../../lib/ui-assets/uiAssets";

interface H2HInfo {
  uiLabel?: string | null;
  summaryEs?: string | null;
  worldCupContext?: string | null;
}

interface Props {
  h2hInfo?: H2HInfo | null;
}

const { h2hInfo = null } = Astro.props;
const label = h2hInfo?.uiLabel ?? "Primer enfrentamiento";
const summary = h2hInfo?.summaryEs ?? "No hay antecedentes historicos confirmados para este duelo.";
const reading = [label, summary, h2hInfo?.worldCupContext].filter(Boolean) as string[];
---

<section class="reading-panel" aria-labelledby="reading-title">
  <div class="panel-title">
    <span aria-hidden="true">
      <img src={INLINE.checklist.src} alt="" width={INLINE.checklist.width} height={INLINE.checklist.height} loading="lazy" decoding="async" />
    </span>
    <h2 id="reading-title">HISTORIAL DEL DUELO</h2>
  </div>
  <ul data-reading-list>
    {reading.map((item) => (
      <li>
        <span aria-hidden="true">◆</span>
        <p>{item}</p>
      </li>
    ))}
  </ul>
</section>

<style>
  .reading-panel {
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--pm-sec-partido-a) 38%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-sec-partido-a) 26%, transparent),
        color-mix(in srgb, var(--pm-sec-partido-b) 34%, transparent)
      ),
      var(--pm-panel-soft);
    box-shadow: 0 18px 45px rgba(7, 23, 53, 0.1);
  }

  .panel-title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.7rem;
  }

  .panel-title > span {
    display: grid;
    width: 2rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.55);
  }

  .panel-title > span img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  h2,
  ul,
  p {
    margin: 0;
  }

  h2 {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 950;
  }

  ul {
    display: grid;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--color-line);
  }

  li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    padding: 0.62rem 0;
    border-bottom: 1px solid var(--color-line);
  }

  li:last-child {
    border-bottom: 0;
  }

  li > span {
    color: var(--color-text);
  }

  p {
    color: var(--color-text);
    font-size: 0.82rem;
    font-weight: 740;
    line-height: 1.35;
  }
</style>
