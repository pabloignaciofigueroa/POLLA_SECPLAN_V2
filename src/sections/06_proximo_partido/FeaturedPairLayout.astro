---
// Hero PAR SIMULTANEO: cuando lo que viene son los DOS finales del grupo a la misma hora, este
// cascaron (oculto por defecto) reemplaza al FeaturedMatchLayout single. El cliente
// (proximo-partido.client.js -> renderMatchPair) lo rellena por innerHTML: columna izquierda =
// LOCALES apilados, centro COMPARTIDO = VS + cuenta regresiva, columna derecha = VISITAS apiladas.
// Es presentacion INFORMATIVA (no biblia): no toca puntaje ni el Centro de definicion F6. Con un
// solo proximo partido queda oculto (cero regresion). CSS is:global anclado a [data-featured-pair]
// porque las cards nacen en runtime (no reciben el scope de Astro). Gotcha del dia: la regla
// [data-featured-pair][hidden]{display:none} es necesaria (el atributo hidden pierde contra el
// display:grid de autor).
---

<section class="featured-pair" data-featured-pair hidden aria-label="Dos partidos simultaneos">
  <div class="fp-col fp-home" data-pair-home></div>
  <div class="fp-center">
    <div class="fp-vs" aria-hidden="true"><strong>VS</strong></div>
    <div class="fp-countdown">
      <span class="fp-cd-label">Faltan</span>
      <strong class="fp-cd-value" data-pair-countdown>--:--:--</strong>
    </div>
  </div>
  <div class="fp-col fp-away" data-pair-away></div>
</section>

<style is:global>
  [data-featured-pair] {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(10rem, 0.46fr) minmax(0, 1fr);
    gap: clamp(0.7rem, 1.6vw, 1.2rem);
    align-items: stretch;
  }
  [data-featured-pair][hidden] { display: none; }

  [data-featured-pair] .fp-col {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: clamp(0.6rem, 1.2vw, 0.9rem);
    min-width: 0;
  }
  [data-featured-pair] .fp-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
  }
  [data-featured-pair] .fp-vs strong {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.6rem);
    font-weight: 950;
    line-height: 1;
    background: linear-gradient(135deg, var(--pm-orange-500, #f97316), var(--pm-red-500, #ef4444));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  [data-featured-pair] .fp-countdown {
    display: grid;
    justify-items: center;
    gap: 0.15rem;
    padding: 0.5rem 0.95rem;
    border-radius: var(--pm-radius-lg, 16px);
    background: var(--pm-blue-950, #071a35);
    box-shadow: 0 10px 24px rgba(7, 26, 53, 0.25);
  }
  [data-featured-pair] .fp-cd-label {
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pm-cyan-300, #7fe3f0);
  }
  [data-featured-pair] .fp-cd-value {
    font-family: var(--font-score);
    font-size: clamp(1.35rem, 3vw, 2rem);
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--pm-yellow-400, #ffd23d);
    line-height: 1;
  }
  [data-featured-pair] .fp-cd-value[data-state="live"] { color: var(--pm-red-400, #ff6b80); }

  /* Card compacta de un equipo (paleta clara del hero). Local = bandera izq; visita = espejada. */
  [data-featured-pair] .fp-card {
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, 1.2vw, 0.85rem);
    padding: clamp(0.55rem, 1.1vw, 0.9rem);
    border: 1px solid var(--pm-blue-200, #c9defb);
    border-radius: var(--pm-radius-lg, 16px);
    background: linear-gradient(135deg, var(--pm-white, #fff), var(--pm-blue-50, #eef5fe));
    box-shadow: 0 6px 16px rgba(7, 26, 53, 0.08);
    min-width: 0;
  }
  [data-featured-pair] .fp-away .fp-card { flex-direction: row-reverse; text-align: right; }
  [data-featured-pair] .fp-flag {
    display: inline-flex;
    width: clamp(2.6rem, 5vw, 3.6rem);
    aspect-ratio: 4 / 3;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--pm-blue-200, #c9defb);
    background: var(--pm-blue-100, #e3effb);
    flex-shrink: 0;
  }
  [data-featured-pair] .fp-flag img { width: 100%; height: 100%; object-fit: cover; display: block; }
  [data-featured-pair] .fp-id { flex: 1; min-width: 0; display: grid; gap: 0.12rem; }
  [data-featured-pair] .fp-name {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.7vw, 1.35rem);
    font-weight: 950;
    color: var(--pm-blue-900, #0b2545);
    text-transform: uppercase;
    line-height: 1;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  [data-featured-pair] .fp-conf {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pm-orange-600, #d9620a);
  }
  [data-featured-pair] .fp-crest { width: 1.5rem; height: 1.5rem; flex-shrink: 0; }
  [data-featured-pair] .fp-crest img { width: 100%; height: 100%; object-fit: contain; display: block; }

  @media (max-width: 860px) {
    [data-featured-pair] { grid-template-columns: 1fr; }
    [data-featured-pair] .fp-center { order: 2; flex-direction: row; gap: 1rem; }
    [data-featured-pair] .fp-home { order: 1; }
    [data-featured-pair] .fp-away { order: 3; }
    [data-featured-pair] .fp-col { grid-template-rows: auto auto; }
    [data-featured-pair] .fp-away .fp-card { flex-direction: row; text-align: left; }
  }
</style>
