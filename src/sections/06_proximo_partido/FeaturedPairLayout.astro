---
// Hero PAR SIMULTANEO: cuando lo que viene son los DOS finales del grupo a la misma hora, este
// cascaron (oculto por defecto) reemplaza al FeaturedMatchLayout single. El cliente
// (proximo-partido.client.js -> renderMatchPair) lo rellena por innerHTML: columna izquierda =
// LOCALES apilados, centro COMPARTIDO = VS + cuenta regresiva, columna derecha = VISITAS apiladas.
// Las cards reusan el LOOK de TeamMatchCard (bandera grande, nombre+escudo, confederacion, "Ver en
// Equipos"); por eso su CSS va aqui (is:global, anclado a [data-featured-pair]) ya que las cards
// nacen en runtime y no reciben el scope de Astro. En modo PAR el cliente OCULTA los paneles de
// detalle de abajo (historial/contexto/carton): el hero del par llena el espacio (referencia del
// usuario). Es presentacion INFORMATIVA: no toca puntaje ni el Centro de definicion F6. Con un solo
// proximo partido queda oculto (cero regresion). Gotcha: [data-featured-pair][hidden]{display:none}.
---

<section class="featured-pair" data-featured-pair hidden aria-label="Dos partidos simultaneos">
  <div class="fp-col fp-home" data-pair-home></div>
  <div class="fp-center">
    <div class="fp-vs" aria-hidden="true"><strong>VS</strong></div>
    <div class="fp-countdown">
      <span class="fp-cd-label">Faltan</span>
      <strong class="fp-cd-value" data-pair-countdown>--:--:--</strong>
    </div>
  </div>
  <div class="fp-col fp-away" data-pair-away></div>
</section>

<style is:global>
  [data-featured-pair] {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(11rem, 0.5fr) minmax(0, 1fr);
    gap: clamp(0.8rem, 2vw, 1.4rem);
    align-items: stretch;
  }
  [data-featured-pair][hidden] { display: none; }

  [data-featured-pair] .fp-col {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: clamp(0.7rem, 1.4vw, 1.1rem);
    min-width: 0;
  }
  [data-featured-pair] .fp-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
  }
  [data-featured-pair] .fp-vs strong {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    font-weight: 950;
    line-height: 1;
    background: linear-gradient(135deg, var(--pm-orange-500, #f97316), var(--pm-red-500, #ef4444));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  [data-featured-pair] .fp-countdown {
    display: grid;
    justify-items: center;
    gap: 0.15rem;
    padding: 0.55rem 1rem;
    border-radius: var(--pm-radius-lg, 16px);
    background: var(--pm-blue-950, #071a35);
    box-shadow: 0 10px 24px rgba(7, 26, 53, 0.25);
  }
  [data-featured-pair] .fp-cd-label {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pm-cyan-300, #7fe3f0);
  }
  [data-featured-pair] .fp-cd-value {
    font-family: var(--font-score);
    font-size: clamp(1.5rem, 3.2vw, 2.2rem);
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--pm-yellow-400, #ffd23d);
    line-height: 1;
  }
  [data-featured-pair] .fp-cd-value[data-state="live"] { color: var(--pm-red-400, #ff6b80); }

  /* Card de equipo: mismo look que TeamMatchCard (bandera grande, nombre+escudo, "Ver en Equipos"). */
  [data-featured-pair] .team-card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0.75rem;
    border: 1px solid var(--color-line, rgba(7, 26, 53, 0.14));
    border-radius: var(--radius-lg, 16px);
    background: rgba(247, 247, 242, 0.92);
    box-shadow: 0 1px 0 rgba(17, 24, 39, 0.08);
  }
  [data-featured-pair] .team-card[data-team-card="home"] { border-left: 3px solid var(--pm-green-500, #16a34a); }
  [data-featured-pair] .team-card[data-team-card="away"] { border-right: 3px solid var(--pm-orange-500, #f97316); }
  [data-featured-pair] .team-head { display: grid; grid-template-columns: minmax(5rem, 40%) 1fr; gap: 0.75rem; align-items: start; min-width: 0; }
  [data-featured-pair] .team-card[data-team-card="away"] .team-head { grid-template-columns: 1fr minmax(5rem, 40%); }
  [data-featured-pair] .team-card[data-team-card="away"] .team-flag { grid-column: 2; grid-row: 1; }
  [data-featured-pair] .team-card[data-team-card="away"] .team-identity { grid-column: 1; grid-row: 1; text-align: right; }
  [data-featured-pair] .team-flag { display: block; width: 100%; aspect-ratio: 3 / 2; min-height: 5rem; overflow: hidden; border: 1px solid var(--color-line, rgba(7, 26, 53, 0.14)); border-radius: var(--radius-md, 12px); background: rgba(255, 255, 255, 0.9); line-height: 0; }
  [data-featured-pair] .team-flag img { display: block; width: 100%; height: 100%; object-fit: contain; }
  [data-featured-pair] .team-identity { display: flex; min-width: 0; flex-direction: column; gap: 0.2rem; }
  [data-featured-pair] .name-row { display: flex; align-items: center; gap: 0.45rem; min-width: 0; }
  [data-featured-pair] .team-card[data-team-card="away"] .name-row { flex-direction: row-reverse; }
  [data-featured-pair] .team-card h2, [data-featured-pair] .team-card p { margin: 0; }
  [data-featured-pair] .team-card h2 { flex: 1 1 auto; min-width: 0; overflow: hidden; color: var(--color-text, #0b2545); font-family: var(--font-display); font-size: clamp(1.4rem, 2.6vw, 2.2rem); font-weight: 950; line-height: 0.95; text-overflow: ellipsis; text-transform: uppercase; white-space: nowrap; }
  [data-featured-pair] .team-card p { margin-top: 0.15rem; color: var(--color-text, #0b2545); font-size: 0.7rem; font-weight: 850; text-transform: uppercase; }
  [data-featured-pair] .team-card[data-team-card="home"] p { color: var(--pm-green-600, #15803d); }
  [data-featured-pair] .team-card[data-team-card="away"] p { color: var(--pm-orange-500, #f97316); }
  [data-featured-pair] .crest-badge { display: inline-grid; width: clamp(3.4rem, 5vw, 4.4rem); height: clamp(3.4rem, 5vw, 4.4rem); flex-shrink: 0; place-items: center; padding: 0.14rem; overflow: hidden; border: 1px solid rgba(7, 23, 53, 0.12); border-radius: 999px; background: rgba(255, 255, 255, 0.88); box-shadow: 0 10px 22px rgba(7, 23, 53, 0.1); }
  [data-featured-pair] .crest-badge img { display: block; width: 100%; height: 100%; object-fit: contain; object-position: center; transform: scale(1.1); }
  [data-featured-pair] .team-link { display: flex; align-items: center; gap: 0.35rem; padding-top: 0.4rem; border-top: 1px solid var(--color-line, rgba(7, 26, 53, 0.14)); color: var(--pm-blue-500, #2f72d6); font-size: 0.7rem; font-weight: 850; text-decoration: none; text-transform: uppercase; letter-spacing: 0.03em; opacity: 0.72; }
  [data-featured-pair] .team-link:hover { opacity: 1; }
  [data-featured-pair] .team-card[data-team-card="away"] .team-link { flex-direction: row-reverse; justify-content: flex-start; }

  @media (max-width: 860px) {
    [data-featured-pair] { grid-template-columns: 1fr; }
    [data-featured-pair] .fp-center { order: 2; flex-direction: row; gap: 1rem; }
    [data-featured-pair] .fp-home { order: 1; }
    [data-featured-pair] .fp-away { order: 3; }
    [data-featured-pair] .fp-col { grid-template-rows: auto auto; }
  }
  @media (max-width: 560px) {
    [data-featured-pair] .crest-badge { width: 3.2rem; height: 3.2rem; }
  }
</style>
