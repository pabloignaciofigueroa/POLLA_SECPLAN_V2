---
import HistoricalMatchupCard from "./HistoricalMatchupCard.astro";

interface Props {
  h2hInfo?: {
    uiLabel?: string | null;
    previousMeetings?: number | null;
  } | null;
}

const { h2hInfo = null } = Astro.props;
---

<div class="versus-center" data-versus-center>
  <div class="vs-block" aria-label="versus" data-moment="vs">
    <img
      class="bolt"
      aria-hidden="true"
      data-moment="swoosh"
      src="/assets/polla-mundialera/sections/06_proximo_partido/asset-ball-energy-swoosh.webp"
      alt=""
      width="320"
      height="320"
      loading="lazy"
      decoding="async"
    />
    <strong>VS</strong>
  </div>
  <div class="countdown" data-countdown-block>
    <span class="countdown-label">Faltan</span>
    <strong class="countdown-value" data-countdown>--:--:--</strong>
  </div>
  <HistoricalMatchupCard h2hInfo={h2hInfo} />
</div>

<style>
  .versus-center {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.85rem;
    align-items: center;
    justify-content: center;
  }

  .vs-block {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bolt {
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(5rem, 12vw, 8.5rem);
    height: auto;
    object-fit: contain;
    opacity: 0.24;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
  }

  .vs-block strong {
    position: relative;
    z-index: 1;
    background: linear-gradient(135deg, var(--pm-yellow-500) 0%, var(--pm-orange-500) 42%, var(--pm-red-500) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 7.5rem);
    font-weight: 950;
    line-height: 0.78;
    text-transform: uppercase;
    filter:
      drop-shadow(0 8px 20px rgba(255, 64, 88, 0.28))
      drop-shadow(0 2px 8px rgba(6, 19, 38, 0.18));
  }

  .countdown {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    min-width: 11.5rem;
    padding: 0.5rem 1.05rem 0.55rem;
    border: 1px solid color-mix(in srgb, var(--pm-orange-500) 45%, transparent);
    border-radius: 1rem;
    background:
      linear-gradient(160deg, rgba(6, 19, 38, 0.94), rgba(7, 26, 53, 0.88)),
      radial-gradient(circle at 24% 0%, rgba(255, 138, 0, 0.22), transparent 48%);
    box-shadow:
      0 14px 28px rgba(6, 19, 38, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    text-align: center;
  }

  .countdown-label {
    color: var(--pm-orange-100);
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .countdown-value {
    color: var(--pm-yellow-500);
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    font-weight: 950;
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
  }

  .countdown-value[data-state="live"] {
    color: var(--pm-mint-500);
    animation: pulse-live 1.4s ease-in-out infinite;
  }

  @keyframes pulse-live {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
</style>
