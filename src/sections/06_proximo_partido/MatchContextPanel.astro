---
import { INLINE } from "../../lib/ui-assets/uiAssets";

interface Context {
  round: string;
  group: string;
  status: string;
  venue: string;
}

interface StadiumImage {
  src: string;
  name?: string;
  city?: string;
}

interface Props {
  context: Context;
  stadium?: StadiumImage | null;
}

const { context, stadium = null } = Astro.props;
const rows = [
  ["Ronda", context.round],
  ["Grupo", context.group],
  ["Estado", context.status],
  ["Estadio", context.venue],
];
---

<section class="context-panel" aria-labelledby="context-title">
  <div class="panel-title">
    <span aria-hidden="true">
      <img src={INLINE.calendar.src} alt="" width={INLINE.calendar.width} height={INLINE.calendar.height} loading="lazy" decoding="async" />
    </span>
    <h2 id="context-title">CONTEXTO DEL PARTIDO</h2>
  </div>

  <div class="context-grid">
    <dl data-context-list>
      {rows.map(([label, value]) => (
        <div>
          <dt>{label}</dt>
          <dd>{value}</dd>
        </div>
      ))}
    </dl>

    {stadium ? (
      <figure class="stadium-media" data-stadium-media>
        <img
          src={stadium.src}
          alt={stadium.name ? `Vista del estadio ${stadium.name}` : ""}
          loading="lazy"
          decoding="async"
          width="900"
          height="540"
        />
        {(stadium.name || stadium.city) && (
          <figcaption>
            {stadium.name && <strong>{stadium.name}</strong>}
            {stadium.city && <span>{stadium.city}</span>}
          </figcaption>
        )}
      </figure>
    ) : (
      <div class="stadium-placeholder" aria-hidden="true">Estadio por confirmar</div>
    )}
  </div>

  <p class="city-chip" data-context-city>{stadium?.city ?? context.venue}</p>
</section>

<style>
  .context-panel {
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--pm-cyan-500) 34%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-blue-500) 22%, transparent),
        color-mix(in srgb, var(--pm-cyan-500) 30%, transparent)
      ),
      var(--pm-panel-soft);
  }

  .panel-title {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.75rem;
  }

  .panel-title > span {
    display: grid;
    width: 2rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
  }

  .panel-title > span img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  h2,
  dl,
  dd,
  .city-chip {
    margin: 0;
  }

  h2 {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 950;
  }

  .context-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(9rem, 1fr);
    gap: 0.8rem;
  }

  dl {
    display: grid;
    gap: 0.55rem;
  }

  dl > div {
    padding-bottom: 0.45rem;
    border-bottom: 1px solid var(--color-line);
  }

  dt {
    color: var(--color-muted);
    font-size: 0.62rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  dd {
    margin-top: 0.15rem;
    color: var(--color-text);
    font-size: 0.82rem;
    font-weight: 850;
  }

  .stadium-placeholder {
    display: grid;
    min-height: 8.6rem;
    place-items: center;
    border: 1px dashed var(--color-muted);
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-size: 0.68rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .stadium-media {
    margin: 0;
    position: relative;
    overflow: hidden;
    min-height: 8.6rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-bg, #f3f7ff);
  }

  .stadium-media img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 5 / 3;
    object-fit: cover;
  }

  .stadium-media figcaption {
    position: absolute;
    left: 0.55rem;
    bottom: 0.55rem;
    display: inline-flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.35rem 0.55rem;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.88);
    color: var(--color-text);
    font-size: 0.65rem;
    font-weight: 850;
    line-height: 1.15;
  }

  .stadium-media figcaption strong {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .city-chip {
    width: fit-content;
    margin-top: 0.75rem;
    margin-left: auto;
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.68);
    color: var(--color-text);
    font-size: 0.7rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  @media (max-width: 560px) {
    .context-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
