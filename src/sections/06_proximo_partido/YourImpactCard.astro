---
// Tarjeta personal "Tu impacto" (F6 pasos E y F). Capa 1: una cifra protagonista
// (proyectado) + delta rotulado. Capa 2 (plegable, cerrada por defecto): matriz de 4
// variables (Final 1 / Final 2 / 1o / 2o). Presentacional: el client rellena todo con
// buildPointLedger (NUNCA calcula puntaje en la UI; solo muestra me.lines).
const matrixRows = [
  { key: "final1", label: "Final 1" },
  { key: "final2", label: "Final 2" },
  { key: "first", label: "Clasifica 1o" },
  { key: "second", label: "Clasifica 2o" },
];
---

<section class="impact" data-your-impact-card>
  <header class="impact-head">
    <span class="impact-kicker">Tu impacto en vivo</span>
    <span class="impact-name" data-impact-name>—</span>
  </header>

  <div class="impact-figures">
    <div class="impact-cell impact-cell--official">
      <span class="impact-cap">Oficial</span>
      <span class="impact-val" data-impact-official>0</span>
    </div>
    <div class="impact-cell impact-cell--projected">
      <span class="impact-cap">Proyectado</span>
      <span class="impact-big" data-impact-projected>0</span>
      <span class="impact-delta" data-impact-delta data-trend="flat">+0 EN VIVO</span>
    </div>
  </div>

  <p class="impact-note">Provisional: no entra al ranking oficial hasta el cierre del grupo.</p>

  <button class="impact-toggle" type="button" data-impact-toggle aria-expanded="false">
    <span>Ver como lo sumo</span>
    <span class="impact-chev" aria-hidden="true">▾</span>
  </button>

  <div class="impact-detail" data-impact-detail hidden>
    <table class="impact-matrix">
      <thead>
        <tr>
          <th class="im-th">Variable</th>
          <th class="im-th">Tu pronostico</th>
          <th class="im-th">Ahora</th>
          <th class="im-th">Tipo</th>
          <th class="im-th im-th--pts">Pts</th>
        </tr>
      </thead>
      <tbody>
        {matrixRows.map((row) => (
          <tr class="im-row" data-impact-row={row.key}>
            <td class="im-var" data-im-var>{row.label}</td>
            <td class="im-pred" data-im-pred>—</td>
            <td class="im-now" data-im-now>—</td>
            <td class="im-type" data-im-type data-token="none">—</td>
            <td class="im-pts" data-im-pts>0</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="impact-foot">
      <span>Variacion provisional del grupo:</span>
      <strong data-impact-foot>+0</strong>
    </p>
  </div>
</section>

<style>
  .impact {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.7rem 0.8rem;
    border-radius: var(--pm-radius-lg);
    background: linear-gradient(160deg, rgba(37, 24, 92, 0.92), rgba(12, 18, 48, 0.92));
    border: 1px solid rgba(139, 92, 246, 0.32);
  }

  .impact-head {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .impact-kicker {
    font-family: var(--font-display);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pm-purple-200, #c4b5fd);
  }

  .impact-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.02em;
    color: var(--pm-white);
  }

  .impact-figures {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: end;
    gap: 0.75rem;
  }

  .impact-cell {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .impact-cap {
    font-family: var(--font-ui);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pm-text-muted);
  }

  .impact-val {
    font-family: var(--font-score);
    font-size: 1.25rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--pm-text-soft);
  }

  .impact-cell--projected {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .impact-big {
    font-family: var(--font-score);
    font-size: 2.3rem;
    font-weight: 900;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--pm-white);
  }

  .impact-delta {
    font-family: var(--font-score);
    font-size: 0.82rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    padding: 0.1rem 0.45rem;
    border-radius: var(--pm-radius-pill);
  }
  .impact-delta[data-trend="up"] { color: var(--pm-white); background: var(--pm-green-600, #16a34a); }
  .impact-delta[data-trend="down"] { color: var(--pm-white); background: var(--pm-red-500, #ef4444); }
  .impact-delta[data-trend="flat"] { color: var(--pm-text-muted); background: rgba(255, 255, 255, 0.08); }

  .impact-note {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--pm-text-muted);
  }

  .impact-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    width: 100%;
    padding: 0.4rem 0.6rem;
    border-radius: var(--pm-radius-md);
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: var(--pm-white);
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background var(--pm-transition-fast);
  }
  .impact-toggle:hover { background: rgba(255, 255, 255, 0.12); }
  .impact-toggle:focus-visible { outline: none; box-shadow: var(--pm-focus-ring-yellow); }

  .impact-chev { transition: transform var(--pm-transition-fast); }
  .impact-toggle[aria-expanded="true"] .impact-chev { transform: rotate(180deg); }

  .impact-detail {
    animation: impact-reveal 220ms ease both;
  }

  .impact-matrix {
    width: 100%;
    border-collapse: collapse;
  }

  .im-th {
    font-family: var(--font-ui);
    font-size: 0.54rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--pm-text-muted);
    text-align: left;
    padding: 0.2rem 0.3rem;
  }
  .im-th--pts { text-align: right; }

  .im-row { border-top: 1px solid rgba(255, 255, 255, 0.08); }

  .im-var {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 800;
    color: var(--pm-white);
    padding: 0.26rem 0.3rem;
  }

  .im-pred,
  .im-now {
    font-family: var(--font-score);
    font-size: 0.7rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--pm-text-soft);
    padding: 0.26rem 0.3rem;
  }

  .im-type {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.26rem 0.3rem;
  }
  .im-type[data-token="lone_wolf"] { color: var(--pm-purple-400, #a78bfa); }
  .im-type[data-token="exact_shared"] { color: var(--pm-blue-400, #60a5fa); }
  .im-type[data-token="tendency"] { color: var(--pm-green-500, #22c55e); }
  .im-type[data-token="group_first"] { color: var(--pm-gold-500, #f5c518); }
  .im-type[data-token="group_second"] { color: var(--pm-blue-400, #60a5fa); }
  .im-type[data-token="none"],
  .im-type[data-token="group_miss"] { color: var(--pm-text-muted); }
  .im-type[data-token="locked"] { color: var(--pm-text-muted); }

  .im-pts {
    font-family: var(--font-score);
    font-size: 0.78rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    text-align: right;
    color: var(--pm-white);
    padding: 0.26rem 0.3rem;
  }

  .impact-foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin: 0.35rem 0 0;
    padding-top: 0.3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-ui);
    font-size: 0.64rem;
    font-weight: 700;
    color: var(--pm-text-soft);
  }
  .impact-foot strong {
    font-family: var(--font-score);
    font-size: 0.95rem;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    color: var(--pm-white);
  }

  @keyframes impact-reveal {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .impact-detail { animation: none; }
    .impact-chev { transition: none; }
  }
</style>
