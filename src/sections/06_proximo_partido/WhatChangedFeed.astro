---
// Cronologia "Que cambio" (F8, SOLO LECTURA). Vive DENTRO del Centro de definicion
// (debajo de la tabla viva) y se alimenta del MISMO recompute/subscribeLiveData que F6
// (un solo dueno del dataset). Shell SSR: cabecera + filtros (Todos/Mi jugador) + lista
// vacia + pildora de cola "N cambios nuevos". El client la rellena por data-attributes.
//
// Cero regresion: el contenedor [data-what-changed-feed] arranca data-active="false";
// el client lo activa SOLO cuando hay eventos (hay actividad viva). Sin vivo no se ve.
//
// Los items se crean en runtime por innerHTML, asi que su CSS va en <style is:global>
// anclado a [data-what-changed-feed] (gotcha: el innerHTML no recibe el scope de Astro).
---

<section
  class="wcf"
  data-what-changed-feed
  data-active="false"
  data-filter="all"
  aria-label="Cronologia: que cambio"
>
  <header class="wcf-head">
    <div class="wcf-title">
      <span class="wcf-kicker">Cronologia</span>
      <h3 class="wcf-h3">Que cambio</h3>
    </div>
    <div class="wcf-filters" role="group" aria-label="Filtrar la cronologia">
      <button type="button" class="wcf-filter" data-wcf-filter="all" aria-pressed="true">
        Todos
      </button>
      <button type="button" class="wcf-filter" data-wcf-filter="mine" aria-pressed="false">
        Mi jugador
      </button>
    </div>
  </header>

  <p class="wcf-empty" data-wcf-empty hidden>Sin cambios para tu jugador todavia.</p>

  <ol class="wcf-list" data-wcf-list aria-live="polite" aria-relevant="additions"></ol>

  <button type="button" class="wcf-queue" data-wcf-queue hidden aria-live="polite">
    <span class="wcf-queue-dot" aria-hidden="true"></span>
    <span data-wcf-queue-count>0</span> cambios nuevos
  </button>
</section>

<style is:global>
  /* F8: el feed se inyecta/rellena en runtime; su CSS va global anclado al contenedor. */
  [data-what-changed-feed] {
    display: none;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    margin-top: 0.55rem;
    padding: 0.6rem 0.7rem;
    border-radius: var(--pm-radius-md);
    background: rgba(8, 14, 38, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  [data-what-changed-feed][data-active="true"] {
    display: flex;
  }

  [data-what-changed-feed] .wcf-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  [data-what-changed-feed] .wcf-title {
    display: flex;
    flex-direction: column;
    gap: 0.02rem;
  }

  [data-what-changed-feed] .wcf-kicker {
    font-family: var(--font-ui);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pm-text-muted);
  }

  [data-what-changed-feed] .wcf-h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    font-weight: 900;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--pm-white);
  }

  [data-what-changed-feed] .wcf-filters {
    display: inline-flex;
    gap: 0.3rem;
  }

  [data-what-changed-feed] .wcf-filter {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.22rem 0.55rem;
    border-radius: var(--pm-radius-pill);
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: transparent;
    color: var(--pm-text-soft);
    cursor: pointer;
  }
  [data-what-changed-feed] .wcf-filter:focus-visible {
    outline: 2px solid var(--pm-gold-500, #f5c518);
    outline-offset: 2px;
  }
  [data-what-changed-feed] .wcf-filter[aria-pressed="true"] {
    background: var(--pm-blue-500, #3884ff);
    border-color: var(--pm-blue-500, #3884ff);
    color: var(--pm-white);
  }

  [data-what-changed-feed] .wcf-empty {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.74rem;
    color: var(--pm-text-muted);
  }

  [data-what-changed-feed] .wcf-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
    max-height: 22rem;
    overflow-y: auto;
  }

  /* Item: una sola fila legible. Color por signo del impacto. */
  [data-what-changed-feed] .wcf-item {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    padding: 0.4rem 0.5rem;
    border-radius: var(--pm-radius-sm, 8px);
    background: rgba(255, 255, 255, 0.04);
    border-left: 3px solid rgba(255, 255, 255, 0.18);
  }
  [data-what-changed-feed] .wcf-item[data-sign="up"] {
    border-left-color: var(--pm-green-500, #22c55e);
  }
  [data-what-changed-feed] .wcf-item[data-sign="down"] {
    border-left-color: var(--pm-red-500, #ef4444);
  }
  [data-what-changed-feed] .wcf-item[data-sign="neutral"] {
    border-left-color: rgba(255, 255, 255, 0.22);
  }

  [data-what-changed-feed] .wcf-ico {
    flex-shrink: 0;
    width: 1.15rem;
    height: 1.15rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1;
    color: var(--pm-text-soft);
  }
  [data-what-changed-feed] .wcf-item[data-type="goal"] .wcf-ico { color: var(--pm-white); }
  [data-what-changed-feed] .wcf-item[data-sign="up"] .wcf-ico { color: var(--pm-green-500, #22c55e); }
  [data-what-changed-feed] .wcf-item[data-sign="down"] .wcf-ico { color: var(--pm-red-500, #ef4444); }

  [data-what-changed-feed] .wcf-text {
    flex: 1;
    min-width: 0;
    font-family: var(--font-ui);
    font-size: 0.76rem;
    line-height: 1.32;
    color: var(--pm-white);
  }

  /* Insignia 1o/2o para eventos de clasificacion (consistente con F6/F7/F9). */
  [data-what-changed-feed] .wcf-badge {
    display: inline-block;
    margin-left: 0.3rem;
    font-family: var(--font-display);
    font-size: 0.56rem;
    font-weight: 900;
    letter-spacing: 0.02em;
    padding: 0.04rem 0.3rem;
    border-radius: var(--pm-radius-pill);
    vertical-align: middle;
  }
  [data-what-changed-feed] .wcf-badge[data-pos="1"] { color: #1a1205; background: var(--pm-gold-500, #f5c518); }
  [data-what-changed-feed] .wcf-badge[data-pos="2"] { color: var(--pm-white); background: var(--pm-blue-500, #3884ff); }

  /* Resumen agrupable (N jugadores afectados), expandible. */
  [data-what-changed-feed] .wcf-summary {
    margin-top: 0.2rem;
    font-family: var(--font-ui);
    font-size: 0.68rem;
    color: var(--pm-text-soft);
  }
  [data-what-changed-feed] .wcf-more {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: var(--pm-blue-300, #93c5fd);
    text-decoration: underline;
    cursor: pointer;
  }
  [data-what-changed-feed] .wcf-more:focus-visible {
    outline: 2px solid var(--pm-gold-500, #f5c518);
    outline-offset: 2px;
  }
  [data-what-changed-feed] .wcf-sublist {
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0 0 0 0.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  [data-what-changed-feed] .wcf-sublist[hidden] { display: none; }
  [data-what-changed-feed] .wcf-subitem {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--pm-text-soft);
  }

  /* Entrada de item nuevo: fade/slide corto desde arriba (<300ms). */
  [data-what-changed-feed] .wcf-item[data-enter="1"] {
    animation: wcf-enter 240ms ease-out both;
  }
  @keyframes wcf-enter {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Pildora "N cambios nuevos": flotante accesible. */
  [data-what-changed-feed] .wcf-queue {
    position: absolute;
    left: 50%;
    bottom: 0.5rem;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.28rem 0.7rem;
    border-radius: var(--pm-radius-pill);
    border: none;
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--pm-white);
    background: var(--pm-blue-500, #3884ff);
    box-shadow: 0 6px 18px rgba(8, 6, 26, 0.5);
    cursor: pointer;
    z-index: 2;
  }
  [data-what-changed-feed] .wcf-queue[hidden] { display: none; }
  [data-what-changed-feed] .wcf-queue:focus-visible {
    outline: 2px solid var(--pm-gold-500, #f5c518);
    outline-offset: 2px;
  }
  [data-what-changed-feed] .wcf-queue-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--pm-white);
  }

  @media (max-width: 860px) {
    [data-what-changed-feed] .wcf-list { max-height: 18rem; }
    [data-what-changed-feed] .wcf-head { flex-direction: column; align-items: stretch; }
    [data-what-changed-feed] .wcf-filters { align-self: flex-start; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-what-changed-feed] .wcf-item[data-enter="1"] {
      animation: none;
    }
    [data-what-changed-feed] .wcf-queue-dot { animation: none; }
  }
</style>
