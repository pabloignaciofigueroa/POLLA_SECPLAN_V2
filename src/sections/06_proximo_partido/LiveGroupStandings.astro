---
// Tabla viva del grupo en definicion (F6 paso D). Presentacional: SSR pinta 4 filas
// vacias y la cabecera; el client las rellena con computeGroupSituation (orden FIFA 2026
// ya desempatado). Fila 1 = CLASIFICA 1o (insignia 1o), fila 2 = CLASIFICA 2o (insignia 2o).
// El rotulo dice "con los marcadores actuales" + chip provisional: NUNCA "oficial" en vivo.
const rows = [0, 1, 2, 3];
---

<section class="lgs" data-live-group-standings>
  <header class="lgs-head">
    <span class="lgs-label">Clasificacion con los marcadores actuales</span>
    <span class="lgs-chip" data-lgs-chip>provisional</span>
  </header>
  <table class="lgs-table">
    <thead>
      <tr>
        <th class="lgs-th lgs-th--pos">POS</th>
        <th class="lgs-th lgs-th--team">Equipo</th>
        <th class="lgs-th lgs-th--num">PJ</th>
        <th class="lgs-th lgs-th--num">DG</th>
        <th class="lgs-th lgs-th--num">GF</th>
        <th class="lgs-th lgs-th--num">PTS</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((i) => (
        <tr class="lgs-row" data-lgs-row={i} data-qualify="out">
          <td class="lgs-posCell">
            <span class="lgs-pos" data-lgs-pos>{i + 1}</span>
            <span class="lgs-badge" data-lgs-badge aria-hidden="true"></span>
          </td>
          <td class="lgs-teamCell">
            <span class="lgs-flag" data-lgs-flag aria-hidden="true"></span>
            <span class="lgs-team" data-lgs-team>—</span>
          </td>
          <td class="lgs-num" data-lgs-pj>–</td>
          <td class="lgs-num" data-lgs-dg>–</td>
          <td class="lgs-num" data-lgs-gf>–</td>
          <td class="lgs-num lgs-pts" data-lgs-pts>–</td>
        </tr>
      ))}
    </tbody>
  </table>
</section>

<style>
  .lgs {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.55rem 0.65rem;
    border-radius: var(--pm-radius-md);
    background: rgba(8, 14, 38, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .lgs-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .lgs-label {
    font-family: var(--font-ui);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--pm-text-soft);
  }

  .lgs-chip {
    font-family: var(--font-ui);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.12rem 0.42rem;
    border-radius: var(--pm-radius-pill);
    color: var(--pm-white);
    background: var(--pm-orange-500, #f97316);
  }

  .lgs-table {
    width: 100%;
    border-collapse: collapse;
  }

  .lgs-th {
    font-family: var(--font-ui);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--pm-text-muted);
    text-align: center;
    padding: 0.2rem 0.25rem;
  }
  .lgs-th--pos { text-align: left; width: 2.4rem; }
  .lgs-th--team { text-align: left; }

  .lgs-row {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .lgs-posCell {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.28rem 0.25rem;
  }

  .lgs-pos {
    font-family: var(--font-score);
    font-size: 0.85rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--pm-text-soft);
    min-width: 1ch;
  }

  .lgs-badge {
    font-family: var(--font-display);
    font-size: 0.56rem;
    font-weight: 900;
    letter-spacing: 0.02em;
    padding: 0.05rem 0.32rem;
    border-radius: var(--pm-radius-pill);
    color: transparent;
  }

  .lgs-teamCell {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.28rem 0.25rem;
    min-width: 0;
  }

  .lgs-flag {
    display: inline-flex;
    width: 1.3rem;
    height: 0.95rem;
    border-radius: 3px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  .lgs-team {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--pm-white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lgs-num {
    font-family: var(--font-score);
    font-size: 0.82rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    text-align: center;
    color: var(--pm-text-soft);
    padding: 0.28rem 0.25rem;
  }

  .lgs-pts {
    color: var(--pm-white);
    font-weight: 800;
  }

  /* Clasifica 1o / 2o: color + insignia (no solo color). */
  .lgs-row[data-qualify="first"] {
    background: rgba(245, 197, 24, 0.08);
  }
  .lgs-row[data-qualify="first"] .lgs-badge {
    color: #1a1205;
    background: var(--pm-gold-500, #f5c518);
  }
  .lgs-row[data-qualify="second"] {
    background: rgba(56, 132, 255, 0.08);
  }
  .lgs-row[data-qualify="second"] .lgs-badge {
    color: var(--pm-white);
    background: var(--pm-blue-500, #3884ff);
  }
  .lgs-row[data-qualify="out"] {
    opacity: 0.74;
  }
</style>
