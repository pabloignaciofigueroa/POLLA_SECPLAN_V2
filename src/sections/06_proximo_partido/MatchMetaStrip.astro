---
interface Match {
  groupLabel: string;
  stage: string;
  dateChile: string;
  timeChile: string;
  location: string;
}

interface Props {
  match: Match;
  displayMode: string;
}

const { match, displayMode } = Astro.props;
const date = new Date(match.dateChile);
const dateLabel = new Intl.DateTimeFormat("es-CL", { weekday: "long", day: "2-digit", month: "long" }).format(date);
const timeLabel = new Intl.DateTimeFormat("es-CL", { hour: "2-digit", minute: "2-digit", hour12: true }).format(date);
---

<div class="meta-strip" aria-label="Datos del partido" data-match-meta-strip data-display-mode={displayMode}>
  <span class="meta-item" data-meta-kind="stage">
    <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1L10.5 6H15L11 9.5l1.5 5L8 12l-4.5 2.5L5 9.5 1 6h4.5L8 1Z" fill="currentColor"/></svg>
    <strong data-meta-stage>{match.stage.replace(" - fecha 1", "")} · {match.groupLabel}</strong>
  </span>
  <span class="sep" aria-hidden="true">|</span>
  <span class="meta-item" data-meta-kind="date">
    <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="11" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M5 1v3M11 1v3M2 7h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <strong data-meta-date>{dateLabel}</strong>
  </span>
  <span class="sep" aria-hidden="true">|</span>
  <span class="meta-item" data-meta-kind="time">
    <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 5v3.5l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <strong data-meta-time>{timeLabel} hrs (Chile)</strong>
  </span>
  <span class="sep" aria-hidden="true">|</span>
  <span class="meta-item" data-meta-kind="location">
    <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1C5.24 1 3 3.24 3 6c0 4 5 9 5 9s5-5 5-9c0-2.76-2.24-5-5-5Zm0 6.5A1.5 1.5 0 1 1 8 4a1.5 1.5 0 0 1 0 3.5Z" fill="currentColor"/></svg>
    <strong data-meta-location>{match.location}</strong>
  </span>
</div>

<style>
  .meta-strip {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    align-items: center;
    justify-content: center;
    gap: 0;
    width: min(100%, 1050px);
    margin-inline: auto;
    padding: 0.42rem 0.75rem;
    border: 1px solid var(--pm-border-soft);
    border-radius: var(--pm-radius-md);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--pm-shadow-soft);
    scrollbar-width: none;
  }

  .meta-strip::-webkit-scrollbar {
    display: none;
  }

  .meta-item {
    display: flex;
    flex-shrink: 0;
    white-space: nowrap;
    align-items: center;
    gap: 0.38rem;
    padding: 0.1rem 0.55rem;
    color: var(--pm-blue-900);
  }

  .meta-item svg {
    flex-shrink: 0;
    color: var(--pm-blue-500);
  }

  .meta-item[data-meta-kind="stage"] svg { color: var(--pm-orange-500); }
  .meta-item[data-meta-kind="time"] svg   { color: var(--pm-purple-500); }
  .meta-item[data-meta-kind="location"] svg { color: var(--pm-pink-500); }

  strong {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .sep {
    color: var(--pm-blue-900);
    opacity: 0.25;
    font-size: 0.9rem;
    font-weight: 300;
    padding: 0 0.1rem;
  }

  /* Modo live */
  .meta-strip[data-display-mode="live"] {
    border-color: var(--pm-state-live-border);
    background: var(--pm-state-live-bg);
  }

  .meta-strip[data-display-mode="live"] strong,
  .meta-strip[data-display-mode="live"] .sep,
  .meta-strip[data-display-mode="live"] .meta-item {
    color: var(--pm-white);
  }

  @media (max-width: 760px) {
    .meta-strip {
      flex-direction: column;
      align-items: flex-start;
      border-radius: var(--pm-radius-lg);
      padding: 0.5rem 0.75rem;
    }

    .sep {
      display: none;
    }
  }
</style>
