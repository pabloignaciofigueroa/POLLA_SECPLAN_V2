---
import TeamCrest from "../../components/ui/TeamCrest.astro";

interface Team {
  id: string;
  name: string;
  shortCode: string;
  crest?: string;
  crestThumb?: string;
}

interface TeamInfo {
  confederation?: string;
}

interface Props {
  team: Team;
  teamInfo?: TeamInfo;
  side: "home" | "away";
}

const { team, teamInfo, side } = Astro.props;
---

<article class="team-card" data-team-card={side} data-team-id={team.id} data-moment={side === "home" ? "home-team" : "away-team"}>
  <div class="team-head">
    <span class="team-flag" aria-hidden="true" data-team-flag-slot>
      <img src={`/assets/flags/${team.id}.svg`} alt={`Bandera ${team.name}`} loading="lazy" decoding="async" width="220" height="147" />
    </span>
    <div class="team-identity">
      <div class="name-row">
        <h2 data-team-name>{team.name}</h2>
        <span class="crest-badge" data-team-crest-slot aria-hidden="true">
          <TeamCrest team={team} size="lg" variant="thumb" decorative />
        </span>
      </div>
      <p data-team-confederation>{teamInfo?.confederation ?? "CONF"}</p>
    </div>
  </div>

  <a class="team-link" href="/equipos">
    <span class="arrow" aria-hidden="true">→</span>
    <span>Ver en Equipos</span>
  </a>
</article>

<style>
  .team-card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0.75rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    background: rgba(247, 247, 242, 0.92);
    box-shadow: 0 1px 0 rgba(17, 24, 39, 0.08);
  }

  .team-card[data-team-card="home"] { border-left: 3px solid var(--pm-green-500); }
  .team-card[data-team-card="away"] { border-right: 3px solid var(--pm-orange-500); }

  .team-head {
    display: grid;
    grid-template-columns: minmax(5rem, 40%) 1fr;
    gap: 0.75rem;
    align-items: start;
    min-width: 0;
  }

  .team-card[data-team-card="away"] .team-head {
    grid-template-columns: 1fr minmax(5rem, 40%);
  }

  .team-card[data-team-card="away"] .team-flag {
    grid-column: 2;
    grid-row: 1;
  }

  .team-card[data-team-card="away"] .team-identity {
    grid-column: 1;
    grid-row: 1;
    text-align: right;
  }

  .team-flag {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
    min-height: 5rem;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.9);
    line-height: 0;
  }

  .team-flag img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .team-identity {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.2rem;
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }

  .team-card[data-team-card="away"] .name-row {
    flex-direction: row-reverse;
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 950;
    line-height: 0.95;
    text-overflow: ellipsis;
    text-transform: uppercase;
    white-space: nowrap;
  }

  p {
    margin-top: 0.15rem;
    color: var(--color-text);
    font-size: 0.7rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .team-card[data-team-card="home"] p { color: var(--pm-green-600); }
  .team-card[data-team-card="away"] p { color: var(--pm-orange-500); }

  .crest-badge {
    display: inline-grid;
    width: clamp(4.25rem, 6.2vw, 4.9rem);
    height: clamp(4.25rem, 6.2vw, 4.9rem);
    flex-shrink: 0;
    place-items: center;
    padding: 0.14rem;
    overflow: hidden;
    border: 1px solid rgba(7, 23, 53, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 10px 22px rgba(7, 23, 53, 0.1);
  }

  .crest-badge :global(.team-crest),
  .crest-badge :global(img) {
    display: grid;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: auto;
    place-items: center;
  }

  .crest-badge :global(img) {
    display: block;
    object-fit: contain;
    object-position: center center;
    transform: scale(1.18);
    transform-origin: center;
  }

  .team-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--color-line);
    color: var(--pm-blue-500);
    font-size: 0.7rem;
    font-weight: 850;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    opacity: 0.7;
    transition: opacity var(--pm-transition-fast);
  }

  .team-link:hover { opacity: 1; }

  .team-card[data-team-card="away"] .team-link {
    flex-direction: row-reverse;
    justify-content: flex-start;
  }

  @media (max-width: 560px) {
    .crest-badge {
      width: 3.35rem;
      height: 3.35rem;
    }
  }
</style>
