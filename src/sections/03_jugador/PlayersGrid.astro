---
import PlayerCard from "./PlayerCard.astro";

interface Player {
  id: string;
  name: string;
  avatar: string;
  status: string;
}

interface Props {
  players: Player[];
  selectedPlayerId: string;
}

const { players, selectedPlayerId } = Astro.props;
---

<section class="players-grid-panel" aria-label="Jugadores disponibles">
  <div class="players-grid" data-moment="player-grid">
    {players.map((player) => (
      <PlayerCard player={player} selected={player.id === selectedPlayerId} />
    ))}
  </div>
</section>

<style>
  .players-grid-panel {
    padding: clamp(0.75rem, 1.5vw, 1rem);
    border: 1px solid color-mix(in srgb, var(--pm-sec-jugador-a) 45%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-sec-jugador-a) 24%, transparent),
        color-mix(in srgb, var(--pm-sec-jugador-b) 32%, transparent)
      ),
      var(--pm-panel-soft);
    box-shadow: 0 18px 45px rgba(7, 23, 53, 0.1);
  }

  @media (max-width: 640px) {
    .players-grid-panel {
      background:
        linear-gradient(
          135deg,
          color-mix(in srgb, var(--pm-sec-jugador-a) 14%, transparent),
          color-mix(in srgb, var(--pm-sec-jugador-b) 20%, transparent)
        ),
        var(--pm-panel-soft);
    }
  }

  .players-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: clamp(0.6rem, 1.1vw, 0.85rem);
  }

  @media (max-width: 1120px) {
    .players-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .players-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .players-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
