---
interface Props {
  href?: string;
}

const { href = "/predicciones" } = Astro.props;
---

<a class="primary-cta" href={href} data-player-cta>
  <svg class="icon-ball" aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
    <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.8"/>
    <path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm0 2c1.2 0 2.3.2 3.3.6L12 7.6 8.7 4.6A8 8 0 0 1 12 4zm-4.6 1.4 3.3 3H7.2A8 8 0 0 1 7.4 5.4zm9.2 0A8 8 0 0 1 16.8 8.4h-3.5l3.3-3zM6.6 10.4h4l-1.3 4-3.5-2.5a8 8 0 0 1 .8-1.5zm6.8 0h4a8 8 0 0 1 .8 1.5l-3.5 2.5-1.3-4zm-4.8 5.2 3-2.2 3 2.2-1.1 3.4a8 8 0 0 1-3.8 0l-1.1-3.4z"/>
  </svg>
  <span>IR A PREDICCIONES</span>
  <svg class="icon-arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
    <polyline points="9 6 15 12 9 18" />
  </svg>
</a>

<style>
  .primary-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: clamp(4rem, 6.5vw, 5rem);
    width: 100%;
    padding: 0.8rem 1.2rem;
    border: 2px solid var(--pm-cta-border);
    border-radius: 999px;
    background: var(--pm-cta-bg);
    color: var(--pm-cta-text);
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.2vw, 1.8rem);
    font-weight: 950;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
    box-shadow: var(--pm-cta-shadow);
    transition:
      transform 150ms cubic-bezier(0.23, 1, 0.32, 1),
      background var(--pm-transition-fast),
      box-shadow 150ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .primary-cta:focus-visible {
    outline: none;
    box-shadow: var(--pm-cta-shadow), var(--pm-focus-ring-yellow);
  }

  .icon-ball {
    width: clamp(1.2rem, 1.8vw, 1.6rem);
    height: clamp(1.2rem, 1.8vw, 1.6rem);
    flex: 0 0 auto;
  }

  .icon-arrow {
    width: clamp(1.1rem, 1.7vw, 1.5rem);
    height: clamp(1.1rem, 1.7vw, 1.5rem);
    flex: 0 0 auto;
  }

  .primary-cta:active {
    transform: scale(0.98);
  }

  @media (hover: hover) and (pointer: fine) {
    .primary-cta:hover {
      transform: translateY(-1px);
      background: var(--pm-cta-bg-hover);
      box-shadow: var(--pm-cta-shadow-hover);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .primary-cta {
      transition: none;
    }

    .primary-cta:hover,
    .primary-cta:active {
      transform: none;
    }
  }
</style>
