---
import type { GroupBucket } from "./equipos.logic";

interface Props {
  groups: GroupBucket[];
  initialGroup: string;
}

const { groups, initialGroup } = Astro.props;
---

<nav class="group-filter" aria-label="Filtrar selecciones por grupo">
  {groups.map((group) => (
    <button
      type="button"
      class="chip"
      data-group-chip={group.id}
      data-group-key={group.id.toLowerCase()}
      data-active={initialGroup === group.id ? "true" : "false"}
      aria-pressed={initialGroup === group.id ? "true" : "false"}
    >
      GRUPO {group.id}
    </button>
  ))}
</nav>

<style>
  .group-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0.62rem 0.75rem;
    border: 1px solid var(--pm-purple-200);
    border-radius: var(--pm-radius-md);
    background: var(--pm-white);
    box-shadow: var(--pm-shadow-soft);
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.38rem 0.78rem;
    border: 2px solid var(--chip-color, var(--pm-purple-500));
    border-radius: 999px;
    background: var(--pm-white);
    color: var(--chip-color, var(--pm-purple-600));
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--pm-transition-fast),
      color var(--pm-transition-fast),
      transform var(--pm-transition-fast),
      box-shadow var(--pm-transition-fast);
  }

  .chip:hover {
    background: var(--chip-color, var(--pm-purple-500));
    color: var(--chip-active-text, var(--pm-white));
    transform: translateY(-1px);
  }

  .chip:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  .chip[data-active="true"] {
    background: var(--chip-color, var(--pm-purple-500));
    color: var(--chip-active-text, var(--pm-white));
    box-shadow: 0 0 14px var(--chip-glow, rgba(124, 53, 255, 0.4));
  }

  .chip[data-group-key="a"] { --chip-color: var(--pm-group-a); --chip-glow: rgba(34, 197, 94, 0.32); }
  .chip[data-group-key="b"] { --chip-color: var(--pm-group-b); --chip-glow: rgba(18, 109, 255, 0.32); }
  .chip[data-group-key="c"] { --chip-color: var(--pm-group-c); --chip-glow: rgba(255, 138, 0, 0.32); --chip-active-text: var(--pm-blue-900); }
  .chip[data-group-key="d"] { --chip-color: var(--pm-group-d); --chip-glow: rgba(124, 53, 255, 0.32); }
  .chip[data-group-key="e"] { --chip-color: var(--pm-group-e); --chip-glow: rgba(24, 221, 242, 0.32); --chip-active-text: var(--pm-blue-900); }
  .chip[data-group-key="f"] { --chip-color: var(--pm-group-f); --chip-glow: rgba(255, 47, 179, 0.32); }
  .chip[data-group-key="g"] { --chip-color: var(--pm-group-g); --chip-glow: rgba(245, 184, 0, 0.32); --chip-active-text: var(--pm-blue-900); }
  .chip[data-group-key="h"] { --chip-color: var(--pm-group-h); --chip-glow: rgba(0, 91, 255, 0.32); }
  .chip[data-group-key="i"] { --chip-color: var(--pm-group-i); --chip-glow: rgba(182, 255, 0, 0.32); --chip-active-text: var(--pm-blue-900); }
  .chip[data-group-key="j"] { --chip-color: var(--pm-group-j); --chip-glow: rgba(255, 64, 88, 0.32); }
  .chip[data-group-key="k"] { --chip-color: var(--pm-group-k); --chip-glow: rgba(217, 70, 239, 0.32); }
  .chip[data-group-key="l"] { --chip-color: var(--pm-group-l); --chip-glow: rgba(0, 184, 217, 0.32); --chip-active-text: var(--pm-blue-900); }

  @media (max-width: 720px) {
    .group-filter {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 0.5rem;
    }

    .chip {
      flex-shrink: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chip:hover {
      transform: none;
    }
  }
</style>
