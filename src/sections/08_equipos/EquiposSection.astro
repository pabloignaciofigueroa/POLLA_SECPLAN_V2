---
// Seccion 08_equipos — ALBUM de los 4 CLASIFICADOS a SEMIFINALES (master-detail). 100% local.
// DERECHA: lista de los 4 equipos que avanzaron (bandera + nombre), clickeables.
// IZQUIERDA: portada GRANDE del equipo seleccionado + nombre + confederación.
// Los 4 se derivan de los resultados vivos (localStorage/Supabase) en el cliente: el SSR pinta
// el esqueleto y `equipos.knockout.client.js` lo llena. NO toca datos ni predicciones.
import styles from "./EquiposSection.module.css";
import EquiposHero from "./EquiposHero.astro";

import teamsData from "../../data/teams.json";
import knockoutData from "../../data/knockout-matches.json";
import seed from "../../data/knockout-results.json";

const teamsLite = (teamsData as any[]).map((t) => ({
  code: t.shortCode,
  id: t.id,
  name: t.name,
  shortCode: t.shortCode,
  flag: t.flag ?? null,
  coverImage: t.coverImage ?? null,
  confederation: t.confederation ?? "",
}));

const clientPayload = {
  teams: teamsLite,
  matches: (knockoutData as any).matches,
  seedAssignments: (seed as any).slotAssignments ?? {},
  seedResults: (seed as any).results ?? [],
};
---

<section class={styles.equiposSection} id="equipos" data-section="equipos">
  <div class={styles.contentShell}>
    <div class={styles.topRow} data-animate="fade-up">
      <EquiposHero />
    </div>

    <div class="eq-board">
      <!-- IZQUIERDA (50%): portada grande del equipo seleccionado -->
      <div class="eq-detail" data-eq-detail>
        <figure class="eq-cover">
          <img class="eq-cover-img" data-eq-cover src="" alt="" width="640" height="425" loading="lazy" decoding="async" />
          <figcaption class="eq-detail-info">
            <span class="eq-detail-conf" data-eq-conf></span>
            <span class="eq-detail-name" data-eq-name>—</span>
          </figcaption>
        </figure>
      </div>

      <!-- DERECHA (50%): lista de los 4 clasificados -->
      <div class="eq-list-wrap">
        <p class="eq-list-title">Clasificados a semifinales</p>
        <div class="eq-list" data-eq-list role="list" aria-label="Clasificados a semifinales">
          <p class="eq-list-empty" data-eq-empty>Cargando clasificados…</p>
        </div>
      </div>
    </div>
  </div>

  <script type="application/json" data-equipos-payload set:html={JSON.stringify(clientPayload)} />
  <script>
    import "./equipos.knockout.client.js";
  </script>
</section>

<style>
  .eq-board {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(0.8rem, 1.8vw, 1.4rem);
    align-items: stretch;
    flex: 1 1 auto;
    min-height: 0;
  }

  /* ===== IZQUIERDA: portada grande (llena el alto de la columna) ===== */
  .eq-detail { display: flex; flex-direction: column; min-width: 0; min-height: 0; }
  .eq-cover {
    position: relative;
    margin: 0;
    flex: 1 1 auto;
    min-height: 0;
    border-radius: var(--pm-radius-lg);
    overflow: hidden;
    background: var(--pm-panel-soft, #f3f7ff);
    border: 2px solid rgba(255, 255, 255, 0.75);
    box-shadow: var(--pm-shadow-card-strong), 0 0 44px rgba(18, 109, 255, 0.14);
    line-height: 0;
  }
  .eq-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }
  .eq-cover-img[src=""] { opacity: 0; }
  .eq-detail-info {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: clamp(0.7rem, 2vw, 1.3rem) clamp(0.85rem, 2.4vw, 1.5rem);
    background: linear-gradient(to top, rgba(4, 16, 38, 0.92) 8%, rgba(4, 16, 38, 0.35) 55%, transparent);
  }
  .eq-detail-conf {
    font-family: var(--font-display); font-weight: 900; font-size: clamp(0.58rem, 1.1vw, 0.72rem);
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--pm-cyan-300, #7fe8f5);
  }
  .eq-detail-name {
    font-family: var(--font-display); font-weight: 950;
    font-size: clamp(1.5rem, 4vw, 3rem); line-height: 0.95; text-transform: uppercase; color: #fff;
    text-shadow: 0 2px 14px rgba(7, 23, 53, 0.55);
  }

  /* ===== DERECHA: lista de 16 (llena el alto de la columna) ===== */
  .eq-list-wrap { display: flex; flex-direction: column; gap: 0.5rem; min-width: 0; min-height: 0; }
  .eq-list-title {
    margin: 0; flex: 0 0 auto; font-family: var(--font-display); font-weight: 900; font-size: 0.82rem;
    letter-spacing: 0.05em; text-transform: uppercase; color: var(--pm-blue-900);
  }
  .eq-list {
    flex: 1 1 auto; min-height: 0;
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: minmax(0, 1fr); gap: clamp(0.4rem, 0.9vw, 0.65rem); align-content: stretch;
  }
  .eq-list-empty { grid-column: 1 / -1; margin: 0; font-family: var(--font-display); font-weight: 700; color: var(--pm-text-soft); padding: 0.6rem 0; }

  /* Las fichas de equipo las inyecta el cliente (innerHTML) -> :global para que apliquen.
     ETAPA SEMIFINALES: son 4 fichas en 2 filas (antes 8 en 4), así que cada una se estira al doble
     de alto; la bandera y el nombre suben en proporción para que la ficha no quede vacía. */
  :global(.eq-item) {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: clamp(0.5rem, 1.1vw, 1rem);
    padding: clamp(0.5rem, 1vw, 1rem) clamp(0.7rem, 1.2vw, 1.2rem); border-radius: var(--pm-radius-md);
    background: linear-gradient(100deg, color-mix(in srgb, var(--pm-blue-500) 10%, #fff), #fff 66%);
    border: 1px solid var(--pm-border-soft);
    box-shadow: var(--pm-shadow-soft);
    cursor: pointer; text-align: left; width: 100%;
    transition: border-color var(--pm-transition-fast), box-shadow var(--pm-transition-fast), transform var(--pm-transition-fast);
  }
  :global(.eq-item:hover) { transform: translateY(-1px); border-color: var(--pm-cyan-500); }
  :global(.eq-item:focus-visible) { outline: none; box-shadow: var(--pm-focus-ring); }
  :global(.eq-item[aria-current="true"]) {
    border-color: var(--pm-cyan-600);
    background: linear-gradient(100deg, color-mix(in srgb, var(--pm-cyan-500) 22%, #fff), #fff 62%);
    box-shadow: 0 0 0 2px var(--pm-cyan-500), var(--pm-shadow-soft);
  }
  :global(.eq-item-flag) {
    width: min(62%, 12rem); height: auto; aspect-ratio: 4 / 3; border-radius: 12px; flex: 0 1 auto; min-height: 0;
    object-fit: cover; border: 1.5px solid rgba(7, 23, 53, 0.14); box-shadow: 0 4px 14px rgba(7, 23, 53, 0.26);
    background: var(--pm-panel-soft);
  }
  :global(.eq-item-name) {
    font-family: var(--font-display); font-weight: 900; font-size: clamp(0.95rem, 1.5vw, 1.6rem); text-transform: uppercase;
    color: var(--pm-blue-900); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; max-width: 100%;
  }

  @media (max-width: 900px) {
    .eq-board { grid-template-columns: 1fr; }
    .eq-detail { position: static; }
  }
  @media (max-width: 480px) {
    .eq-list { grid-template-columns: 1fr; }
  }
</style>
