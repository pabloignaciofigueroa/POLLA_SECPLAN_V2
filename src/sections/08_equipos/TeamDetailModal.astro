---
---

<dialog class="team-modal" data-team-modal aria-labelledby="team-modal-title">
  <article class="modal-shell" data-modal-shell>
    <header class="modal-head">
      <div class="head-text">
        <p class="eyebrow" data-modal-confederation>—</p>
        <h2 id="team-modal-title" data-modal-name>—</h2>
        <p class="title" data-modal-title>—</p>
      </div>
      <button type="button" class="close" data-modal-close aria-label="Cerrar ficha">
        <span aria-hidden="true">✕</span>
      </button>
    </header>

    <figure class="team-portrait" data-modal-cover>
      <img
        src=""
        alt=""
        loading="lazy"
        decoding="async"
        width="1086"
        height="1448"
        data-modal-cover-img
      />
    </figure>

    <section class="meta-row" aria-label="Datos editoriales">
      <div>
        <dt>Grupo</dt>
        <dd data-modal-group>—</dd>
      </div>
      <div>
        <dt>Categoría</dt>
        <dd data-modal-category>—</dd>
      </div>
      <div>
        <dt>Formaciones</dt>
        <dd class="pills" data-modal-formations>—</dd>
      </div>
    </section>

    <section class="copy">
      <p data-modal-info-secondary>—</p>
      <p data-modal-info-tertiary>—</p>
    </section>

    <section class="especial">
      <div>
        <dt>Fortaleza</dt>
        <dd data-modal-fortaleza>—</dd>
      </div>
      <div>
        <dt>Riesgo</dt>
        <dd data-modal-riesgo>—</dd>
      </div>
    </section>

    <section class="players">
      <h3>Jugadores clave</h3>
      <ul data-modal-players>
        <li>—</li>
      </ul>
    </section>

    <section class="tags" aria-label="Estilo y tono">
      <ul data-modal-tags>
        <li>—</li>
      </ul>
    </section>

    <p class="empty-note" data-modal-empty hidden>
      Ficha editorial pendiente para esta selección.
    </p>
  </article>
</dialog>

<style>
  .team-modal {
    width: min(100% - 1.5rem, 820px);
    max-height: calc(100svh - 3rem);
    margin: auto;
    padding: 0;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .team-modal::backdrop {
    background: rgba(17, 24, 39, 0.55);
    backdrop-filter: blur(2px);
  }

  .modal-shell {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    padding: clamp(1rem, 2.5vw, 1.5rem);
    overflow-y: auto;
    max-height: calc(100svh - 3rem);
  }

  .modal-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: flex-start;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-line);
  }

  .team-portrait {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: rgba(7, 23, 53, 0.08);
    line-height: 0;
  }

  .team-portrait::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(7, 23, 53, 0) 46%, rgba(7, 23, 53, 0.32) 100%),
      linear-gradient(90deg, rgba(7, 23, 53, 0.16), rgba(7, 23, 53, 0));
    pointer-events: none;
  }

  .team-portrait img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .team-portrait[hidden] {
    display: none;
  }

  .head-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .eyebrow {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 950;
    line-height: 1;
    text-transform: uppercase;
  }

  .title {
    margin: 0;
    color: var(--color-text);
    font-size: 0.92rem;
    font-weight: 800;
  }

  .close {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid var(--color-line);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    color: var(--color-text);
    font-size: 1rem;
    cursor: pointer;
  }

  .close:hover {
    border-color: var(--color-text);
  }

  .meta-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 0;
  }

  .meta-row > div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  dt {
    color: var(--color-muted);
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .pills span {
    padding: 0.18rem 0.45rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .copy {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .copy p {
    margin: 0;
    color: var(--color-text);
    font-size: 0.85rem;
    line-height: 1.45;
  }

  .especial {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    padding: 0.7rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: rgba(247, 247, 242, 0.7);
  }

  .especial > div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .players h3 {
    margin: 0 0 0.4rem;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .players ul,
  .tags ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .players li {
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.85);
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 800;
  }

  .tags li {
    padding: 0.22rem 0.5rem;
    border: 1px dashed var(--color-muted);
    border-radius: 999px;
    color: var(--color-text);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .empty-note {
    margin: 0;
    padding: 0.8rem;
    border: 1px dashed var(--color-muted);
    border-radius: var(--radius-md);
    color: var(--color-muted);
    font-size: 0.8rem;
    text-align: center;
  }

  @media (max-width: 560px) {
    .team-modal {
      width: min(100% - 1rem, 820px);
    }

    .meta-row,
    .especial {
      grid-template-columns: 1fr;
    }
  }
</style>
