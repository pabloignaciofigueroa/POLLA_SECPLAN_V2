---
import type { EnrichedTeam } from "./equipos.logic";
import { shortDescription } from "./equipos.logic";
import TeamFlag from "../../components/ui/TeamFlag.astro";
import TeamCrest from "../../components/ui/TeamCrest.astro";
import TeamCoverImage from "../../components/ui/TeamCoverImage.astro";
import ConfederationLogo from "../../components/ui/ConfederationLogo.astro";

interface Props {
  team: EnrichedTeam;
}

const { team } = Astro.props;
const hasInfo = Boolean(team.info);
const groupKey = (team.group ?? "").toLowerCase();
const description = shortDescription(team.info, "Ficha editorial pendiente.");
---

<article
  class="team-card"
  data-team-card={team.id}
  data-team-group={team.group}
  data-group-key={groupKey}
  data-has-info={hasInfo ? "true" : "false"}
>
  <div class="cover-stage">
    <TeamCoverImage team={team} variant="full" alt={`Portada de ${team.name}`} />
  </div>

  <div class="card-shade" aria-hidden="true"></div>

  <header class="card-head">
    <span class="flag-pill">
      <TeamFlag team={team} size="md" rounded={false} decorative />
      <span class="flag-code">{team.shortCode}</span>
    </span>

    <button
      type="button"
      class="favorite"
      data-favorite-toggle={team.id}
      aria-label={`Marcar ${team.name} como favorito`}
      aria-pressed="false"
    >
      <span aria-hidden="true">*</span>
    </button>
  </header>

  <div class="card-content">
    <p class="confederation-tag" data-team-confederation>
      <ConfederationLogo code={team.confederation} size="xs" decorative className="conf-inline" />
      <span>{team.confederation}</span>
    </p>
    <h3 class="team-name" data-team-name>{team.name}</h3>
    <p class="team-description">{description}</p>
  </div>

  <footer class="card-foot">
    <span class="crest-overlay" aria-hidden="true">
      <TeamCrest team={team} size="md" variant="thumb" decorative />
    </span>
    <button
      type="button"
      class="view-ficha"
      data-view-ficha={team.id}
    >
      VER FICHA <span aria-hidden="true">-&gt;</span>
    </button>
  </footer>
</article>

<style>
  .team-card {
    --group-color: var(--pm-blue-500);
    --group-glow: var(--pm-shadow-blue);

    position: relative;
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-width: 0;
    min-height: 28.05rem;
    overflow: hidden;
    border: 1px solid transparent;
    border-radius: 0.62rem;
    background: var(--pm-blue-900);
    box-shadow: 0 14px 28px rgba(7, 23, 53, 0.18);
    transition: transform var(--pm-transition-fast), box-shadow var(--pm-transition-fast);
  }

  .team-card::before {
    content: "";
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 2;
    height: 0.26rem;
    background: var(--group-color);
  }

  .team-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 4;
    border: 1px solid color-mix(in srgb, var(--group-color) 55%, transparent);
    border-radius: inherit;
    pointer-events: none;
  }

  .team-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--group-glow);
  }

  .team-card[data-group-key="a"] { --group-color: var(--pm-group-a); --group-glow: 0 16px 36px rgba(34, 197, 94, 0.28); }
  .team-card[data-group-key="b"] { --group-color: var(--pm-group-b); --group-glow: var(--pm-shadow-blue); }
  .team-card[data-group-key="c"] { --group-color: var(--pm-group-c); --group-glow: var(--pm-shadow-orange); }
  .team-card[data-group-key="d"] { --group-color: var(--pm-group-d); --group-glow: var(--pm-shadow-purple); }
  .team-card[data-group-key="e"] { --group-color: var(--pm-group-e); --group-glow: var(--pm-shadow-cyan); }
  .team-card[data-group-key="f"] { --group-color: var(--pm-group-f); --group-glow: var(--pm-shadow-pink); }
  .team-card[data-group-key="g"] { --group-color: var(--pm-group-g); --group-glow: 0 16px 36px rgba(245, 184, 0, 0.28); }
  .team-card[data-group-key="h"] { --group-color: var(--pm-group-h); --group-glow: var(--pm-shadow-blue); }
  .team-card[data-group-key="i"] { --group-color: var(--pm-group-i); --group-glow: var(--pm-shadow-lime); }
  .team-card[data-group-key="j"] { --group-color: var(--pm-group-j); --group-glow: var(--pm-shadow-coral); }
  .team-card[data-group-key="k"] { --group-color: var(--pm-group-k); --group-glow: 0 16px 36px rgba(217, 70, 239, 0.28); }
  .team-card[data-group-key="l"] { --group-color: var(--pm-group-l); --group-glow: var(--pm-shadow-cyan); }

  .cover-stage {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--pm-panel-soft);
  }

  .cover-stage :global(.team-cover) {
    width: 100%;
    height: 100%;
    margin: 0;
    border-radius: 0;
    background: transparent;
  }

  .cover-stage :global(.team-cover img),
  :global([data-section="equipos"] [data-team-card] [data-team-cover] img) {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .card-shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(7, 23, 53, 0.52) 0%, rgba(7, 23, 53, 0.24) 42%, rgba(7, 23, 53, 0.02) 100%),
      linear-gradient(0deg, rgba(7, 23, 53, 0.72) 0%, rgba(7, 23, 53, 0.18) 34%, transparent 62%);
  }

  .card-head {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0.58rem 0;
  }

  .flag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.22rem 0.42rem;
    border: 1px solid rgba(255, 255, 255, 0.56);
    border-radius: 0.35rem;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 4px 12px rgba(7, 23, 53, 0.16);
  }

  .flag-code {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.06em;
  }

  .favorite {
    display: grid;
    place-items: center;
    width: 1.6rem;
    height: 1.6rem;
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 50%;
    background: rgba(7, 23, 53, 0.42);
    color: var(--pm-white);
    font-size: 0.78rem;
    font-weight: 900;
    cursor: pointer;
    transition: color var(--pm-transition-fast),
      border-color var(--pm-transition-fast),
      background var(--pm-transition-fast),
      transform var(--pm-transition-fast);
  }

  .favorite:hover {
    border-color: var(--pm-yellow-500);
    color: var(--pm-yellow-500);
    transform: scale(1.08);
  }

  .favorite:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring-yellow);
  }

  .favorite[aria-pressed="true"] {
    background: var(--pm-yellow-500);
    border-color: var(--pm-yellow-600);
    color: var(--pm-blue-900);
    box-shadow: 0 0 12px var(--pm-gold-glow);
  }

  .card-content {
    position: relative;
    z-index: 3;
    display: flex;
    min-width: 0;
    min-height: 4.6rem;
    flex-direction: column;
    justify-content: end;
    gap: 0.22rem;
    padding: 0.15rem 0.72rem 0.25rem;
  }

  .confederation-tag {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.28rem;
    margin: 0;
    padding: 0;
    background: transparent;
    color: var(--group-color);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .confederation-tag :global(.conf-inline) {
    background: rgba(255, 255, 255, 0.95);
    border-radius: 50%;
    padding: 1px;
  }

  .team-name {
    max-width: 9.8rem;
    margin: 0;
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2vw, 1.45rem);
    font-weight: 950;
    line-height: 0.9;
    text-shadow: 0 2px 10px rgba(7, 23, 53, 0.55);
    text-transform: uppercase;
  }

  .team-description {
    display: -webkit-box;
    max-width: 14rem;
    margin: 0;
    overflow: hidden;
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.65rem;
    font-weight: 700;
    line-height: 1.25;
    text-shadow: 0 2px 8px rgba(7, 23, 53, 0.5);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .card-foot {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.55rem;
    padding: 0.2rem 0.58rem 0.58rem 0.72rem;
  }

  .crest-overlay {
    display: inline-grid;
    place-items: center;
    width: 2.45rem;
    height: 2.45rem;
    padding: 0.22rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 2px 6px rgba(7, 23, 53, 0.18);
  }

  .view-ficha {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
    padding: 0.36rem 0.68rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 0.4rem;
    background: linear-gradient(135deg, var(--group-color), color-mix(in srgb, var(--group-color) 72%, var(--pm-blue-900)));
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform var(--pm-transition-fast), box-shadow var(--pm-transition-fast);
  }

  .view-ficha:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 16px color-mix(in srgb, var(--group-color) 48%, transparent);
  }

  .view-ficha:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  @media (max-width: 560px) {
    .team-card {
      min-height: 32.25rem;
    }

    .team-name {
      max-width: 12rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .team-card:hover,
    .favorite:hover,
    .view-ficha:hover {
      transform: none;
    }
  }
</style>
