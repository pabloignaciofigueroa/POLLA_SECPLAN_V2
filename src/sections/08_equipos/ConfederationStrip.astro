---
import ConfederationLogo from "../../components/ui/ConfederationLogo.astro";

interface Props {
  confederations: string[];
}

const { confederations } = Astro.props;
---

<aside class="confederation-strip" aria-label="Confederaciones representadas">
  <span class="label">CONFEDERACIONES</span>
  <ul class="list" role="list">
    {confederations.map((conf) => (
      <li>
        <ConfederationLogo code={conf} size="sm" decorative />
        <span class="name">{conf}</span>
      </li>
    ))}
  </ul>
</aside>

<style>
  .confederation-strip {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
    padding: 0.58rem 0.85rem;
    border: 1px solid rgba(7, 23, 53, 0.1);
    border-radius: 999px 999px 0 0;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 -8px 26px rgba(7, 23, 53, 0.08);
  }

  .label {
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.28rem 0.62rem;
    border: 1px solid rgba(7, 23, 53, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.85);
  }


  .name {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .confederation-strip {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .list {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    li {
      flex-shrink: 0;
    }
  }
</style>
