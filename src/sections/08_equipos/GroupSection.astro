---
import TeamCard from "./TeamCard.astro";
import type { GroupBucket } from "./equipos.logic";

interface Props {
  bucket: GroupBucket;
  activeGroup: string;
}

const { bucket, activeGroup } = Astro.props;
const isActive = bucket.id === activeGroup;
const groupKey = bucket.id.toLowerCase();
---

<section class="group-section" data-group-section={bucket.id} data-group-key={groupKey} hidden={!isActive}>
  <header class="group-header">
    <div class="title-wrap">
      <h2 class="group-title">GRUPO {bucket.id}</h2>
      <span class="group-count">{bucket.teams.length} selecciones</span>
    </div>
    <button type="button" class="group-jump" data-group-jump={bucket.id}>
      Ver grupo completo <span aria-hidden="true">-&gt;</span>
    </button>
  </header>

  <div class="team-grid">
    {bucket.teams.map((team) => <TeamCard team={team} />)}
  </div>
</section>

<style>
  .group-section {
    --group-color: var(--pm-blue-500);
    --group-glow: rgba(18, 109, 255, 0.22);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
  }

  .group-section[hidden] {
    display: none;
  }

  .group-section[data-group-key="a"] { --group-color: var(--pm-group-a); --group-glow: rgba(34, 197, 94, 0.24); }
  .group-section[data-group-key="b"] { --group-color: var(--pm-group-b); --group-glow: rgba(18, 109, 255, 0.24); }
  .group-section[data-group-key="c"] { --group-color: var(--pm-group-c); --group-glow: rgba(255, 138, 0, 0.24); }
  .group-section[data-group-key="d"] { --group-color: var(--pm-group-d); --group-glow: rgba(124, 53, 255, 0.24); }
  .group-section[data-group-key="e"] { --group-color: var(--pm-group-e); --group-glow: rgba(24, 221, 242, 0.24); }
  .group-section[data-group-key="f"] { --group-color: var(--pm-group-f); --group-glow: rgba(255, 47, 179, 0.24); }
  .group-section[data-group-key="g"] { --group-color: var(--pm-group-g); --group-glow: rgba(245, 184, 0, 0.24); }
  .group-section[data-group-key="h"] { --group-color: var(--pm-group-h); --group-glow: rgba(0, 91, 255, 0.24); }
  .group-section[data-group-key="i"] { --group-color: var(--pm-group-i); --group-glow: rgba(182, 255, 0, 0.24); }
  .group-section[data-group-key="j"] { --group-color: var(--pm-group-j); --group-glow: rgba(255, 64, 88, 0.24); }
  .group-section[data-group-key="k"] { --group-color: var(--pm-group-k); --group-glow: rgba(217, 70, 239, 0.24); }
  .group-section[data-group-key="l"] { --group-color: var(--pm-group-l); --group-glow: rgba(0, 184, 217, 0.24); }

  .group-header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
  }

  .group-header::after {
    content: "";
    grid-column: 2;
    grid-row: 1;
    min-width: 1.5rem;
    height: 2px;
    background: linear-gradient(90deg, var(--group-color), transparent);
  }

  .title-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    min-width: 0;
    padding: 0.38rem 0.72rem 0.34rem;
    border-radius: 0.55rem 0.55rem 0.18rem 0.18rem;
    background: linear-gradient(135deg, var(--group-color), color-mix(in srgb, var(--group-color) 72%, var(--pm-blue-900)));
    color: var(--pm-white);
    box-shadow: 0 10px 24px var(--group-glow);
  }

  .group-title {
    margin: 0;
    color: currentColor;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .group-count {
    color: currentColor;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    opacity: 0.88;
    text-transform: uppercase;
  }

  .group-jump {
    display: inline-flex;
    align-items: center;
    grid-column: 3;
    grid-row: 1;
    justify-self: end;
    gap: 0.38rem;
    padding: 0.25rem 0.1rem;
    border: 0;
    background: transparent;
    color: var(--group-color);
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .group-jump:hover {
    color: var(--pm-blue-900);
  }

  .group-jump:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.55rem, 1vw, 0.78rem);
  }

  @media (max-width: 1080px) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .group-header {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .group-header::after {
      display: none;
    }

    .group-jump {
      justify-self: start;
    }

    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
