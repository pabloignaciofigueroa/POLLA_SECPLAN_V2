---
import TeamFlag from "../../components/ui/TeamFlag.astro";

interface Team {
  id: string;
  name: string;
  shortCode: string;
  flag?: string;
}

interface Props {
  team: Team;
  ariaHidden?: boolean;
}

const { team, ariaHidden = false } = Astro.props;
---

<span
  class="chip"
  data-team-code={team.shortCode}
  aria-hidden={ariaHidden ? "true" : undefined}
  title={team.name}
>
  <span class="chip-flag">
    <TeamFlag team={team} size="sm" rounded decorative />
  </span>
  <span class="code">{team.shortCode}</span>
</span>

<style>
  .chip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.32rem 0.8rem 0.32rem 0.36rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--pm-white), var(--pm-panel-soft));
    border: 1px solid var(--pm-border-blue);
    box-shadow:
      0 7px 15px rgba(7, 23, 53, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--pm-blue-900);
    user-select: none;
  }

  .chip-flag {
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    box-shadow:
      0 0 0 2px var(--pm-white),
      0 3px 8px rgba(7, 23, 53, 0.22);
  }

  .code {
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
