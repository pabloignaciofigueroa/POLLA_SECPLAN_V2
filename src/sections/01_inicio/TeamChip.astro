---
import TeamFlag from "../../components/ui/TeamFlag.astro";

interface Team {
  id: string;
  name: string;
  shortCode: string;
  flag?: string;
}

interface Props {
  team: Team;
  ariaHidden?: boolean;
}

const { team, ariaHidden = false } = Astro.props;
---

<span
  class="chip"
  aria-hidden={ariaHidden ? "true" : undefined}
  title={team.name}
>
  <TeamFlag team={team} size="sm" rounded={false} decorative />
  <span class="code">{team.shortCode}</span>
</span>

<style>
  .chip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: var(--color-bg);
    border: 1px solid var(--color-line);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text);
    user-select: none;
  }

  .code {
    font-family: var(--font-display);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
