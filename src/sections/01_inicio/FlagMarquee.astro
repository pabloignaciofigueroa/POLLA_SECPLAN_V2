---
import teams from "../../data/teams.json";
import knockoutTeams from "../../data/knockout-teams.json";
import knockoutMatches from "../../data/knockout-matches.json";
import seed from "../../data/knockout-results.json";
import TeamChip from "./TeamChip.astro";

// Polla de ELIMINATORIAS. Etapa CUARTOS: se muestran SOLO los 8 clasificados que avanzaron de
// octavos. El SSR renderiza los 32 (fallback sin-JS); el cliente los filtra a los 8 ganadores
// reales derivados de los resultados vivos (localStorage/Supabase). Orden = knockout-teams.
const byCode = new Map((teams as any[]).map((t) => [t.shortCode, t]));
const qualified = (knockoutTeams.slots as any[])
  .filter((s) => s.concrete)
  .map((s) => byCode.get(s.code))
  .filter(Boolean);

const marqueePayload = {
  matches: (knockoutMatches as any).matches,
  seedAssignments: (seed as any).slotAssignments ?? {},
  seedResults: (seed as any).results ?? [],
};
---

<aside class="marquee" data-section="flag-marquee" aria-label="8 clasificados a cuartos">
  <div class="summary">
    <span class="icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <circle cx="12" cy="12" r="9" />
        <ellipse cx="12" cy="12" rx="9" ry="4" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="12" y1="3" x2="12" y2="21" />
      </svg>
    </span>
    <div class="summary-text">
      <span class="summary-label">Clasificados</span>
      <span class="summary-value">8 SELECCIONES</span>
    </div>
  </div>

  <div class="viewport">
    <div class="track" data-marquee-track>
      {qualified.map((team) => <TeamChip team={team} />)}
      {qualified.map((team) => <TeamChip team={team} ariaHidden />)}
    </div>
  </div>

  <div class="phase-status">
    <span>Cuartos</span>
    <span class="dot" aria-hidden="true">·</span>
    <span>4 cruces</span>
  </div>

  <script type="application/json" data-marquee-payload set:html={JSON.stringify(marqueePayload)} />
  <script>
    import "./inicio.marquee.client.js";
  </script>
</aside>

<style>
  .marquee {
    position: relative;
    display: flex;
    align-items: stretch;
    width: 100%;
    overflow: hidden;
    border-radius: var(--pm-radius-xl);
    background: var(--pm-white);
    border: 1px solid rgba(18, 109, 255, 0.18);
    box-shadow: 0 18px 38px rgba(7, 23, 53, 0.14), var(--pm-shadow-cyan);
  }

  .summary {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.62rem 1rem;
    border-right: 1px solid var(--pm-cyan-200);
    z-index: 2;
    background: linear-gradient(135deg, var(--pm-blue-500), var(--pm-cyan-500));
    color: var(--pm-white);
  }

  .icon {
    width: 34px;
    height: 34px;
    color: var(--pm-white);
    display: inline-block;
  }

  .icon svg {
    width: 100%;
    height: 100%;
  }

  .summary-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .summary-label {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  .summary-value {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: var(--pm-white);
  }

  .viewport {
    flex: 1 1 auto;
    overflow: hidden;
    display: flex;
    align-items: center;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .track {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: max-content;
    padding: 0.46rem 0;
    animation: marquee-left 60s linear infinite;
  }

  .marquee:hover .track {
    animation-play-state: paused;
  }

  .phase-status {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.62rem 1.05rem;
    border-left: 1px solid var(--pm-cyan-200);
    background: var(--pm-white);
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pm-blue-700);
    z-index: 2;
  }

  .dot {
    color: var(--pm-cyan-500);
  }

  @keyframes marquee-left {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 700px) {
    .summary {
      padding: 0.55rem 0.75rem;
      gap: 0.5rem;
    }
    .summary-value {
      font-size: 0.85rem;
    }
    .phase-status {
      display: none;
    }
    .track {
      animation-duration: 45s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      animation: none;
    }
  }
</style>
