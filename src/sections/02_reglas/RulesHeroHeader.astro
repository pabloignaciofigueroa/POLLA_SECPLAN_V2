---
---

<header class="hero-header" data-section="reglas" data-animate="fade-up">
  <h1>
    <span class="title-mark" aria-hidden="true"></span>
    <span class="title-main">Las 5</span>
    <span class="title-accent">Reglas Clave</span>
    <span class="title-mark title-mark--right" aria-hidden="true"></span>
  </h1>
  <p class="subtitle">Tutorial simple en <strong>30 segundos</strong></p>
</header>

<style>
  .hero-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.38rem;
    text-align: center;
  }

  h1 {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    column-gap: 0.24em;
    row-gap: 0.05em;
    font-family: var(--font-display);
    font-size: clamp(2.15rem, 5.4vw, 4.85rem);
    font-weight: 950;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .title-mark {
    position: relative;
    width: clamp(2.1rem, 4.8vw, 4.1rem);
    height: 1.25rem;
    flex: 0 0 auto;
  }

  .title-mark::before,
  .title-mark::after {
    content: "";
    position: absolute;
    right: 0.25rem;
    width: 70%;
    height: 0.16rem;
    border-radius: 999px;
    background: var(--pm-purple-500);
  }

  .title-mark::before {
    top: 0.22rem;
    transform: rotate(10deg);
  }

  .title-mark::after {
    bottom: 0.2rem;
    width: 45%;
    transform: rotate(-8deg);
  }

  .title-mark--right {
    transform: scaleX(-1);
  }

  .title-main {
    color: var(--pm-blue-900);
  }

  .title-accent {
    background: linear-gradient(135deg, var(--pm-purple-500), var(--pm-pink-500));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .subtitle {
    margin: 0;
    color: var(--pm-text-body);
    font-size: clamp(0.95rem, 1.7vw, 1.25rem);
    font-weight: 600;
  }

  .subtitle::before,
  .subtitle::after {
    content: "";
    display: inline-block;
    width: 0.45rem;
    aspect-ratio: 1;
    margin-inline: 0.8rem;
    border-radius: 999px;
    background: var(--pm-purple-500);
    vertical-align: 0.12em;
  }

  .subtitle strong {
    color: var(--pm-purple-700);
    font-weight: 900;
  }

  @media (max-width: 640px) {
    .title-mark,
    .subtitle::before,
    .subtitle::after {
      display: none;
    }
  }
</style>
