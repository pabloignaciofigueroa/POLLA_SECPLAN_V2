---
const panelStyle = [
  "overflow:hidden",
  "min-height:100%",
  "border:1px solid color-mix(in srgb, var(--pm-purple-500) 40%, transparent)",
  "border-radius:0.95rem",
  "background:linear-gradient(135deg, rgba(255, 255, 255, 0.92), color-mix(in srgb, var(--pm-purple-300) 12%, white)), var(--pm-panel-soft)",
  "box-shadow:0 14px 32px rgba(7, 23, 53, 0.12)",
].join(";");

const headerStyle = [
  "display:flex",
  "align-items:center",
  "gap:0.55rem",
  "padding:0.42rem 0.85rem",
  "background:linear-gradient(120deg, var(--pm-purple-600) 0 76%, var(--pm-yellow-400) 76% 82%, var(--pm-white) 82%)",
  "color:var(--pm-white)",
].join(";");

const iconStyle = [
  "display:grid",
  "width:1.8rem",
  "aspect-ratio:1",
  "place-items:center",
  "color:var(--pm-yellow-400)",
].join(";");

const svgStyle = [
  "width:100%",
  "height:100%",
  "filter:drop-shadow(0 4px 7px rgba(245, 184, 0, 0.3))",
].join(";");

const titleStyle = [
  "margin:0",
  "color:var(--pm-white)",
  "font-family:var(--font-display)",
  "font-size:0.9rem",
  "font-weight:900",
  "letter-spacing:0.03em",
  "text-transform:uppercase",
].join(";");

const rowsStyle = "display:grid";

const rowStyle = [
  "display:grid",
  "grid-template-columns:3.6rem minmax(0, 1fr) 3rem",
  "align-items:center",
  "gap:0.6rem",
  "min-height:3.25rem",
  "padding:0.48rem 0.85rem",
  "border-bottom:1px solid var(--pm-border-soft)",
].join(";");

const lastRowStyle = [
  "display:grid",
  "grid-template-columns:3.6rem minmax(0, 1fr) 3rem",
  "align-items:center",
  "gap:0.6rem",
  "min-height:3.25rem",
  "padding:0.48rem 0.85rem",
].join(";");

const firstRankStyle = [
  "display:grid",
  "min-height:2.1rem",
  "place-items:center",
  "border:1px solid color-mix(in srgb, var(--pm-purple-500) 34%, transparent)",
  "border-radius:0.55rem",
  "background:color-mix(in srgb, var(--pm-purple-500) 14%, white)",
  "color:var(--pm-purple-700)",
  "font-family:var(--font-display)",
  "font-weight:900",
  "text-transform:uppercase",
].join(";");

const secondRankStyle = [
  "display:grid",
  "min-height:2.1rem",
  "place-items:center",
  "border:1px solid color-mix(in srgb, var(--pm-orange-500) 34%, transparent)",
  "border-radius:0.55rem",
  "background:color-mix(in srgb, var(--pm-orange-500) 14%, white)",
  "color:var(--pm-orange-600)",
  "font-family:var(--font-display)",
  "font-weight:900",
  "text-transform:uppercase",
].join(";");

const copyStyle = [
  "margin:0",
  "color:var(--pm-text-body)",
  "font-size:0.76rem",
  "line-height:1.35",
].join(";");

const firstPointsStyle = [
  "margin:0",
  "color:var(--pm-purple-600)",
  "font-family:var(--font-display)",
  "font-size:1.22rem",
  "font-weight:900",
  "text-align:right",
].join(";");

const secondPointsStyle = [
  "margin:0",
  "color:var(--pm-orange-600)",
  "font-family:var(--font-display)",
  "font-size:1.22rem",
  "font-weight:900",
  "text-align:right",
].join(";");
---

<aside class="group-bonus-panel" data-group-bonus-panel aria-labelledby="group-bonus-title" style={panelStyle}>
  <div class="group-bonus-header" style={headerStyle}>
    <span class="group-bonus-icon" aria-hidden="true" style={iconStyle}>
      <svg viewBox="0 0 72 72" fill="none" style={svgStyle}>
        <path d="M26 13h20v14c0 10-4 18-10 18s-10-8-10-18V13Z" fill="currentColor" />
        <path d="M26 19H15c0 10 4 16 13 17M46 19h11c0 10-4 16-13 17" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
        <path d="M36 45v11M24 61h24M29 56h14" stroke="currentColor" stroke-width="5" stroke-linecap="round" />
        <path d="M15 48c-5-4-7-9-7-14M57 48c5-4 7-9 7-14" stroke="currentColor" stroke-width="3" stroke-linecap="round" opacity="0.35" />
      </svg>
    </span>
    <p id="group-bonus-title" style={titleStyle}>Tambien sumas por grupo</p>
  </div>

  <div class="group-bonus-rows" style={rowsStyle}>
    <article class="group-bonus-row" data-rank="first" style={rowStyle}>
      <span style={firstRankStyle}>1ro</span>
      <p style={copyStyle}>Eliges al primero del grupo</p>
      <strong style={firstPointsStyle}>+1</strong>
    </article>
    <article class="group-bonus-row" data-rank="second" style={lastRowStyle}>
      <span style={secondRankStyle}>2do</span>
      <p style={copyStyle}>Eliges al segundo del grupo</p>
      <strong style={secondPointsStyle}>+3</strong>
    </article>
  </div>
</aside>
