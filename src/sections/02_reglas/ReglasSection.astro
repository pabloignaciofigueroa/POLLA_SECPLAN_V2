---
import styles from "./ReglasSection.module.css";
import RulesHeroHeader from "./RulesHeroHeader.astro";
import RulesCardsGrid from "./RulesCardsGrid.astro";
import ScoringPanel from "./ScoringPanel.astro";
import WorldPodiumPanel from "./WorldPodiumPanel.astro";
import RulesActionPanel from "./RulesActionPanel.astro";
import FairPlayFooter from "./FairPlayFooter.astro";

// Polla de ELIMINATORIAS: ya no hay grupos. Parte desde dieciseisavos de final.
const rules = [
  {
    number: "1",
    title: "Parte en dieciseisavos",
    description: "Ya no hay grupos. La polla arranca en los dieciseisavos y todos desde cero.",
    icon: "ball",
    tone: "blue",
  },
  {
    number: "2",
    title: "Marcador + quién avanza",
    description: "Predice el resultado de cada cruce. Si empatas, elige quién pasa por penales.",
    icon: "chart",
    tone: "green",
  },
  {
    number: "3",
    title: "Arma tu podio",
    description: "Elige campeón, subcampeón, tercer y cuarto lugar entre los 32 clasificados.",
    icon: "trophy",
    tone: "purple",
  },
  {
    number: "4",
    title: "Rondas bloqueadas",
    description: "Octavos en adelante se abren cuando se conozcan los clasificados.",
    icon: "lock",
    tone: "orange",
  },
  {
    number: "5",
    title: "Gana la gloria",
    description: "Suma puntos cruce a cruce y llega a la cima del ranking.",
    icon: "trophy",
    tone: "red",
  },
];

/*
  LONE WOLF:
  Se otorga cuando un jugador acierta el resultado exacto de un cruce y ningún otro
  jugador acertó ese mismo resultado exacto. No es premio por racha ni manual.
*/
const scoringRules = [
  {
    id: "tendencia",
    label: "TENDENCIA",
    description: "Aciertas la dirección del marcador: gana local, empate o gana visita",
    points: "+1",
    icon: "trend",
  },
  {
    id: "exacto",
    label: "EXACTO",
    description: "Resultado exacto del cruce (ya incluye la tendencia)",
    points: "+3",
    icon: "target",
  },
  {
    id: "lone-wolf",
    label: "LONE WOLF",
    description: "Exacto único entre todos los jugadores",
    points: "+5",
    icon: "wolf",
  },
  {
    id: "penales",
    label: "BONUS PENALES",
    description: "El partido termina empatado, predijiste empate y aciertas quién pasa por penales",
    points: "+1",
    icon: "target",
  },
];
---

<section class={styles.reglasSection} id="reglas" data-section="reglas">
  <div class={styles.trophyDeco} aria-hidden="true">
    <img
      src="/assets/copa/trophy-worldcup-main.webp"
      alt=""
      width="400"
      height="560"
      loading="lazy"
      class={styles.trophyImg}
    />
  </div>
  <div class={styles.contentShell}>
    <RulesHeroHeader />

    <RulesCardsGrid rules={rules} />

    <div class={styles.bottomLayout} data-animate="fade-up" style="--i:7">
      <div class={styles.scoringChallenge}>
        <ScoringPanel scoringRules={scoringRules} />
        <WorldPodiumPanel />
      </div>
      <RulesActionPanel />
    </div>

    <FairPlayFooter />
  </div>
</section>
