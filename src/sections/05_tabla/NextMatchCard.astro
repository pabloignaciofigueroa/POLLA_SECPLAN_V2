---
import { INLINE } from "../../lib/ui-assets/uiAssets";
import type { Match } from "../../lib/tabla/types";

interface Props {
  match?: Match;
}

const { match } = Astro.props;
const dateLabel = match ? new Intl.DateTimeFormat("es-CL", { day: "2-digit", month: "short" }).format(new Date(match.dateChile)) : "--";
---

<article class="next-match-card" data-next-match-card>
  <span class="next-icon" aria-hidden="true">
    <img src={INLINE.calendar.src} alt="" width={INLINE.calendar.width} height={INLINE.calendar.height} loading="lazy" decoding="async" />
  </span>
  <div>
    <p>Próximo partido</p>
    <strong>
      <span data-next-home>{match?.homeTeam.name ?? "Por definir"}</span>
      <span>vs</span>
      <span data-next-away>{match?.awayTeam.name ?? "Por definir"}</span>
    </strong>
    <small><span data-next-date>{dateLabel}</span> · <span data-next-time>{match?.timeChile ?? "--:--"}</span> Chile</small>
  </div>
  <a href="/proximo-partido" aria-label="Ver detalle del próximo partido">Ver detalles</a>
</article>

<style>
  .next-match-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.6rem;
    align-items: center;
    padding: 0.6rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--pm-cyan-500) 34%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-cyan-500) 22%, transparent),
        color-mix(in srgb, var(--pm-blue-500) 28%, transparent)
      ),
      var(--pm-panel-soft);
  }

  .next-icon {
    display: grid;
    width: 2.4rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
  }

  .next-icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  p,
  strong,
  small {
    margin: 0;
  }

  p {
    color: var(--color-muted);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  strong {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.2rem;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.86rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  small {
    display: block;
    margin-top: 0.15rem;
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 800;
  }

  a {
    display: inline-grid;
    min-height: 2.4rem;
    place-items: center;
    padding-inline: 0.85rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-text);
    font-size: 0.72rem;
    font-weight: 950;
    text-decoration: none;
    text-transform: uppercase;
  }

  @media (max-width: 540px) {
    .next-match-card {
      grid-template-columns: 1fr;
    }

    a {
      justify-self: stretch;
    }
  }
</style>
