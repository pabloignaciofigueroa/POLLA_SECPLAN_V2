---
import type { Movement } from "../../lib/tabla/types";

interface Props {
  movement: Movement;
}

const { movement } = Astro.props;

const labels: Record<Movement, string> = {
  up: "Sube",
  down: "Baja",
  same: "Mantiene",
  new: "Nuevo",
};

const SECT = "/assets/polla-mundialera/sections/05_tabla";
const UI = "/assets/polla-mundialera/00_shared/ui";
const icons: Record<Movement, { src: string; w: number; h: number }> = {
  up: { src: `${SECT}/icon-trend-up-green.webp`, w: 456, h: 460 },
  down: { src: `${SECT}/icon-trend-down-red.webp`, w: 454, h: 460 },
  same: { src: `${SECT}/icon-trend-neutral-gray.webp`, w: 452, h: 460 },
  new: { src: `${UI}/icon-star-blue.webp`, w: 307, h: 320 },
};
const icon = icons[movement];
---

<span class="movement" data-movement={movement} aria-label={labels[movement]}>
  <img data-movement-icon src={icon.src} alt="" width={icon.w} height={icon.h} loading="lazy" decoding="async" />
</span>

<style>
  .movement {
    display: inline-grid;
    width: 1.5rem;
    aspect-ratio: 1;
    place-items: center;
    padding: 1px;
    border: 1px solid transparent;
    border-radius: 999px;
  }

  .movement img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .movement[data-movement="up"] {
    background: color-mix(in srgb, var(--pm-green-500) 12%, white);
    border-color: color-mix(in srgb, var(--pm-green-600) 30%, transparent);
  }

  .movement[data-movement="down"] {
    background: color-mix(in srgb, var(--pm-red-500) 12%, white);
    border-color: color-mix(in srgb, var(--pm-red-500) 30%, transparent);
  }

  .movement[data-movement="same"] {
    background: color-mix(in srgb, var(--pm-cyan-500) 12%, white);
    border-color: color-mix(in srgb, var(--pm-cyan-600) 30%, transparent);
  }

  .movement[data-movement="new"] {
    background: color-mix(in srgb, var(--pm-pink-500) 12%, white);
    border-color: color-mix(in srgb, var(--pm-pink-500) 30%, transparent);
  }

  /* El src lo cambia tabla.client.js sobre el mismo nodo: el holder debe mandar. */
  :global([data-section="tabla"] [data-movement] img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
