---
import type { Match, MatchResult } from "../../lib/tabla/types";

interface Props {
  match: Match;
  result?: MatchResult;
}

const { match, result } = Astro.props;
const hasScore = Number.isInteger(result?.homeScore) && Number.isInteger(result?.awayScore);
const homeScore = hasScore ? result?.homeScore : "-";
const awayScore = hasScore ? result?.awayScore : "-";
const statusLabel = hasScore
  ? result?.status === "finished"
    ? "FINAL"
    : "EN VIVO"
  : "EN ESPERA";
const minute = hasScore
  ? result?.minute ?? (result?.status === "finished" ? "Finalizado" : "00:00")
  : "Sin goles aun";
const separator = hasScore ? "vs" : "/";
const state = hasScore ? result?.status ?? "in_progress" : "waiting";
---

<article class="live-match-card" data-live-match-card data-match-id={match.id} data-live-state={state}>
  <div class="status-row">
    <span class="live-pill">
      <span class="live-dot" aria-hidden="true"></span>
      <span data-live-status>{statusLabel}</span>
    </span>
  </div>

  <div class="score-layout">
    <div class="team-block">
      <span class="team-flag" aria-hidden="true">
        <img src={`/assets/flags/${match.homeTeam.id}.svg`} alt="" width="160" height="120" loading="lazy" decoding="async" data-live-home-flag />
      </span>
      <strong data-live-home>{match.homeTeam.name}</strong>
    </div>

    <div class="score-block">
      <p><span data-live-home-score>{homeScore}</span><span class="sep" data-live-separator>{separator}</span><span data-live-away-score>{awayScore}</span></p>
      <time data-live-minute>{minute}</time>
    </div>

    <div class="team-block team-away">
      <span class="team-flag" aria-hidden="true">
        <img src={`/assets/flags/${match.awayTeam.id}.svg`} alt="" width="160" height="120" loading="lazy" decoding="async" data-live-away-flag />
      </span>
      <strong data-live-away>{match.awayTeam.name}</strong>
    </div>
  </div>

  <p class="stadium" data-live-stadium>{match.location}</p>
</article>

<style>
  .live-match-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0.72rem;
    border: 1px solid var(--pm-red-500);
    border-radius: var(--pm-radius-lg);
    background: linear-gradient(180deg, var(--pm-white), var(--pm-red-100));
    box-shadow: var(--pm-shadow-coral);
  }

  .live-match-card[data-live-state="waiting"] {
    border-color: var(--pm-yellow-500);
    background: linear-gradient(180deg, var(--pm-white), color-mix(in srgb, var(--pm-yellow-500) 18%, white));
    box-shadow: var(--pm-shadow-yellow);
  }

  .status-row {
    display: flex;
    justify-content: center;
  }

  .live-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.34rem 0.85rem;
    border-radius: 999px;
    background: var(--pm-state-live-bg);
    color: var(--pm-state-live-text);
    font-family: var(--font-ui);
    font-size: clamp(0.68rem, 0.75vw, 0.74rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.2;
    text-transform: uppercase;
    box-shadow: 0 0 12px rgba(255, 64, 88, 0.45);
  }

  .live-match-card[data-live-state="waiting"] .live-pill {
    background: var(--pm-yellow-500);
    color: var(--pm-blue-900);
    box-shadow: 0 0 12px rgba(255, 210, 45, 0.35);
  }

  .live-dot {
    display: inline-block;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--pm-white);
    animation: livePulse 1.4s ease-in-out infinite;
  }

  .live-match-card[data-live-state="waiting"] .live-dot {
    background: var(--pm-blue-900);
    animation: none;
  }

  @keyframes livePulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.45; transform: scale(0.85); }
  }

  .score-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 0.6rem;
    align-items: center;
  }

  .team-block {
    display: grid;
    gap: 0.35rem;
    justify-items: center;
    min-width: 0;
    text-align: center;
  }

  .team-flag {
    display: grid;
    width: clamp(2.6rem, 4.5vw, 3.5rem);
    aspect-ratio: 1;
    place-items: center;
    overflow: hidden;
    border: 2px solid var(--pm-blue-500);
    border-radius: 999px;
    background: var(--pm-blue-100);
  }

  .team-flag img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  strong {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    font-weight: 950;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .score-block {
    display: grid;
    justify-items: center;
    gap: 0.35rem;
  }

  .score-block p {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    margin: 0;
    color: var(--pm-blue-900);
    font-family: var(--font-score);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .score-block p .sep {
    font-size: 0.9rem;
    font-family: var(--font-display);
    text-transform: uppercase;
    color: var(--pm-red-500);
  }

  time {
    padding: 0.34rem 0.72rem;
    border: 1px solid var(--pm-red-500);
    border-radius: var(--pm-radius-sm);
    background: var(--pm-white);
    color: var(--pm-red-600);
    font-family: var(--font-score);
    font-weight: 900;
  }

  .stadium {
    margin: 0;
    color: var(--pm-text-body);
    font-size: 0.82rem;
    font-weight: 600;
    text-align: center;
  }

  @media (max-width: 520px) {
    .score-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-dot {
      animation: none;
    }
  }
</style>
