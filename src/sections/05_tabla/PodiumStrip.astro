---
import type { RankingRow } from "../../lib/tabla/types";

interface Props {
  rows: RankingRow[];
}

const { rows } = Astro.props;
const top = rows.slice(0, 3);
const leaderPoints = top[0]?.points ?? 0;
const slotLabel = ["1º", "2º", "3º"];
---

{top.length > 0 && (
  <section class="podium" data-podium-strip aria-label="Podio de la tabla">
    {top.map((row, index) => (
      <article
        class="podium-card"
        data-podium-slot={index + 1}
        data-player-id={row.playerId}
        data-rank={`top-${index + 1}`}
      >
        <span class="slot" aria-hidden="true">{slotLabel[index]}</span>
        <span class="avatar" aria-hidden="true">
          <img
            src={row.avatarThumb ?? row.avatar}
            alt=""
            width="120"
            height="120"
            loading="lazy"
            decoding="async"
            data-podium-avatar
          />
        </span>
        <strong class="name" data-podium-name>{row.name}</strong>
        <span class="pts"><b data-podium-points>{row.points}</b> pts</span>
        <span class="gap" data-podium-gap>
          {index === 0 ? "LÍDER" : `a ${Math.max(0, leaderPoints - row.points)} pts`}
        </span>
      </article>
    ))}
  </section>
)}

<style>
  .podium {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.4rem, 1vw, 0.7rem);
    align-items: end;
  }

  .podium-card {
    display: grid;
    justify-items: center;
    gap: 0.2rem;
    padding: 0.55rem 0.5rem 0.6rem;
    border: 1px solid color-mix(in srgb, var(--pm-sec-tabla-b) 32%, transparent);
    border-radius: var(--radius-lg);
    background: var(--pm-panel-soft);
    text-align: center;
    transition: transform var(--pm-transition-fast), box-shadow var(--pm-transition-fast);
  }

  .podium-card[data-rank="top-1"] {
    background: linear-gradient(160deg, var(--pm-rank-gold-bg), var(--pm-white));
    border-color: var(--pm-gold-700);
    box-shadow: 0 12px 30px var(--pm-gold-glow);
    transform: translateY(-0.25rem) scale(1.02);
  }

  .podium-card[data-rank="top-2"] {
    background: linear-gradient(160deg, var(--pm-rank-silver-bg), var(--pm-white));
    border-color: var(--pm-rank-silver);
  }

  .podium-card[data-rank="top-3"] {
    background: linear-gradient(160deg, var(--pm-rank-bronze-bg), var(--pm-white));
    border-color: var(--pm-rank-bronze);
  }

  .podium-card.is-cross-highlight {
    box-shadow: 0 0 0 2px var(--pm-pink-500), 0 10px 24px rgba(7, 23, 53, 0.12);
  }

  .slot {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    color: var(--pm-blue-900);
  }

  .podium-card[data-rank="top-1"] .slot { color: var(--pm-gold-700); }

  .avatar {
    display: grid;
    width: clamp(2.1rem, 6vw, 2.7rem);
    aspect-ratio: 1;
    overflow: hidden;
    border: 2px solid currentColor;
    border-radius: 999px;
    background: var(--pm-cyan-200);
    color: var(--pm-rank-silver);
  }

  .podium-card[data-rank="top-1"] .avatar { color: var(--pm-gold-700); }
  .podium-card[data-rank="top-3"] .avatar { color: var(--pm-rank-bronze); }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Mismo rol tipografico que los nombres del ranking (font UI legible). */
  .name {
    max-width: 100%;
    overflow: hidden;
    color: var(--pm-blue-900);
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pts {
    color: var(--color-muted);
    font-size: 0.62rem;
    font-weight: 850;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }

  .pts b {
    color: var(--pm-pink-600);
    font-family: var(--font-score, var(--font-display));
    font-size: 0.95rem;
  }

  .podium-card[data-rank="top-1"] .pts b { color: var(--pm-gold-700); }

  .gap {
    padding: 0.08rem 0.42rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--pm-cyan-200) 60%, white);
    color: var(--pm-blue-700);
    font-size: 0.55rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .podium-card[data-rank="top-1"] .gap {
    background: color-mix(in srgb, var(--pm-gold-700) 18%, white);
    color: var(--pm-gold-700);
  }

  @media (prefers-reduced-motion: no-preference) {
    .podium-card[data-rank="top-1"] {
      animation: podiumGlow 2.6s ease-in-out infinite;
    }

    @keyframes podiumGlow {
      0%, 100% { box-shadow: 0 12px 30px var(--pm-gold-glow); }
      50%      { box-shadow: 0 12px 38px var(--pm-gold-glow); }
    }
  }

  @media (max-width: 420px) {
    .podium-card {
      padding: 0.45rem 0.3rem 0.5rem;
    }
    .name { font-size: 0.68rem; }
  }
</style>
