---
// Matriz de predicciones para DEFINICION SIMULTANEA (Estado C/D). Cascaron oculto: el cuerpo
// lo pinta tabla.client.js por innerHTML cuando hay ventana simultanea, y se oculta el
// PlayerPredictionsPanel normal. Columnas: Jugador · Partido A · Partido B · Clasificados ·
// Pts en vivo (impacto de la ventana, desde buildPointLedger). La PRECISION agregada se omite
// en este modo (fallback aprobado por la comanda: no promediar % entre dos partidos).
// CSS is:global anclado a [data-simul-preds] porque las filas nacen en runtime.
---

<section class="simul-preds" data-simul-preds hidden aria-labelledby="simul-preds-title">
  <div class="sp-header">
    <h2 id="simul-preds-title">Predicciones de los jugadores</h2>
    <span class="sp-sub">Impacto de la ventana simultánea</span>
  </div>
  <div class="sp-labels" aria-hidden="true">
    <span>Jugador</span>
    <span data-sp-label-a>Partido A</span>
    <span data-sp-label-b>Partido B</span>
    <span>Clasificados</span>
    <span>Pts en vivo</span>
  </div>
  <div data-sp-list></div>
</section>

<style is:global>
  [data-simul-preds] {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--pm-sec-tabla-b) 32%, transparent);
    border-radius: var(--radius-lg, 16px);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--pm-sec-tabla-b) 18%, transparent), color-mix(in srgb, var(--pm-sec-tabla-a) 22%, transparent)),
      var(--pm-panel-soft);
  }
  [data-simul-preds][hidden] { display: none; }

  [data-simul-preds] .sp-header { padding: 0.45rem 0.7rem; border-bottom: 1px solid var(--color-line, rgba(7, 26, 53, 0.12)); }
  [data-simul-preds] .sp-header h2 { margin: 0; color: var(--color-text, #0b2545); font-family: var(--font-display); font-size: 0.86rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; }
  [data-simul-preds] .sp-sub { display: block; margin-top: 0.05rem; color: var(--pm-pink-600); font-size: 0.58rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; }

  /* 5 columnas: jugador | A | B | clasificados | pts vivo */
  [data-simul-preds] .sp-labels,
  [data-simul-preds] .sp-row {
    display: grid;
    grid-template-columns: minmax(7rem, 1.1fr) minmax(3.2rem, 0.55fr) minmax(3.2rem, 0.55fr) minmax(4.2rem, 0.7fr) minmax(4.6rem, 0.8fr);
    gap: 0.5rem;
    align-items: center;
  }
  [data-simul-preds] .sp-labels {
    padding: 0.32rem 0.6rem;
    border-bottom: 1px solid var(--color-line, rgba(7, 26, 53, 0.12));
    color: var(--color-muted, #4a5a72);
    font-family: var(--font-display);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1.05;
    text-transform: uppercase;
  }
  [data-simul-preds] .sp-row {
    padding: 0.28rem 0.6rem;
    border-bottom: 1px solid var(--color-line, rgba(7, 26, 53, 0.1));
    color: var(--color-text, #0b2545);
  }
  [data-simul-preds] .sp-row:last-child { border-bottom: 0; }
  [data-simul-preds] .sp-row.is-cross-highlight { background: color-mix(in srgb, var(--pm-cyan-200) 32%, transparent); box-shadow: inset 3px 0 0 var(--pm-pink-500); }

  [data-simul-preds] .sp-player { display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 0.35rem; align-items: center; min-width: 0; }
  [data-simul-preds] .sp-avatar { display: grid; width: 1.35rem; aspect-ratio: 1; overflow: hidden; border: 1px solid var(--color-line, rgba(7, 26, 53, 0.12)); border-radius: 999px; background: var(--pm-cyan-200); }
  [data-simul-preds] .sp-avatar img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  [data-simul-preds] .sp-name { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-family: var(--font-ui); font-size: 0.72rem; font-weight: 700; letter-spacing: -0.01em; }

  [data-simul-preds] .sp-chip { display: inline-grid; min-height: 1.4rem; place-items: center; border: 1px solid var(--color-line, rgba(7, 26, 53, 0.12)); border-radius: var(--radius-sm, 8px); background: rgba(255, 255, 255, 0.74); font-family: var(--font-score); font-size: 0.72rem; font-weight: 700; font-variant-numeric: tabular-nums; }
  [data-simul-preds] .sp-chip[data-empty="true"] { color: var(--color-muted, #4a5a72); opacity: 0.7; }

  [data-simul-preds] .sp-clasif { font-family: var(--font-ui); font-size: 0.66rem; font-weight: 800; letter-spacing: 0.02em; color: var(--pm-blue-800, #143a6b); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  [data-simul-preds] .sp-live { display: grid; gap: 0.02rem; min-width: 0; }
  [data-simul-preds] .sp-live-num { font-family: var(--font-score); font-size: 0.98rem; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1; color: var(--pm-blue-900); }
  [data-simul-preds] .sp-live[data-trend="up"] .sp-live-num { color: var(--pm-green-600, #16a34a); }
  [data-simul-preds] .sp-live[data-trend="down"] .sp-live-num { color: var(--pm-red-600, #c81e3a); }
  [data-simul-preds] .sp-live[data-trend="flat"] .sp-live-num { color: var(--color-muted, #4a5a72); }
  [data-simul-preds] .sp-live-break { font-family: var(--font-ui); font-size: 0.54rem; font-weight: 600; letter-spacing: 0.01em; line-height: 1.15; color: var(--color-muted, #4a5a72); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* Responsive: oculta Clasificados primero, luego compacta a 2 columnas. */
  @media (max-width: 1180px) {
    [data-simul-preds] .sp-labels span:nth-child(4),
    [data-simul-preds] .sp-row .sp-clasif { display: none; }
    [data-simul-preds] .sp-labels,
    [data-simul-preds] .sp-row { grid-template-columns: minmax(6.5rem, 1.1fr) minmax(3rem, 0.5fr) minmax(3rem, 0.5fr) minmax(4.4rem, 0.8fr); }
  }
  @media (max-width: 560px) {
    [data-simul-preds] .sp-labels { display: none; }
    [data-simul-preds] .sp-row { grid-template-columns: 1fr 1fr 1fr; gap: 0.35rem 0.5rem; }
    [data-simul-preds] .sp-player { grid-column: 1 / -1; }
  }
</style>
