---
import AccuracyBar from "./AccuracyBar.astro";
import type { MatchAccuracyRow } from "../../lib/tabla/types";

interface Props {
  row: MatchAccuracyRow;
}

const { row } = Astro.props;
---

<article class="prediction-row" data-player-prediction-row data-player-id={row.playerId} data-accuracy-level={row.level}>
  <div class="player-cell">
    <span class="player-avatar" aria-hidden="true">
      <img
        src={row.avatarThumb ?? row.avatar}
        alt=""
        width="120"
        height="120"
        loading="lazy"
        decoding="async"
      />
    </span>
    <strong data-prediction-name>{row.name}</strong>
  </div>
  <span class="score-chip" data-prediction-score>{row.prediction}</span>
  <span class="difference-label" data-prediction-diff>{row.differenceLabel}</span>
  <div class="accuracy-cell">
    <span data-prediction-percent>{row.accuracyPercent}%</span>
    <AccuracyBar percent={row.accuracyPercent} level={row.level} />
  </div>
</article>

<style>
  .prediction-row {
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) minmax(4.5rem, 0.45fr) minmax(4.5rem, 0.5fr) minmax(7rem, 0.75fr);
    gap: 0.4rem;
    align-items: center;
    padding: 0.28rem 0.5rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-text);
  }

  .prediction-row:last-child {
    border-bottom: 0;
  }

  .player-cell {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.35rem;
    align-items: center;
    min-width: 0;
  }

  .player-avatar {
    display: grid;
    width: 1.35rem;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--pm-cyan-200);
  }

  .player-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  strong,
  span {
    font-size: 0.72rem;
    font-weight: 850;
  }

  strong {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .score-chip {
    display: inline-grid;
    min-height: 1.5rem;
    place-items: center;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.74);
    font-family: var(--font-display);
    font-weight: 950;
  }

  .difference-label {
    color: var(--color-text);
    font-size: 0.68rem;
    font-weight: 950;
  }

  .accuracy-cell {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: 0.45rem;
    align-items: center;
  }

  @media (max-width: 560px) {
    .prediction-row {
      grid-template-columns: 1fr 1fr;
    }

    .player-cell {
      grid-column: 1 / -1;
    }
  }
</style>
