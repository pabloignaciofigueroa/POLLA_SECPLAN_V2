---
import AccuracyBar from "./AccuracyBar.astro";
import type { MatchAccuracyRow } from "../../lib/tabla/types";

interface Props {
  row: MatchAccuracyRow;
}

const { row } = Astro.props;
---

<article class="prediction-row" data-player-prediction-row data-player-id={row.playerId} data-accuracy-level={row.level} data-hit-type={row.hitType}>
  <div class="player-cell">
    <span class="player-avatar" aria-hidden="true">
      <img
        src={row.avatarThumb ?? row.avatar}
        alt=""
        width="120"
        height="120"
        loading="lazy"
        decoding="async"
      />
    </span>
    <strong data-prediction-name>{row.name}</strong>
  </div>
  <span class="score-chip" data-prediction-score>{row.prediction}</span>
  <div class="points-cell">
    <strong class="points-value" data-prediction-points>{row.points > 0 ? `+${row.points}` : "0"}</strong>
    <span class="points-type" data-prediction-type>{row.differenceLabel}</span>
    <span class="wolf-badge" data-wolf-badge aria-hidden="true">LONE WOLF</span>
  </div>
  <div class="accuracy-cell">
    <span class="acc-top">
      <span class="acc-percent" data-prediction-percent>{row.accuracyPercent}%</span>
      <AccuracyBar percent={row.accuracyPercent} level={row.level} />
    </span>
    <small class="acc-label" data-prediction-acc-label title={row.accuracyLabel}>{row.accuracyLabel}</small>
  </div>
</article>

<style>
  .prediction-row {
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) minmax(4.5rem, 0.45fr) minmax(4.5rem, 0.5fr) minmax(7rem, 0.75fr);
    gap: 0.4rem;
    align-items: center;
    padding: 0.28rem 0.5rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-text);
  }

  .prediction-row:last-child {
    border-bottom: 0;
  }

  /* Cruce de resaltado con la fila de la tabla (mismo jugador). */
  .prediction-row.is-cross-highlight {
    background: color-mix(in srgb, var(--pm-cyan-200) 32%, transparent);
    box-shadow: inset 3px 0 0 var(--pm-pink-500);
  }

  /* Badge LONE WOLF — acierto exacto unico. Nunca "BONUS". Se controla por
     [data-hit-type="lone_wolf"], que el cliente actualiza en vivo. */
  .wolf-badge {
    display: none;
    width: max-content;
    margin-top: 0.1rem;
    padding: 0.04rem 0.34rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--pm-gold-700, #b8860b) 16%, white);
    color: var(--pm-gold-700, #b8860b);
    font-family: var(--font-display);
    font-size: 0.5rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .prediction-row[data-hit-type="lone_wolf"] .wolf-badge {
    display: inline-grid;
  }

  .player-cell {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.35rem;
    align-items: center;
    min-width: 0;
  }

  .player-avatar {
    display: grid;
    width: 1.35rem;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--pm-cyan-200);
  }

  .player-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  strong,
  span {
    font-size: 0.72rem;
    font-weight: 850;
  }

  strong {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .score-chip {
    display: inline-grid;
    min-height: 1.5rem;
    place-items: center;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.74);
    font-family: var(--font-display);
    font-weight: 950;
  }

  /* PUNTOS (oficiales) — separados de la precision visual. */
  .points-cell {
    display: grid;
    gap: 0.05rem;
    min-width: 0;
  }

  .points-value {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 950;
    color: var(--pm-blue-900);
    line-height: 1;
  }

  .points-type {
    font-size: 0.56rem;
    font-weight: 850;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Color del puntaje segun tipo de acierto. */
  .prediction-row[data-hit-type="lone_wolf"] .points-value { color: var(--pm-gold-700, #b8860b); }
  .prediction-row[data-hit-type="exact"] .points-value { color: var(--pm-mint-600, #16a34a); }
  .prediction-row[data-hit-type="tendency"] .points-value { color: var(--pm-blue-700); }
  .prediction-row[data-hit-type="none"] .points-value,
  .prediction-row[data-hit-type="no_info"] .points-value { color: var(--color-muted); }

  /* PRECISION % (solo visual). */
  .accuracy-cell {
    display: grid;
    gap: 0.18rem;
    min-width: 0;
  }

  .acc-top {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: 0.45rem;
    align-items: center;
  }

  .acc-percent {
    font-weight: 950;
  }

  .acc-label {
    font-size: 0.52rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .prediction-row {
      grid-template-columns: 1fr 1fr;
    }

    .player-cell {
      grid-column: 1 / -1;
    }
  }
</style>
