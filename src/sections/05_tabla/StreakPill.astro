---
interface Props {
  value: string;
}

const { value } = Astro.props;
---

<span class="streak-pill" data-streak={value}>{value}</span>

<style>
  .streak-pill {
    display: inline-grid;
    width: 1.5rem;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid transparent;
    border-radius: 999px;
    background: var(--pm-panel-soft);
    color: var(--pm-text-soft);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 950;
  }

  /* G (Ganado), E (Empate), P (Perdido) */
  .streak-pill[data-streak="G"] {
    background: var(--pm-green-500);
    border-color: var(--pm-green-700);
    color: var(--pm-white);
  }

  .streak-pill[data-streak="E"] {
    background: var(--pm-cyan-500);
    border-color: var(--pm-cyan-600);
    color: var(--pm-blue-900);
  }

  .streak-pill[data-streak="P"] {
    background: var(--pm-red-500);
    border-color: var(--pm-red-600);
    color: var(--pm-white);
  }
</style>
