---
const items = [
  { level: "excellent", label: "EXCELENTE", description: "Resultado exacto" },
  { level: "close", label: "CERCA", description: "A 1 gol de diferencia" },
  { level: "regular", label: "REGULAR", description: "A 2 goles de diferencia" },
  { level: "far", label: "LEJOS", description: "Más de 2 goles" },
  { level: "very_far", label: "MUY LEJOS", description: "Sin posibilidades" },
];
---

<section class="accuracy-legend" aria-labelledby="legend-title">
  <h2 id="legend-title">Nivel de acierto en el partido actual</h2>
  <div class="legend-track">
    {items.map((item) => (
      <article data-accuracy-level={item.level}>
        <span aria-hidden="true"></span>
        <div>
          <strong>{item.label}</strong>
          <p>{item.description}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .accuracy-legend {
    padding: 1rem;
    border: 1px solid var(--pm-blue-300);
    border-radius: var(--pm-radius-lg);
    background: var(--pm-white);
    box-shadow: var(--pm-shadow-card);
  }

  h2 {
    margin: 0 0 0.85rem;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .legend-track {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.75rem;
  }

  article {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.55rem;
    align-items: start;
    min-width: 0;
  }

  article > span {
    display: block;
    width: 1.45rem;
    aspect-ratio: 1;
    border: 1px solid transparent;
    border-radius: var(--pm-radius-sm);
  }

  article[data-accuracy-level="excellent"] > span {
    background: var(--pm-lime-500);
    border-color: var(--pm-green-600);
  }

  article[data-accuracy-level="close"] > span {
    background: var(--pm-cyan-500);
    border-color: var(--pm-cyan-600);
  }

  article[data-accuracy-level="regular"] > span {
    background: var(--pm-orange-500);
    border-color: var(--pm-orange-600);
  }

  article[data-accuracy-level="far"] > span {
    background: var(--pm-red-500);
    border-color: var(--pm-red-600);
  }

  article[data-accuracy-level="very_far"] > span {
    background: var(--pm-purple-500);
    border-color: var(--pm-purple-600);
  }

  strong,
  p {
    margin: 0;
  }

  strong {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 950;
  }

  p {
    margin-top: 0.18rem;
    color: var(--pm-text-soft);
    font-size: 0.66rem;
    line-height: 1.25;
  }

  @media (max-width: 900px) {
    .legend-track {
      display: flex;
      overflow-x: auto;
      padding-bottom: 0.2rem;
    }

    article {
      flex: 0 0 12rem;
    }
  }
</style>
