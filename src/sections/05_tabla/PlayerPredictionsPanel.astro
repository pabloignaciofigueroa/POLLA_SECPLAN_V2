---
import PlayerPredictionRow from "./PlayerPredictionRow.astro";
import type { MatchAccuracyRow } from "../../lib/tabla/types";

interface Props {
  rows: MatchAccuracyRow[];
}

const { rows } = Astro.props;
---

<section class="predictions-panel" aria-labelledby="predictions-title">
  <div class="panel-header">
    <h2 id="predictions-title">Predicciones de los jugadores</h2>
  </div>
  <div class="labels" aria-hidden="true">
    <span>Jugador</span>
    <span>Su predicción</span>
    <span>Puntos</span>
    <span>Precisión</span>
  </div>
  <div data-player-predictions-list>
    {rows.map((row) => <PlayerPredictionRow row={row} />)}
  </div>
</section>

<style>
  .predictions-panel {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--pm-sec-tabla-b) 32%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-sec-tabla-b) 18%, transparent),
        color-mix(in srgb, var(--pm-sec-tabla-a) 22%, transparent)
      ),
      var(--pm-panel-soft);
  }

  .panel-header {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-line);
  }

  h2 {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.86rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .labels {
    display: grid;
    grid-template-columns: minmax(8rem, 1fr) minmax(4.5rem, 0.45fr) minmax(4.5rem, 0.5fr) minmax(7rem, 0.75fr);
    gap: 0.55rem;
    padding: 0.35rem 0.55rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-muted);
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 560px) {
    .labels {
      display: none;
    }
  }
</style>
