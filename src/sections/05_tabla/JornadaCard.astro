---
import { INLINE } from "../../lib/ui-assets/uiAssets";

interface Props {
  current: number;
  total: number;
}

const { current, total } = Astro.props;
---

<article class="matchday-card">
  <span aria-hidden="true">
    <img src={INLINE.calendar.src} alt="" width={INLINE.calendar.width} height={INLINE.calendar.height} loading="lazy" decoding="async" />
  </span>
  <div>
    <p>Jornada</p>
    <strong><span data-matchday-current>{current}</span> / <span data-matchday-total>{total}</span></strong>
  </div>
</article>

<style>
  .matchday-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.7rem;
    align-items: center;
    min-height: 4.6rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: rgba(247, 247, 242, 0.92);
  }

  .matchday-card > span {
    display: grid;
    width: 2.05rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.7);
  }

  .matchday-card > span img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  p,
  strong {
    margin: 0;
  }

  p {
    color: var(--color-muted);
    font-size: 0.62rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  strong {
    display: block;
    margin-top: 0.24rem;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 950;
  }
</style>
