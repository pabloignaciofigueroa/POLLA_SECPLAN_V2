---
import RankingRow from "./RankingRow.astro";
import type { RankingRow as RankingRowType } from "../../lib/tabla/types";

interface Props {
  rows: RankingRowType[];
}

const { rows } = Astro.props;
---

<section class="ranking-panel" aria-labelledby="ranking-title">
  <div class="panel-header">
    <h2 id="ranking-title">Ranking de jugadores</h2>
    <span>{rows.length} jugadores</span>
  </div>

  <div class="table-scroll">
    <table data-ranking-table>
      <thead>
        <tr>
          <th>Pos</th>
          <th>Jugador</th>
          <th>Pts</th>
          <th data-column="played">PJ</th>
          <th data-column="exact">G</th>
          <th data-column="tendency">E</th>
          <th data-column="misses">P</th>
          <th data-column="difference">DG</th>
          <th>Rend.</th>
          <th>Racha</th>
        </tr>
      </thead>
      <tbody data-ranking-body>
        {rows.map((row) => <RankingRow row={row} />)}
      </tbody>
    </table>
  </div>
</section>

<style>
  .ranking-panel {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--pm-sec-tabla-b) 36%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--pm-sec-tabla-a) 22%, transparent),
        color-mix(in srgb, var(--pm-sec-tabla-b) 30%, transparent)
      ),
      var(--pm-panel-soft);
    box-shadow: 0 18px 45px rgba(7, 23, 53, 0.08);
  }

  @media (max-width: 640px) {
    .ranking-panel {
      background:
        linear-gradient(
          135deg,
          color-mix(in srgb, var(--pm-sec-tabla-a) 12%, transparent),
          color-mix(in srgb, var(--pm-sec-tabla-b) 18%, transparent)
        ),
        var(--pm-panel-soft);
    }
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid color-mix(in srgb, var(--pm-sec-tabla-b) 30%, transparent);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--pm-sec-tabla-a) 22%, transparent),
      color-mix(in srgb, var(--pm-sec-tabla-b) 18%, transparent)
    );
  }

  h2,
  .panel-header span {
    margin: 0;
  }

  h2 {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .panel-header span {
    color: var(--color-muted);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .table-scroll {
    overflow-x: auto;
  }

  table {
    width: 100%;
    min-width: 34rem;
    border-collapse: collapse;
  }

  th {
    padding: 0.38rem 0.52rem;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.05;
    text-align: center;
    text-transform: uppercase;
  }

  th:nth-child(2) {
    text-align: left;
  }

  th[data-column="played"],
  th[data-column="exact"],
  th[data-column="tendency"],
  th[data-column="misses"],
  th[data-column="difference"] {
    display: none;
  }

  /* Mobile: lista compacta tipo marcador deportivo. Un solo header arriba
     (este thead) y filas de una linea; sin labels repetidos por jugador. */
  @media (max-width: 720px) {
    .table-scroll {
      overflow: visible;
      padding: 0.6rem;
    }

    table,
    thead,
    tbody {
      display: block;
      min-width: 0;
      width: 100%;
    }

    thead tr {
      display: grid;
      grid-template-columns: 38px minmax(0, 1fr) 48px 52px 44px;
      gap: 8px;
      align-items: center;
      padding: 0 10px 4px;
    }

    th {
      padding: 0;
      border-bottom: 0;
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      color: var(--color-muted);
    }

    tbody {
      display: grid;
      gap: 6px;
    }
  }
</style>

<!-- F7 Nivel 2: la fila-detalle se crea en runtime (innerHTML) -> CSS global anclado a
     [data-rank-detail], que no recibe el scope de Astro. -->
<style is:global>
  tr[data-rank-detail] > td {
    padding: 0;
    background: color-mix(in srgb, var(--pm-sec-tabla-a) 8%, var(--pm-white));
    border-bottom: 1px solid var(--pm-border-soft);
  }

  tr[data-rank-detail] .rank-detail-inner {
    padding: 0.5rem 0.75rem 0.65rem;
    animation: rankDetailReveal 220ms ease both;
  }

  tr[data-rank-detail] .rd-table {
    width: 100%;
    border-collapse: collapse;
  }

  tr[data-rank-detail] .rd-table td {
    padding: 0.22rem 0.3rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-align: left;
    color: var(--pm-blue-900);
    border-top: 1px solid color-mix(in srgb, var(--pm-blue-900) 8%, transparent);
  }

  tr[data-rank-detail] .rd-base td {
    border-top: 0;
    color: var(--color-muted, #5b6b86);
  }

  tr[data-rank-detail] .rd-var {
    font-family: var(--font-ui);
    font-weight: 800;
  }

  tr[data-rank-detail] .rd-pred,
  tr[data-rank-detail] .rd-now,
  tr[data-rank-detail] .rd-pts {
    font-family: var(--font-score);
    font-variant-numeric: tabular-nums;
    text-align: center;
  }
  tr[data-rank-detail] .rd-pts { text-align: right; font-weight: 800; }

  tr[data-rank-detail] .rd-type {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  tr[data-rank-detail] .rd-type[data-token="lone_wolf"] { color: var(--pm-purple-600, #7c3aed); }
  tr[data-rank-detail] .rd-type[data-token="exact_shared"] { color: var(--pm-blue-600, #2563eb); }
  tr[data-rank-detail] .rd-type[data-token="tendency"] { color: var(--pm-green-600, #16a34a); }
  tr[data-rank-detail] .rd-type[data-token="group_first"] { color: var(--pm-gold-700, #b8860b); }
  tr[data-rank-detail] .rd-type[data-token="group_second"] { color: var(--pm-blue-600, #2563eb); }
  tr[data-rank-detail] .rd-type[data-token="none"],
  tr[data-rank-detail] .rd-type[data-token="group_miss"] { color: var(--color-muted, #5b6b86); }

  tr[data-rank-detail] .rd-badge {
    display: inline-block;
    min-width: 1.2rem;
    padding: 0.02rem 0.28rem;
    border-radius: var(--pm-radius-pill);
    font-family: var(--font-display);
    font-size: 0.56rem;
    font-weight: 900;
    text-align: center;
    color: var(--pm-white);
  }
  tr[data-rank-detail] .rd-badge[data-pos="1"] { background: var(--pm-gold-700, #b8860b); }
  tr[data-rank-detail] .rd-badge[data-pos="2"] { background: var(--pm-blue-600, #2563eb); }

  tr[data-rank-detail] .rd-foot {
    margin: 0.4rem 0 0;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.66rem;
    font-weight: 700;
    color: var(--color-muted, #5b6b86);
  }
  tr[data-rank-detail] .rd-foot strong {
    font-family: var(--font-score);
    font-size: 0.92rem;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    color: var(--pm-blue-900);
  }

  tr[data-rank-detail] .rd-why {
    margin: 0.2rem 0 0;
    font-family: var(--font-ui);
    font-size: 0.66rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--pm-blue-900);
  }

  @keyframes rankDetailReveal {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    tr[data-rank-detail] .rank-detail-inner { animation: none; }
  }
</style>
