---
import MovementIndicator from "./MovementIndicator.astro";
import StreakDot from "./StreakDot.astro";
import type { RankingRow as RankingRowType } from "../../lib/tabla/types";

interface Props {
  row: RankingRowType;
}

const { row } = Astro.props;
const rankClass = row.points > 0 && row.position <= 3 ? `top-${row.position}` : "other";
---

<tr
  data-ranking-row
  data-player-id={row.playerId}
  data-rank={rankClass}
  data-position={row.position}
  data-animate="fade-in"
  role="button"
  tabindex="0"
  aria-expanded="false"
  aria-label={`Ver desglose de ${row.name}`}
  style={`--i:${row.position}`}
>
  <td data-cell="position">
    <span class="position-badge" data-rank-position>{row.position}</span>
  </td>
  <td data-cell="player">
    <span class="player-avatar" aria-hidden="true">
      <img
        src={row.avatarThumb ?? row.avatar}
        alt=""
        width="160"
        height="160"
        loading="lazy"
        decoding="async"
      />
    </span>
    <strong data-rank-name>{row.name}</strong>
    <MovementIndicator movement={row.movement} />
  </td>
  <td data-cell="points">
    <span class="points-stack">
      <span class="points-main">
        <strong data-rank-projected data-rank-points>{row.points}</strong>
        <span class="delta-pill" data-rank-delta data-trend="flat" hidden
          ><span data-rank-delta-num>+0</span><span class="delta-tag"> EN VIVO</span></span>
      </span>
      <small class="points-sub" data-rank-official-wrap hidden><span data-rank-official>{row.points}</span> oficiales</small>
    </span>
  </td>
  <td data-cell="played" data-rank-played>{row.played}</td>
  <td data-cell="exact" data-rank-exact>{row.exactHits}</td>
  <td data-cell="tendency" data-rank-tendency>{row.tendencyHits}</td>
  <td data-cell="misses" data-rank-misses>{row.misses}</td>
  <td data-cell="difference" data-rank-difference>{row.goalDifference > 0 ? `+${row.goalDifference}` : row.goalDifference}</td>
  <td data-cell="performance"><span data-rank-performance>{row.performance}%</span></td>
  <td data-cell="streak">
    <span class="streak-list" data-rank-streak>
      {row.streak.map((item) => <StreakDot value={item} />)}
    </span>
  </td>
</tr>

<style>
  tr {
    border-bottom: 1px solid var(--pm-border-soft);
    background: var(--pm-white);
    cursor: pointer;
    transition: background var(--pm-transition-fast), box-shadow var(--pm-transition-fast);
  }

  tr:focus-visible {
    outline: none;
    box-shadow: inset 4px 0 0 var(--pm-pink-500), var(--pm-focus-ring-yellow);
  }

  tr:last-child {
    border-bottom: 0;
  }

  tr:hover {
    background: var(--pm-panel-soft);
    box-shadow: inset 4px 0 0 var(--pm-pink-500);
  }

  /* Cruce de resaltado con el panel de predicciones (mismo jugador). */
  tr.is-cross-highlight {
    background: color-mix(in srgb, var(--pm-cyan-200) 30%, transparent);
    box-shadow: inset 4px 0 0 var(--pm-pink-500);
  }

  /* PODIUM: top 1/2/3 con oro/plata/bronce */
  tr[data-rank="top-1"] {
    background: linear-gradient(90deg, rgba(255, 210, 31, 0.18), transparent 60%);
    box-shadow: inset 4px 0 0 var(--pm-rank-gold);
  }

  tr[data-rank="top-2"] {
    background: linear-gradient(90deg, rgba(199, 210, 229, 0.32), transparent 60%);
    box-shadow: inset 4px 0 0 var(--pm-rank-silver);
  }

  tr[data-rank="top-3"] {
    background: linear-gradient(90deg, rgba(201, 130, 59, 0.18), transparent 60%);
    box-shadow: inset 4px 0 0 var(--pm-rank-bronze);
  }

  td {
    padding: 0.36rem 0.5rem;
    color: var(--pm-blue-900);
    font-size: 0.8rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    text-align: center;
    vertical-align: middle;
  }

  td[data-cell="player"] {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.42rem;
    align-items: center;
    min-width: 10rem;
    text-align: left;
  }

  .position-badge {
    display: inline-grid;
    min-width: 2rem;
    min-height: 1.65rem;
    place-items: center;
    border: 1px solid var(--pm-border-soft);
    border-radius: var(--pm-radius-sm);
    background: var(--pm-white);
    color: var(--pm-blue-900);
    font-family: var(--font-score);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  tr[data-rank="top-1"] .position-badge {
    background: var(--pm-rank-gold-bg);
    border-color: var(--pm-gold-700);
    color: var(--pm-blue-900);
    box-shadow: 0 0 12px var(--pm-gold-glow);
  }

  tr[data-rank="top-2"] .position-badge {
    background: var(--pm-rank-silver-bg);
    border-color: var(--pm-rank-silver);
    color: var(--pm-blue-900);
  }

  tr[data-rank="top-3"] .position-badge {
    background: var(--pm-rank-bronze-bg);
    border-color: var(--pm-rank-bronze);
    color: var(--pm-white);
  }

  .player-avatar {
    display: grid;
    width: 1.65rem;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--pm-cyan-200);
    border-radius: 999px;
    background: var(--pm-cyan-200);
  }

  .player-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Nombre de jugador = dato principal: font UI legible, no label arcade. */
  td[data-cell="player"] strong {
    font-family: var(--font-ui);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--pm-blue-900);
  }

  /* Numeros = scoreboard. */
  td[data-cell="points"] strong {
    color: var(--pm-pink-600);
    font-family: var(--font-score);
    font-size: 1rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  /* F7: proyectado (protagonista) + delta + oficial (subtitulo). En modo normal el
     delta y el subtitulo van ocultos, asi la celda se ve igual que hoy. */
  .points-stack {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.12rem;
    line-height: 1;
  }

  .points-main {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .delta-pill {
    font-family: var(--font-score);
    font-size: 0.62rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    padding: 0.05rem 0.32rem;
    border-radius: var(--pm-radius-pill);
    line-height: 1.3;
    white-space: nowrap;
  }
  .delta-pill[hidden] { display: none; }
  .delta-pill[data-trend="up"] { color: var(--pm-white); background: var(--pm-green-600); }
  .delta-pill[data-trend="down"] { color: var(--pm-white); background: var(--pm-red-500); }
  .delta-pill[data-trend="flat"] { color: var(--pm-blue-900); background: var(--pm-border-soft); }

  .points-sub {
    font-family: var(--font-ui);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--color-muted, #5b6b86);
    white-space: nowrap;
  }
  .points-sub[hidden] { display: none; }
  .points-sub span {
    font-family: var(--font-score);
    font-variant-numeric: tabular-nums;
  }

  td[data-cell="performance"] span {
    font-family: var(--font-score);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0;
    line-height: 1;
  }

  td[data-cell="played"],
  td[data-cell="exact"],
  td[data-cell="tendency"],
  td[data-cell="misses"],
  td[data-cell="difference"] {
    display: none;
  }

  tr[data-rank="top-1"] td[data-cell="points"] strong {
    color: var(--pm-gold-700);
  }

  .streak-list {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
  }

  /* Shimmer suave del lider (acento dorado), respetando reduced-motion. */
  @media (prefers-reduced-motion: no-preference) {
    tr[data-rank="top-1"] .position-badge {
      animation: leaderGlow 2.6s ease-in-out infinite;
    }

    @keyframes leaderGlow {
      0%, 100% { box-shadow: 0 0 12px var(--pm-gold-glow); }
      50%      { box-shadow: 0 0 22px var(--pm-gold-glow); }
    }
  }

  /* Mobile: fila compacta de una linea (pos | jugador | pts | rend | racha).
     Sin labels internos por fila: el header compacto vive una sola vez en el
     thead de RankingTable. Altura objetivo 56-72px por jugador. */
  @media (max-width: 720px) {
    tr {
      display: grid;
      grid-template-columns: 38px minmax(0, 1fr) 48px 52px 44px;
      gap: 8px;
      align-items: center;
      min-height: 3.5rem;
      padding: 8px 10px;
      border: 1px solid var(--pm-border-soft);
      border-radius: 14px;
    }

    td {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      font-size: 0.82rem;
    }

    td[data-cell="player"] {
      display: flex;
      justify-content: flex-start;
      gap: 8px;
      min-width: 0;
    }

    .position-badge {
      min-width: 1.9rem;
      min-height: 1.65rem;
      border-radius: 9px;
      font-size: 0.9rem;
    }

    .player-avatar {
      width: 1.75rem;
      flex: 0 0 auto;
    }

    td[data-cell="player"] strong {
      flex: 1 1 auto;
      min-width: 0;
      overflow: hidden;
      font-size: 0.88rem;
      line-height: 1.2;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    td[data-cell="points"] strong,
    td[data-cell="performance"] span {
      font-size: 0.95rem;
      line-height: 1;
      text-align: center;
    }

    /* F7 mobile: en la columna de puntos solo entra proyectado + numero de delta;
       "EN VIVO" y el subtitulo "oficiales" se ocultan para no romper la grilla. */
    .points-main {
      flex-direction: column;
      gap: 0.08rem;
    }
    .delta-tag,
    .points-sub {
      display: none;
    }
    .delta-pill {
      font-size: 0.54rem;
      padding: 0.02rem 0.24rem;
    }

    .streak-list {
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.14rem;
    }
  }
</style>
