---
// Contenedor del grafico de la Carrera de Puntaje. El SVG (lineas + nodos) y la
// columna "posicion actual" los inyecta score-race.client.js en runtime; por eso
// el estilo de esos nodos vive en el <style is:global> de StatsGraphTab.astro.
// El grafico siempre tiene datos (baseline commiteado + overlay en vivo): no hay
// estado vacio.
---

<div class="race-graph" data-score-race-graph>
  <div class="race-canvas" data-score-race-canvas></div>
</div>
