---
import LockOrbVisual from "./LockOrbVisual.astro";
import StatsProgressCard from "./StatsProgressCard.astro";
import type { ProgressSnapshot } from "./estadisticas.logic";

interface Props {
  snapshot: ProgressSnapshot;
}

const { snapshot } = Astro.props;
---

<section class="stats-hero" aria-labelledby="estadisticas-title">
  <div class="geo-decorations" aria-hidden="true">
    <span class="geo geo-diamond geo-yellow" style="top:12%;left:38%"></span>
    <span class="geo geo-square geo-cyan" style="top:18%;left:55%"></span>
    <span class="geo geo-diamond geo-purple" style="top:72%;left:42%"></span>
    <span class="geo geo-square geo-yellow" style="top:65%;left:62%"></span>
    <span class="geo geo-diamond geo-blue" style="top:30%;left:68%"></span>
    <span class="geo geo-square geo-cyan" style="top:82%;left:52%"></span>
  </div>
  <div class="copy" data-animate="fade-up">
    <p class="eyebrow">
      <span class="lock-icon" aria-hidden="true">🔒</span>
      DATA CENTER BLOQUEADO
    </p>
    <h1 id="estadisticas-title">
      <span class="title-main">Estadísticas</span>
    </h1>
    <p class="subtitle">
      Completa tus <strong>72 predicciones</strong> para desbloquear la inteligencia de la comunidad.
    </p>
  </div>

  <div class="orb-wrap">
    <LockOrbVisual />
  </div>

  <div class="progress-wrap" data-animate="fade-up" style="--i:1">
    <StatsProgressCard snapshot={snapshot} />
  </div>
</section>

<style>
  .stats-hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(210px, 0.74fr) minmax(260px, 0.82fr);
    gap: clamp(0.75rem, 1.5vw, 1.3rem);
    align-items: center;
    padding: clamp(0.9rem, 1.7vw, 1.35rem) clamp(1rem, 2vw, 1.5rem);
    border: 1px solid color-mix(in srgb, var(--pm-cyan-500) 35%, transparent);
    border-radius: 1.35rem;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 48%, color-mix(in srgb, var(--pm-cyan-500) 28%, transparent), transparent 36%),
      linear-gradient(112deg, rgba(255, 255, 255, 0.96), rgba(247, 252, 255, 0.88) 48%, rgba(255, 255, 255, 0.94));
    box-shadow: 0 22px 52px rgba(7, 23, 53, 0.14), 0 0 0 1px rgba(24, 221, 242, 0.1);
  }

  .geo-decorations {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .geo {
    position: absolute;
    border-radius: 2px;
    opacity: 0.55;
  }

  .geo-diamond { width: 0.55rem; height: 0.55rem; transform: rotate(45deg); }
  .geo-square  { width: 0.45rem; height: 0.45rem; }

  .geo-yellow { background: #f5b800; }
  .geo-blue   { background: var(--pm-blue-400, #3b82f6); }
  .geo-cyan   { background: var(--pm-cyan-500, #18ddf2); }
  .geo-purple { background: var(--pm-purple-400, #a855f7); }

  .copy {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    margin: 0;
    padding: 0.34rem 0.7rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--pm-purple-500), var(--pm-blue-500));
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: 0 0 14px rgba(124, 53, 255, 0.32);
  }

  .lock-icon {
    font-size: 0.85rem;
  }

  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 6.5vw, 5.65rem);
    font-weight: 950;
    letter-spacing: 0;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .title-main {
    color: var(--pm-blue-900);
    text-shadow: 0 2px 0 rgba(255, 255, 255, 0.5);
  }

  .subtitle {
    margin: 0;
    color: var(--pm-blue-900);
    font-size: clamp(0.92rem, 1.3vw, 1.05rem);
    font-weight: 600;
    max-width: 38ch;
  }

  .subtitle strong {
    color: var(--pm-purple-600);
    font-weight: 900;
  }

  .orb-wrap {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    min-width: 0;
  }

  .progress-wrap {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  @media (max-width: 1080px) {
    .stats-hero {
      grid-template-columns: minmax(0, 1fr) minmax(260px, 0.8fr);
    }

    .orb-wrap {
      grid-column: 1 / -1;
      grid-row: 2;
      order: 3;
    }
  }

  @media (max-width: 720px) {
    .stats-hero {
      grid-template-columns: 1fr;
      border-radius: 1rem;
    }

    .orb-wrap {
      grid-column: auto;
      grid-row: auto;
    }
  }
</style>
