---
import UnlockBenefitCard from "./UnlockBenefitCard.astro";

const benefits = [
  {
    icon: "VS",
    title: "Comparar",
    description: "Compara tu rendimiento contra la comunidad y tus amigos.",
    tone: "blue" as const,
  },
  {
    icon: "01",
    title: "Ranking",
    description: "Descubre tu posicion en los rankings globales y entre tus amigos.",
    tone: "purple" as const,
  },
  {
    icon: "UP",
    title: "Tendencias",
    description: "Explora tendencias, aciertos y evolucion de la comunidad a lo largo del torneo.",
    tone: "cyan" as const,
  },
];
---

<section class="benefits-panel" aria-label="Beneficios que se desbloquean" data-animate="fade-up" style="--i:1">
  <header class="panel-head">
    <h2>
      <svg class="h2-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
      </svg>
      DESBLOQUEA ESTADISTICAS PODEROSAS
    </h2>
  </header>

  <div class="benefits-grid">
    {benefits.map((benefit) => (
      <UnlockBenefitCard
        icon={benefit.icon}
        title={benefit.title}
        description={benefit.description}
        tone={benefit.tone}
      />
    ))}
  </div>
</section>

<style>
  .benefits-panel {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 0.82rem 1rem;
    border: 1px solid rgba(7, 23, 53, 0.1);
    border-radius: 0.95rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 16px 34px rgba(7, 23, 53, 0.1);
  }

  .panel-head h2 {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0;
    color: var(--pm-blue-500);
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.25vw, 1.05rem);
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .h2-icon {
    flex-shrink: 0;
    width: 1.05rem;
    height: 1.05rem;
    color: var(--pm-yellow-500, #f5b800);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
  }

  @media (max-width: 1080px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
