---
// Panel "LO QUE PASO EN LA OFICINA". El cuerpo lo escribe score-race.client.js
// segun el partido o jugador seleccionado (relato derivado de datos reales).
---

<aside class="race-narrative" data-score-race-narrative-panel>
  <header>
    <span class="race-narrative-kicker">Lo que pasó en la oficina</span>
    <strong data-score-race-narrative-title>La carrera, partido a partido</strong>
  </header>
  <div class="race-narrative-body" data-score-race-narrative>
    <p class="race-muted">Toca un partido en la línea de tiempo o un jugador para ver el movimiento.</p>
  </div>
</aside>
