---
// Panel GRÁFICO ("Carrera de Puntaje"): primera vista de /estadisticas.
// Shell SSR; score-race.client.js (montado por estadisticas.client.js al
// desbloquear) pinta el SVG, la leyenda de jugadores, la narrativa, la línea de
// tiempo y el pop-up. Estilo en <style is:global> anclado a [data-score-race]
// porque esos nodos nacen en runtime y no reciben el scope de Astro.
import ScoreRaceGraph from "./ScoreRaceGraph.astro";
import ScoreRaceLegend from "./ScoreRaceLegend.astro";
import ScoreRaceNarrative from "./ScoreRaceNarrative.astro";
import ScoreRacePopup from "./ScoreRacePopup.astro";
---

<div class="score-race" data-score-race>
  <header class="race-head">
    <p class="race-kicker">Gráfico · Ranking vivo</p>
    <h2 class="race-title">Carrera de Puntaje</h2>
    <p class="race-sub">Cada partido mueve la tabla. Mira quién subió, quién se secó y quién viene prendido.</p>
  </header>

  <div class="race-layout">
    <div class="race-main">
      <ScoreRaceGraph />
      <div class="race-timeline-wrap">
        <span class="race-timeline-label">Partidos</span>
        <div class="race-timeline" data-score-race-timeline role="tablist" aria-label="Línea de tiempo de partidos"></div>
      </div>
    </div>

    <div class="race-side">
      <ScoreRaceNarrative />
      <ScoreRaceLegend />
    </div>
  </div>

  <ScoreRacePopup />
</div>

<style is:global>
  [data-section="estadisticas"] [data-score-race] {
    --race-purple: var(--pm-purple-500);
    --race-blue: var(--pm-blue-500);
    --race-green: var(--pm-green-500);
    --race-miss: rgba(7, 26, 53, 0.22);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-width: 0;
  }

  /* ── Cabecera ──────────────────────────────────────────────────────────── */
  [data-score-race] .race-head { display: flex; flex-direction: column; gap: 0.12rem; }
  [data-score-race] .race-kicker {
    margin: 0;
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  [data-score-race] .race-title {
    margin: 0;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.6vw, 2.8rem);
    font-weight: 950;
    line-height: 0.95;
    text-transform: uppercase;
  }
  [data-score-race] .race-sub {
    margin: 0;
    color: var(--pm-blue-700);
    font-size: 0.8rem;
    font-weight: 700;
  }

  /* ── Layout: el gráfico ocupa TODO el ancho; narrativa + leyenda van debajo ── */
  [data-score-race] .race-layout {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  [data-score-race] .race-main { display: flex; min-width: 0; flex-direction: column; gap: 0.6rem; }
  [data-score-race] .race-side {
    display: grid;
    min-width: 0;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 0.7rem;
    align-items: start;
  }

  [data-score-race] .race-graph,
  [data-score-race] .race-narrative,
  [data-score-race] .race-legend-block {
    border: 1px solid color-mix(in srgb, var(--pm-cyan-500) 30%, transparent);
    border-radius: 1rem;
    background:
      radial-gradient(circle at 92% 8%, rgba(24, 221, 242, 0.12), transparent 32%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.97), rgba(241, 249, 255, 0.94));
    box-shadow: 0 14px 34px rgba(7, 23, 53, 0.1);
  }

  /* ── Gráfico ───────────────────────────────────────────────────────────── */
  [data-score-race] .race-graph {
    position: relative;
    min-height: 21rem;
    padding: 0.85rem;
  }

  [data-score-race] .race-canvas { display: grid; grid-template-columns: 180px minmax(0, 1fr); gap: 0.5rem; }
  [data-score-race] .race-scroll { overflow-x: auto; overflow-y: hidden; min-width: 0; padding-bottom: 0.3rem; }
  [data-score-race] .race-svg { display: block; }

  /* Rejilla + ejes */
  [data-score-race] .race-grid-line { stroke: rgba(7, 26, 53, 0.1); stroke-width: 1; }
  [data-score-race] .race-axis-label { fill: var(--pm-blue-700); font-family: var(--font-score); font-size: 11px; font-weight: 700; }
  [data-score-race] .race-xtick { fill: var(--pm-blue-900); font-family: var(--font-display); font-size: 11px; font-weight: 800; }
  [data-score-race] .race-xresult { fill: var(--pm-blue-700); font-family: var(--font-score); font-size: 10px; font-weight: 700; }
  [data-score-race] .race-xcol { fill: transparent; cursor: pointer; }
  [data-score-race] .race-xcol.is-selected ~ .race-xtick { fill: var(--pm-blue-900); }
  [data-score-race] .race-col-highlight { fill: rgba(245, 180, 23, 0.14); }

  /* Líneas de jugador */
  [data-score-race] .race-line {
    fill: none;
    stroke: var(--c, var(--pm-blue-500));
    stroke-width: 2.4;
    stroke-linejoin: round;
    stroke-linecap: round;
    filter: drop-shadow(0 1px 2px color-mix(in srgb, var(--c, #126dff) 45%, transparent));
    transition: opacity 160ms ease, stroke-width 160ms ease;
  }
  [data-score-race] .race-line[data-status="live"] { stroke-dasharray: 6 5; }
  [data-score-race].is-focusing .race-line { opacity: 0.16; }
  [data-score-race].is-focusing .race-line.is-focus { opacity: 1; stroke-width: 4; }
  [data-score-race] .race-line.is-you { stroke-width: 3.2; }

  /* Nodos (clusters) */
  [data-score-race] .race-node { cursor: pointer; }
  [data-score-race] .race-node circle {
    stroke: var(--pm-white);
    stroke-width: 2.5;
    fill: var(--race-miss);
    transition: r 140ms ease;
  }
  [data-score-race] .race-node[data-hit-type="lone_wolf"] circle { fill: var(--race-purple); }
  [data-score-race] .race-node[data-hit-type="exact"] circle { fill: var(--race-blue); }
  [data-score-race] .race-node[data-hit-type="tendency"] circle { fill: var(--race-green); }
  [data-score-race] .race-node-badge { fill: var(--pm-white); font-family: var(--font-score); font-size: 11px; font-weight: 800; text-anchor: middle; dominant-baseline: central; }
  [data-score-race] .race-node.is-live circle { stroke-dasharray: 3 3; }

  /* Etiqueta flotante (hover) */
  [data-score-race] .race-floating {
    position: absolute;
    z-index: 5;
    display: none;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.5rem;
    border-radius: 0.6rem;
    background: var(--pm-blue-900);
    color: var(--pm-white);
    font-size: 0.72rem;
    font-weight: 800;
    pointer-events: none;
    box-shadow: 0 8px 20px rgba(7, 23, 53, 0.3);
    transform: translate(-50%, -130%);
    white-space: nowrap;
  }
  [data-score-race] .race-floating[data-show="true"] { display: flex; }
  [data-score-race] .race-floating img { width: 1.1rem; height: 1.1rem; border-radius: 999px; object-fit: cover; }
  [data-score-race] .race-floating strong { font-family: var(--font-score); color: var(--pm-cyan-500); }

  /* Columna posición actual */
  [data-score-race] .race-rail { display: flex; flex-direction: column; gap: 0.18rem; padding-left: 0.2rem; }
  [data-score-race] .race-rail-head { color: var(--pm-blue-700); font-family: var(--font-display); font-size: 0.56rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; }
  [data-score-race] .race-rail-item {
    display: grid;
    grid-template-columns: 1.1rem 1.5rem minmax(0, 1fr) auto;
    gap: 0.32rem;
    align-items: center;
    padding: 0.16rem 0.28rem;
    border-radius: 0.5rem;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
  }
  [data-score-race] .race-rail-item:hover,
  [data-score-race] .race-rail-item.is-focus { background: var(--pm-blue-100); }
  [data-score-race] .race-rail-pos { font-family: var(--font-score); font-size: 0.78rem; font-weight: 800; color: var(--pm-blue-900); font-variant-numeric: tabular-nums; }
  [data-score-race] .race-rail-avatar { width: 1.5rem; height: 1.5rem; border-radius: 999px; object-fit: cover; border: 2px solid var(--c, var(--pm-blue-500)); }
  [data-score-race] .race-rail-name { min-width: 0; font-family: var(--font-ui); font-size: 0.8rem; font-weight: 700; color: var(--pm-blue-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  [data-score-race] .race-rail-pts { font-family: var(--font-score); font-size: 0.78rem; font-weight: 800; color: var(--pm-blue-900); font-variant-numeric: tabular-nums; }

  /* ── Línea de tiempo ───────────────────────────────────────────────────── */
  [data-score-race] .race-timeline-wrap { display: flex; flex-direction: column; gap: 0.25rem; }
  [data-score-race] .race-timeline-label { color: var(--pm-blue-700); font-family: var(--font-display); font-size: 0.6rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; }
  [data-score-race] .race-timeline { display: flex; gap: 0.35rem; overflow-x: auto; padding-bottom: 0.25rem; }
  [data-score-race] .race-tl-item {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    min-width: 4.4rem;
    padding: 0.4rem 0.55rem;
    border: 1px solid rgba(7, 23, 53, 0.14);
    border-radius: 0.6rem;
    background: rgba(255, 255, 255, 0.9);
    cursor: pointer;
  }
  [data-score-race] .race-tl-item[aria-selected="true"] { border-color: var(--pm-blue-600); background: linear-gradient(135deg, var(--pm-blue-600), var(--pm-purple-500)); color: var(--pm-white); }
  [data-score-race] .race-tl-item[data-status="live"] { border-style: dashed; }
  [data-score-race] .race-tl-n { font-family: var(--font-display); font-size: 0.62rem; font-weight: 900; letter-spacing: 0.04em; }
  [data-score-race] .race-tl-r { font-family: var(--font-score); font-size: 0.72rem; font-weight: 800; font-variant-numeric: tabular-nums; }

  /* ── Narrativa ─────────────────────────────────────────────────────────── */
  [data-score-race] .race-narrative { padding: 0.85rem; }
  [data-score-race] .race-narrative header { display: flex; flex-direction: column; gap: 0.1rem; margin-bottom: 0.5rem; }
  [data-score-race] .race-narrative-kicker { color: var(--pm-blue-700); font-family: var(--font-display); font-size: 0.6rem; font-weight: 950; letter-spacing: 0.07em; text-transform: uppercase; }
  [data-score-race] .race-narrative header strong { color: var(--pm-blue-900); font-family: var(--font-display); font-size: 0.95rem; font-weight: 900; text-transform: uppercase; }
  [data-score-race] .race-narrative-body p { margin: 0 0 0.4rem; color: var(--color-text); font-size: 0.84rem; font-weight: 650; line-height: 1.45; }
  [data-score-race] .race-narrative-body .race-muted { color: var(--color-muted); font-weight: 600; }
  [data-score-race] .race-narrative-body ul { margin: 0.2rem 0 0; padding-left: 1rem; }
  [data-score-race] .race-narrative-body li { color: var(--pm-blue-700); font-size: 0.78rem; font-weight: 650; }

  /* ── Leyenda ───────────────────────────────────────────────────────────── */
  [data-score-race] .race-legend-block { display: flex; flex-direction: column; gap: 0.55rem; padding: 0.75rem; }
  [data-score-race] .race-hitlegend { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  [data-score-race] .race-hitlegend span { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.68rem; font-weight: 800; color: var(--pm-blue-900); }
  [data-score-race] .race-dot { width: 0.62rem; aspect-ratio: 1; border-radius: 999px; background: var(--race-miss); }
  [data-score-race] .race-dot[data-hit-type="lone_wolf"] { background: var(--race-purple); }
  [data-score-race] .race-dot[data-hit-type="exact"] { background: var(--race-blue); }
  [data-score-race] .race-dot[data-hit-type="tendency"] { background: var(--race-green); }
  [data-score-race] .race-players summary { cursor: pointer; font-family: var(--font-display); font-size: 0.66rem; font-weight: 900; letter-spacing: 0.05em; text-transform: uppercase; color: var(--pm-blue-900); }
  [data-score-race] .race-players-list { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.5rem; }
  [data-score-race] .race-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    padding: 0.2rem 0.5rem 0.2rem 0.2rem;
    border: 1px solid rgba(7, 23, 53, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    cursor: pointer;
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--pm-blue-900);
  }
  [data-score-race] .race-chip img { width: 1.25rem; height: 1.25rem; border-radius: 999px; object-fit: cover; border: 2px solid var(--c, var(--pm-blue-500)); }
  /* Pintado por puntaje del partido seleccionado (mismo mapeo que los nodos). */
  [data-score-race] .race-chip[data-hit-type="lone_wolf"] { border-color: var(--race-purple); background: color-mix(in srgb, var(--race-purple) 16%, white); }
  [data-score-race] .race-chip[data-hit-type="exact"] { border-color: var(--race-blue); background: color-mix(in srgb, var(--race-blue) 16%, white); }
  [data-score-race] .race-chip[data-hit-type="tendency"] { border-color: var(--race-green); background: color-mix(in srgb, var(--race-green) 16%, white); }
  [data-score-race] .race-chip[data-hit-type="none"],
  [data-score-race] .race-chip[data-hit-type="no_info"] { border-color: rgba(7, 23, 53, 0.18); background: rgba(7, 23, 53, 0.05); }
  [data-score-race] .race-chip[data-you="true"] { box-shadow: 0 0 0 2px var(--pm-yellow-500); }
  [data-score-race] .race-chip.is-focus { background: var(--pm-blue-100); }
  [data-score-race] .race-chip .race-you-badge { font-size: 0.54rem; font-weight: 900; color: var(--pm-blue-700); letter-spacing: 0.04em; }

  /* ── Pop-up / bottom sheet ─────────────────────────────────────────────── */
  [data-score-race] .race-popup { width: min(30rem, 92vw); max-width: 92vw; padding: 0; border: 0; border-radius: 1rem; background: transparent; }
  [data-score-race] .race-popup::backdrop { background: rgba(7, 23, 53, 0.45); backdrop-filter: blur(2px); }
  [data-score-race] .race-popup-inner {
    border: 1px solid color-mix(in srgb, var(--pm-cyan-500) 34%, transparent);
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(240, 249, 255, 0.97));
    box-shadow: 0 26px 60px rgba(7, 23, 53, 0.32);
    overflow: hidden;
  }
  [data-score-race] .race-popup-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; padding: 0.85rem 0.95rem; border-bottom: 1px solid rgba(7, 23, 53, 0.1); }
  [data-score-race] .race-popup-kicker { display: block; color: var(--pm-blue-700); font-family: var(--font-display); font-size: 0.58rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; }
  [data-score-race] .race-popup-head h3 { margin: 0.1rem 0 0; color: var(--pm-blue-900); font-family: var(--font-display); font-size: 1.05rem; font-weight: 950; text-transform: uppercase; }
  [data-score-race] .race-popup-close { display: grid; place-items: center; width: 2rem; height: 2rem; border: 1px solid var(--pm-border-soft); border-radius: 0.5rem; background: rgba(255, 255, 255, 0.8); font-size: 1.2rem; line-height: 1; cursor: pointer; color: var(--pm-blue-900); }
  [data-score-race] .race-popup-body { max-height: 60vh; overflow-y: auto; padding: 0.7rem 0.95rem 1rem; }
  [data-score-race] .race-popup-meta { margin: 0 0 0.6rem; color: var(--pm-blue-700); font-size: 0.78rem; font-weight: 750; }
  [data-score-race] .race-popup-list { display: flex; flex-direction: column; gap: 0.28rem; }
  [data-score-race] .race-prow {
    display: grid;
    grid-template-columns: 1.6rem minmax(0, 1fr) auto auto;
    gap: 0.45rem;
    align-items: center;
    padding: 0.3rem 0.4rem;
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.7);
  }
  [data-score-race] .race-prow[data-you="true"] { box-shadow: inset 0 0 0 2px var(--pm-yellow-500); }
  [data-score-race] .race-prow img { width: 1.6rem; height: 1.6rem; border-radius: 999px; object-fit: cover; }
  [data-score-race] .race-prow-name { min-width: 0; font-size: 0.78rem; font-weight: 800; color: var(--pm-blue-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  [data-score-race] .race-prow-pred { font-family: var(--font-score); font-size: 0.74rem; font-weight: 700; color: var(--pm-blue-700); font-variant-numeric: tabular-nums; }
  [data-score-race] .race-prow-pts { display: inline-flex; align-items: center; gap: 0.3rem; font-family: var(--font-score); font-size: 0.78rem; font-weight: 800; color: var(--pm-blue-900); font-variant-numeric: tabular-nums; }
  [data-score-race] .race-prow-pts .race-dot { width: 0.55rem; }

  /* ── Responsive ────────────────────────────────────────────────────────── */
  @media (max-width: 720px) {
    [data-score-race] .race-side { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    [data-score-race] .race-canvas { grid-template-columns: 1fr; }
    [data-score-race] .race-rail { flex-direction: row; flex-wrap: wrap; gap: 0.3rem; }
    /* En el cel el orden ya da la posición: se oculta el número y queda
       avatar · nombre · pts (más aire para el nombre). */
    [data-score-race] .race-rail-pos { display: none; }
    [data-score-race] .race-rail-item { grid-template-columns: 1.5rem minmax(0, 1fr) auto; }
    /* Bottom sheet en mobile */
    [data-score-race] .race-popup { width: 100vw; max-width: 100vw; margin: auto auto 0; border-radius: 1rem 1rem 0 0; }
    [data-score-race] .race-popup-inner { border-radius: 1rem 1rem 0 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-score-race] .race-line,
    [data-score-race] .race-node circle { transition: none; }
  }
</style>
