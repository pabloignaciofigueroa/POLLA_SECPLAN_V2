---
import { INLINE, type UiAsset } from "../../lib/ui-assets/uiAssets";

interface Props {
  icon: string;
  title: string;
  description: string;
  tone?: "blue" | "purple" | "cyan" | "lime";
}

const { icon, title, description, tone = "blue" } = Astro.props;

// Iconos inline = familia mate (icon-circle-*).
const ICONS: Record<string, UiAsset> = {
  VS: INLINE.player, // comparativa entre jugadores
  "01": INLINE.podium, // ranking global
};
const benefitIcon = ICONS[icon] ?? INLINE.trendUp; // tendencias
---

<article class={`benefit-card benefit-card--${tone}`}>
  <span class="icon" aria-hidden="true">
    <img src={benefitIcon.src} alt="" width={benefitIcon.width} height={benefitIcon.height} loading="eager" decoding="async" />
  </span>
  <div class="copy">
    <h3 class="title">{title}</h3>
    <p class="description">{description}</p>
  </div>
</article>

<style>
  .benefit-card {
    --card-accent: var(--pm-blue-500);

    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.85rem;
    align-items: center;
    min-width: 0;
    padding: 0.3rem 1.35rem 0.3rem 0.2rem;
    color: var(--pm-blue-900);
  }

  .benefit-card + .benefit-card {
    border-left: 1px solid rgba(7, 23, 53, 0.12);
    padding-left: 1.35rem;
  }

  .benefit-card--blue { --card-accent: var(--pm-blue-500); }
  .benefit-card--purple { --card-accent: var(--pm-purple-500); }
  .benefit-card--cyan { --card-accent: var(--pm-mint-500); }
  .benefit-card--lime { --card-accent: var(--pm-lime-500); }

  .icon {
    display: grid;
    place-items: center;
    width: 3.45rem;
    height: 3.45rem;
    padding: 0.35rem;
    border: 1px solid color-mix(in srgb, var(--card-accent) 42%, transparent);
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--card-accent) 12%, white);
    box-shadow: 0 12px 24px color-mix(in srgb, var(--card-accent) 18%, transparent);
  }

  .icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.2rem;
  }

  .title {
    margin: 0;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.12rem);
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .description {
    margin: 0;
    color: var(--pm-blue-900);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.35;
    opacity: 0.86;
  }

  @media (max-width: 1080px) {
    .benefit-card {
      padding: 0.65rem 0.2rem;
    }

    .benefit-card + .benefit-card {
      border-top: 1px solid rgba(7, 23, 53, 0.12);
      border-left: 0;
      padding-left: 0.2rem;
    }
  }
</style>
