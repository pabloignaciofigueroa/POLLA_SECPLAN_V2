---
// Pop-up de nodo agrupado / jugador. En mobile la CSS lo convierte en bottom
// sheet. Accesible: <dialog> nativo (Esc + focus-trap), boton cerrar y backdrop.
// El contenido lo inyecta score-race.client.js.
---

<dialog class="race-popup" data-score-race-popup aria-labelledby="race-popup-title">
  <div class="race-popup-inner">
    <header class="race-popup-head">
      <div>
        <span class="race-popup-kicker" data-score-race-popup-kicker>Partido</span>
        <h3 id="race-popup-title" data-score-race-popup-title>Detalle</h3>
      </div>
      <button type="button" class="race-popup-close" data-score-race-popup-close aria-label="Cerrar">
        <span aria-hidden="true">×</span>
      </button>
    </header>
    <div class="race-popup-body" data-score-race-popup-body></div>
  </div>
</dialog>
