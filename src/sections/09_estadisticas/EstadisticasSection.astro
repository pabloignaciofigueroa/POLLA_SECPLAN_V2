---
// Seccion 09_estadisticas — "DATA ARENA" arcade. 100% local. Tu resumen (stat cards) +
// consenso de la oficina como barras de votacion por cruce. Hooks data-es-* preservados.
import playersData from "../../data/players.json";
import knockoutData from "../../data/knockout-matches.json";
import teamsData from "../../data/teams.json";
import seed from "../../data/knockout-results.json";
import submissionsData from "../../data/knockout-predictions.json";

const players = (playersData as any[]).map((p) => ({ id: p.id, name: p.name }));
const teamsLite = (teamsData as any[]).map((t) => ({ code: t.shortCode, name: t.name, shortCode: t.shortCode, flag: t.flag }));
const clientPayload = {
  players,
  matches: (knockoutData as any).matches,
  teams: teamsLite,
  seedAssignments: (seed as any).slotAssignments ?? {},
  seedResults: (seed as any).results ?? [],
  submissions: (submissionsData as any).submissions ?? [],
};
---

<section class="es" id="estadisticas" data-section="estadisticas">
  <div class="es-shell">
    <header class="es-hero" data-animate="fade-up" style="--i:0">
      <p class="es-eyebrow">eliminatorias · data arena</p>
      <h1 class="es-title">Data <span class="es-title-accent">Arena</span></h1>
      <p class="es-sub" data-es-cartones>Aún sin cartones cargados.</p>
    </header>

    <div class="es-profile" data-stagger>
      <article class="es-stat es-stat--blue" data-animate="pop-in" style="--i:1">
        <span class="es-stat-ic">🎯</span>
        <span class="es-stat-num" data-es-predicted>0</span>
        <span class="es-stat-label">Cruces pronosticados</span>
      </article>
      <article class="es-stat es-stat--purple" data-animate="pop-in" style="--i:2">
        <span class="es-stat-ic">🏆</span>
        <span class="es-stat-num" data-es-podium>0/4</span>
        <span class="es-stat-label">Podio definido</span>
      </article>
      <article class="es-stat es-stat--gold" data-animate="pop-in" style="--i:3">
        <span class="es-stat-ic">⚡</span>
        <span class="es-stat-num" data-es-points>0</span>
        <span class="es-stat-label">Tus puntos</span>
      </article>
    </div>

    <section class="es-arena">
      <h2 class="es-arena-title">Consenso de la oficina</h2>
      <ul class="es-vote-list" data-es-consensus>
        <li class="es-vote-empty">El consenso aparece cuando hay cartones cargados y cruces con ambos equipos definidos.</li>
      </ul>
    </section>
  </div>

  <script type="application/json" data-estadisticas-payload set:html={JSON.stringify(clientPayload)} />
  <script>
    import "./estadisticas.knockout.client.js";
  </script>
</section>

<style>
  .es {
    --section-accent: var(--pm-sec-estadisticas-a);
    --section-accent-2: var(--pm-sec-estadisticas-b);
    position: relative;
    min-height: calc(100svh - var(--layout-header-height));
    padding: clamp(1.2rem, 3vw, 2.4rem);
    background-image: image-set(
      url("/assets/backgrounds/avif/09_estadisticas_background.avif") type("image/avif"),
      url("/assets/backgrounds/webp/09_estadisticas_background.webp") type("image/webp"));
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--pm-text-main);
    font-family: var(--font-ui);
  }
  .es-shell { max-width: 50rem; margin-inline: auto; display: flex; flex-direction: column; gap: clamp(1.1rem, 2.6vw, 1.7rem); }
  .es-hero { display: flex; flex-direction: column; align-items: flex-start; gap: 0.35rem; }
  .es-eyebrow {
    margin: 0; padding: 0.3rem 0.95rem; border-radius: 999px;
    background: color-mix(in srgb, var(--section-accent) 18%, var(--pm-white));
    border: 1px solid color-mix(in srgb, var(--section-accent) 42%, var(--pm-white));
    color: var(--pm-text-main); font-family: var(--font-display); font-weight: 900;
    font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase;
  }
  .es-title { margin: 0; font-family: var(--font-display); font-weight: 950; font-size: clamp(2rem, 5vw, 3.4rem); text-transform: uppercase; line-height: 0.95; color: var(--pm-blue-900); }
  .es-title-accent {
    background: linear-gradient(100deg, var(--pm-sec-estadisticas-a), var(--pm-sec-estadisticas-b));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .es-sub { margin: 0; color: var(--pm-blue-900); font-size: 0.86rem; font-weight: 700; }

  /* ===== STAT CARDS ===== */
  .es-profile { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.7rem; }
  .es-stat {
    display: flex; flex-direction: column; gap: 0.2rem; padding: clamp(0.9rem, 2.4vw, 1.3rem) clamp(0.8rem, 2vw, 1.1rem);
    border-radius: var(--pm-radius-lg); color: #fff; box-shadow: var(--pm-shadow-card); position: relative; overflow: hidden;
  }
  .es-stat--blue { background: linear-gradient(135deg, var(--pm-blue-600), var(--pm-cyan-500)); }
  .es-stat--purple { background: linear-gradient(135deg, var(--pm-purple-600), var(--pm-magenta-500)); }
  .es-stat--gold { background: linear-gradient(135deg, var(--pm-orange-500), var(--pm-yellow-500)); color: #3a2700; }
  .es-stat-ic { font-size: 1.7rem; line-height: 1; }
  .es-stat-num { font-family: var(--font-score); font-variant-numeric: tabular-nums; font-weight: 800; font-size: clamp(2rem, 6vw, 2.8rem); line-height: 1; }
  .es-stat-label { font-family: var(--font-display); font-weight: 800; font-size: 0.64rem; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.95; }

  /* ===== CONSENSO (barras de votación) ===== */
  .es-arena { display: flex; flex-direction: column; gap: 0.6rem; }
  .es-arena-title { margin: 0; font-family: var(--font-display); font-weight: 950; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--pm-blue-900); }
  .es-vote-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  /* OJO: los <li> del consenso los inyecta el cliente (innerHTML) -> sin scope de Astro.
     Por eso estas reglas van :global, si no, no aplican a lo inyectado. */
  :global(.es-vote) { padding: 0.6rem 0.85rem; border-radius: var(--pm-radius-md); background: var(--pm-white); box-shadow: var(--pm-shadow-soft); display: flex; flex-direction: column; gap: 0.45rem; }
  :global(.es-vote-head) { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 0.5rem; font-family: var(--font-display); font-weight: 900; font-size: 0.92rem; }
  :global(.es-vote-team) { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--pm-blue-700); min-width: 0; }
  :global(.es-vote-team--away) { justify-content: flex-end; color: var(--pm-red-500); }
  :global(.es-vote-team img) { width: 1.5rem; height: 1.5rem; border-radius: 999px; object-fit: cover; flex: 0 0 auto; }
  :global(.es-vote-id) { font-family: var(--font-display); font-weight: 800; font-size: 0.6rem; color: var(--pm-text-soft); }
  :global(.es-vote-bar) { display: flex; height: 1.6rem; border-radius: 999px; overflow: hidden; background: var(--pm-ice); font-family: var(--font-score); font-weight: 800; font-size: 0.82rem; color: #fff; }
  :global(.es-vote-fill) { display: flex; align-items: center; min-width: 1.6rem; box-sizing: border-box; }
  :global(.es-vote-fill--home) { background: linear-gradient(90deg, var(--pm-blue-600), var(--pm-cyan-500)); justify-content: flex-start; padding-left: 0.55rem; }
  :global(.es-vote-fill--away) { background: linear-gradient(90deg, var(--pm-orange-500), var(--pm-red-500)); justify-content: flex-end; padding-right: 0.55rem; }
  :global(.es-vote-meta) { display: flex; justify-content: space-between; gap: 0.5rem; font-family: var(--font-display); font-weight: 700; font-size: 0.68rem; color: var(--pm-text-soft); }
  :global(.es-vote-empty) { color: var(--pm-text-soft); font-weight: 600; padding: 0.6rem; }

  @media (max-width: 520px) {
    .es-profile { grid-template-columns: 1fr; }
  }
</style>
