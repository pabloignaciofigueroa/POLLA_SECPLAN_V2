---
import type { ArenaHighlightCategory } from "../../lib/statistics/dataArenaBase";

interface Props {
  categories: ArenaHighlightCategory[];
  universeSize: number;
}

const { categories, universeSize } = Astro.props;

const formatValue = (value: number, format: "count" | "avg") =>
  format === "avg" ? value.toFixed(2) : String(value);
---

{categories.length > 0 && (
  <section class="highlights" aria-label="Highlights del universo">
    <header class="head">
      <p class="kicker">🏆 HIGHLIGHTS DEL UNIVERSO</p>
      <p class="sub">Los récords de la oficina, rankeados contra los {universeSize} cartones.</p>
    </header>

    <div class="grid">
      {categories.map((category) => (
        <article class="category">
          <header class="category-head">
            <span class="category-emoji" aria-hidden="true">{category.emoji}</span>
            <div>
              <h3>{category.title}</h3>
              <p>{category.description}</p>
            </div>
          </header>
          <ol class="podium">
            {category.entries.map((entry) => (
              <li class={entry.rank === 1 ? "leader" : undefined}>
                <span class="rank">#{entry.rank}</span>
                <img
                  src={entry.avatarThumb}
                  alt=""
                  width="30"
                  height="30"
                  loading="lazy"
                  decoding="async"
                />
                <span class="name">{entry.displayName}</span>
                <b class="value">{formatValue(entry.value, category.format)}</b>
              </li>
            ))}
          </ol>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .highlights {
    display: grid;
    gap: 0.65rem;
  }

  .head {
    display: grid;
    gap: 0.15rem;
  }

  .kicker {
    margin: 0;
    color: var(--pm-purple-700);
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.06em;
  }

  .sub {
    margin: 0;
    color: var(--pm-blue-700);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.5rem, 1.2vw, 0.8rem);
  }

  .category {
    display: grid;
    align-content: start;
    gap: 0.45rem;
    padding: 0.8rem;
    border: 1px solid color-mix(in srgb, var(--pm-purple-500) 30%, transparent);
    border-radius: 0.9rem;
    background: linear-gradient(160deg, var(--pm-white), var(--pm-panel-soft, #eef4fb));
  }

  .category-head {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
  }

  .category-emoji {
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .category-head h3 {
    margin: 0;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 950;
    text-transform: uppercase;
    line-height: 1.05;
  }

  .category-head p {
    margin: 0.1rem 0 0;
    color: var(--pm-blue-700);
    font-size: 0.62rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .podium {
    display: grid;
    gap: 0.28rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .podium li {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: 0.45rem;
    padding: 0.3rem 0.5rem;
    border-radius: 0.6rem;
    background: color-mix(in srgb, var(--pm-blue-100, #e5eefc) 55%, transparent);
  }

  .podium li.leader {
    background: color-mix(in srgb, var(--pm-gold-500, #f5c542) 26%, var(--pm-white));
    border: 1px solid color-mix(in srgb, var(--pm-gold-700, #b8860b) 40%, transparent);
  }

  .rank {
    color: var(--pm-purple-700);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 950;
    font-variant-numeric: tabular-nums;
  }

  .podium img {
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid rgba(7, 23, 53, 0.16);
  }

  .name {
    color: var(--pm-blue-900);
    font-size: 0.74rem;
    font-weight: 850;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .value {
    color: var(--pm-blue-900);
    font-family: var(--font-score, var(--font-display));
    font-size: 0.92rem;
    font-weight: 950;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 880px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
