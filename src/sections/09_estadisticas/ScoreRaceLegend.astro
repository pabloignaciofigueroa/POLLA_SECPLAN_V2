---
// Leyenda de la Carrera de Puntaje:
//  - Colores de acierto (estatico): mismo mapeo que /tabla y Partidos.
//  - Leyenda de jugadores (dinamico): la pinta score-race.client.js.
---

<div class="race-legend-block">
  <div class="race-hitlegend" aria-label="Colores de acierto">
    <span><i class="race-dot" data-hit-type="lone_wolf" aria-hidden="true"></i> +5 Lone Wolf</span>
    <span><i class="race-dot" data-hit-type="exact" aria-hidden="true"></i> +3 Exacto</span>
    <span><i class="race-dot" data-hit-type="tendency" aria-hidden="true"></i> +1 Tendencia</span>
    <span><i class="race-dot" data-hit-type="none" aria-hidden="true"></i> 0 Sin puntos</span>
  </div>

  <details class="race-players" open>
    <summary>Jugadores <span data-score-race-legend-count></span></summary>
    <div class="race-players-list" data-score-race-legend></div>
  </details>
</div>
