<div class="lock-orb" data-lock-orb data-moment="lock-orb" aria-hidden="true">
  <img
    class="orb-image"
    src="/assets/polla-mundialera/sections/09_estadisticas/15-lock-data-center-purple.webp"
    alt=""
    width="600"
    height="600"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
</div>

<style>
  .lock-orb {
    position: relative;
    display: grid;
    place-items: center;
    width: min(100%, 285px);
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    filter: drop-shadow(0 18px 30px rgba(18, 109, 255, 0.22));
  }

  .lock-orb::before,
  .lock-orb::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .lock-orb::before {
    inset: 12%;
    background: radial-gradient(circle, rgba(24, 221, 242, 0.22), transparent 62%);
    filter: blur(8px);
  }

  .lock-orb::after {
    inset: 28%;
    box-shadow: 0 0 42px rgba(24, 221, 242, 0.42);
  }

  .orb-image {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 14px 26px rgba(124, 53, 255, 0.3));
  }

  @media (max-width: 720px) {
    .lock-orb {
      max-width: 210px;
    }
  }
</style>
