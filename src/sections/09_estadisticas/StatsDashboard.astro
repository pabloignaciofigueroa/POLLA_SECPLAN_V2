---
import StatsGraphTab from "./StatsGraphTab.astro";

interface Props {
  confirmedCards: number;
  expectedPlayers: number;
}

const { confirmedCards, expectedPlayers } = Astro.props;
---

<section class="stats-dashboard" data-stats-dashboard hidden aria-labelledby="stats-dashboard-title">
  <header class="dashboard-head">
    <div class="identity-stage" data-profile-identity>
      <span class="avatar-shell" data-profile-avatar aria-hidden="true"></span>
      <div>
        <p class="dashboard-kicker">DATA CENTER ACTIVO</p>
        <h1 id="stats-dashboard-title">Tu ADN mundialero</h1>
        <p data-profile-intro>
          Tu cartón ya puede compararse con la inteligencia colectiva de la oficina.
        </p>
      </div>
    </div>

    <dl class="coral-summary" aria-label="Estado de la comunidad">
      <div>
        <dt>Cartones</dt>
        <dd><strong>{confirmedCards}</strong> / {expectedPlayers}</dd>
      </div>
      <div>
        <dt>Marcadores</dt>
        <dd><strong>{confirmedCards * 72}</strong></dd>
      </div>
      <div>
        <dt>Clasificados</dt>
        <dd><strong>{confirmedCards * 24}</strong></dd>
      </div>
    </dl>
  </header>

  <nav class="stats-tabs" aria-label="Secciones de estadísticas" role="tablist">
    <button type="button" role="tab" id="stats-tab-grafico" data-stats-tab="grafico" aria-controls="stats-panel-grafico" aria-selected="true">
      Gráfico
    </button>
    <button type="button" role="tab" id="stats-tab-partidos" data-stats-tab="partidos" aria-controls="stats-panel-partidos" aria-selected="false" tabindex="-1">
      Partidos
    </button>
    <button type="button" role="tab" id="stats-tab-comunidad" data-stats-tab="comunidad" aria-controls="stats-panel-comunidad" aria-selected="false" tabindex="-1">
      Comunidad
    </button>
    <button type="button" role="tab" id="stats-tab-perfil" data-stats-tab="perfil" aria-controls="stats-panel-perfil" aria-selected="false" tabindex="-1">
      Mi perfil
    </button>
    <button type="button" role="tab" id="stats-tab-comparar" data-stats-tab="comparar" aria-controls="stats-panel-comparar" aria-selected="false" tabindex="-1">
      Comparar
    </button>
    <button type="button" role="tab" id="stats-tab-grupos" data-stats-tab="grupos" aria-controls="stats-panel-grupos" aria-selected="false" tabindex="-1">
      Clasificación
    </button>
  </nav>

  <div class="dashboard-status" data-dashboard-status role="status" aria-live="polite">
    Preparando las comparaciones...
  </div>

  <section id="stats-panel-grafico" data-stats-panel="grafico" role="tabpanel" aria-labelledby="stats-tab-grafico">
    <StatsGraphTab />
  </section>
  <section id="stats-panel-perfil" data-stats-panel="perfil" role="tabpanel" aria-labelledby="stats-tab-perfil" hidden></section>
  <section id="stats-panel-comunidad" data-stats-panel="comunidad" role="tabpanel" aria-labelledby="stats-tab-comunidad" hidden></section>
  <section id="stats-panel-partidos" data-stats-panel="partidos" role="tabpanel" aria-labelledby="stats-tab-partidos" hidden></section>
  <section id="stats-panel-comparar" data-stats-panel="comparar" role="tabpanel" aria-labelledby="stats-tab-comparar" hidden></section>
  <section id="stats-panel-grupos" data-stats-panel="grupos" role="tabpanel" aria-labelledby="stats-tab-grupos" hidden></section>
</section>

<style>
  .stats-dashboard {
    display: flex;
    flex-direction: column;
    gap: 0.72rem;
  }

  .stats-dashboard[hidden] {
    display: none;
  }

  .dashboard-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: clamp(0.9rem, 1.7vw, 1.35rem);
    border: 1px solid color-mix(in srgb, var(--pm-cyan-500) 38%, transparent);
    border-radius: 1rem;
    background:
      radial-gradient(circle at 12% 15%, rgba(24, 221, 242, 0.18), transparent 28%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.97), rgba(242, 250, 255, 0.94));
    box-shadow: 0 18px 42px rgba(7, 23, 53, 0.13);
  }

  .identity-stage {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.85rem;
    align-items: center;
    min-width: 0;
  }

  .avatar-shell {
    display: grid;
    place-items: center;
    width: clamp(4.25rem, 8vw, 6.25rem);
    aspect-ratio: 1;
    overflow: hidden;
    border: 0.28rem solid rgba(255, 255, 255, 0.9);
    border-radius: 1rem;
    background: linear-gradient(135deg, var(--pm-blue-500), var(--pm-purple-500));
    box-shadow: 0 12px 30px rgba(18, 109, 255, 0.25);
  }

  .dashboard-kicker,
  .dashboard-head h1,
  .dashboard-head p {
    margin: 0;
  }

  .dashboard-kicker {
    color: var(--pm-mint-600, #16a34a);
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.08em;
  }

  .dashboard-head h1 {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.3rem);
    font-weight: 950;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .dashboard-head p:not(.dashboard-kicker) {
    max-width: 58ch;
    color: var(--pm-blue-700);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .coral-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(5.2rem, auto));
    gap: 0;
    margin: 0;
    overflow: hidden;
    border-radius: 0.72rem;
    background: var(--pm-blue-900);
    color: var(--pm-white);
  }

  .coral-summary div {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.08rem;
    padding: 0.65rem 0.8rem;
    text-align: center;
  }

  .coral-summary div + div {
    border-left: 1px solid rgba(255, 255, 255, 0.16);
  }

  .coral-summary dt {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.54rem;
    font-weight: 850;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .coral-summary dd {
    margin: 0;
    font-family: var(--font-score);
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
    font-weight: 800;
  }

  .coral-summary strong {
    color: var(--pm-cyan-500);
    font-size: 1.35rem;
  }

  .stats-tabs {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.35rem;
    padding: 0.35rem;
    border: 1px solid rgba(7, 23, 53, 0.12);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.9);
  }

  .stats-tabs button {
    min-width: 0;
    padding: 0.62rem 0.55rem;
    border: 0;
    border-radius: 0.52rem;
    background: transparent;
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.76rem;
    font-weight: 950;
    letter-spacing: 0.035em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 160ms var(--ease-out, ease-out),
      color 160ms var(--ease-out, ease-out),
      transform 120ms var(--ease-out, ease-out);
  }

  .stats-tabs button:hover {
    background: var(--pm-blue-100);
    color: var(--pm-blue-900);
  }

  .stats-tabs button:active {
    transform: scale(0.97);
  }

  .stats-tabs button:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  .stats-tabs button[aria-selected="true"] {
    background: linear-gradient(135deg, var(--pm-blue-600), var(--pm-purple-500));
    color: var(--pm-white);
    box-shadow: 0 7px 18px rgba(18, 109, 255, 0.22);
  }

  .dashboard-status {
    min-height: 1.1rem;
    color: var(--pm-blue-700);
    font-size: 0.7rem;
    font-weight: 750;
  }

  @media (max-width: 840px) {
    .dashboard-head {
      grid-template-columns: 1fr;
    }

    .coral-summary {
      width: 100%;
    }

    /* 6 pestanas se aprietan en tablet: 3 columnas x 2 filas. */
    .stats-tabs {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .identity-stage {
      grid-template-columns: 1fr;
    }

    .stats-tabs {
      grid-template-columns: 1fr 1fr;
    }

    .coral-summary {
      grid-template-columns: 1fr;
    }

    .coral-summary div + div {
      border-top: 1px solid rgba(255, 255, 255, 0.16);
      border-left: 0;
    }
  }
</style>

<!--
  F9 Clasificacion de grupos: el panel se llena por innerHTML en runtime
  (estadisticas.client.js -> renderGrupos), por lo que el CSS scoped de Astro NO
  aplica. Estilo via <style is:global> anclado a [data-stats-panel="grupos"]
  (gotcha "CSS de nodos runtime"). Estados: locked=gris, in_definition=naranja,
  final=verde, con texto/candado ademas del color (no color solo).
-->
<style is:global>
  [data-stats-panel="grupos"] .grupos-layout {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  [data-stats-panel="grupos"] .grupos-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  [data-stats-panel="grupos"] .grupos-head-main {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  [data-stats-panel="grupos"] .grupos-kicker {
    color: var(--pm-blue-700);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 950;
    letter-spacing: 0.06em;
  }

  [data-stats-panel="grupos"] .grupos-player-select select {
    padding: 0.4rem 0.6rem;
    border: 1px solid rgba(7, 23, 53, 0.18);
    border-radius: 0.5rem;
    background: var(--pm-white, #fff);
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 850;
    cursor: pointer;
  }

  [data-stats-panel="grupos"] .grupos-player-select select:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  [data-stats-panel="grupos"] .grupos-totals {
    display: flex;
    gap: 0;
    margin: 0;
    overflow: hidden;
    border-radius: 0.6rem;
    background: var(--pm-blue-900);
    color: var(--pm-white);
  }

  [data-stats-panel="grupos"] .grupos-totals div {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    padding: 0.45rem 0.7rem;
    text-align: center;
  }

  [data-stats-panel="grupos"] .grupos-totals div + div {
    border-left: 1px solid rgba(255, 255, 255, 0.16);
  }

  [data-stats-panel="grupos"] .grupos-totals dt {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.52rem;
    font-weight: 850;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  [data-stats-panel="grupos"] .grupos-totals dd {
    margin: 0;
    color: var(--pm-cyan-500);
    font-family: var(--font-score, var(--font-display));
    font-size: 1.1rem;
    font-variant-numeric: tabular-nums;
    font-weight: 900;
  }

  [data-stats-panel="grupos"] .grupos-note {
    margin: 0;
    color: var(--pm-blue-700);
    font-size: 0.72rem;
    font-weight: 650;
  }

  [data-stats-panel="grupos"] .grupos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 0.65rem;
  }

  [data-stats-panel="grupos"] .grupo-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.7rem 0.8rem;
    border: 1px solid rgba(7, 23, 53, 0.12);
    border-radius: 0.7rem;
    background: var(--pm-white, #fff);
  }

  [data-stats-panel="grupos"] .grupo-card[data-grupo-state="locked"] {
    background: rgba(241, 245, 249, 0.85);
    border-color: rgba(7, 23, 53, 0.1);
  }

  [data-stats-panel="grupos"] .grupo-card[data-grupo-state="in_definition"] {
    border-color: color-mix(in srgb, #f97316 55%, transparent);
    box-shadow: 0 6px 18px rgba(249, 115, 22, 0.12);
  }

  [data-stats-panel="grupos"] .grupo-card[data-grupo-state="final"] {
    border-color: color-mix(in srgb, var(--pm-mint-600, #16a34a) 55%, transparent);
  }

  [data-stats-panel="grupos"] .grupo-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
  }

  [data-stats-panel="grupos"] .grupo-head h3 {
    margin: 0;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 900;
  }

  [data-stats-panel="grupos"] .grupo-state {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
    padding: 0.18rem 0.45rem;
    border-radius: 999px;
    font-size: 0.56rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  [data-stats-panel="grupos"] .grupo-state[data-grupo-state="locked"] {
    background: rgba(100, 116, 139, 0.16);
    color: #475569;
  }

  [data-stats-panel="grupos"] .grupo-state[data-grupo-state="in_definition"] {
    background: rgba(249, 115, 22, 0.16);
    color: #c2410c;
  }

  [data-stats-panel="grupos"] .grupo-state[data-grupo-state="final"] {
    background: color-mix(in srgb, var(--pm-mint-600, #16a34a) 16%, transparent);
    color: var(--pm-mint-700, #15803d);
  }

  [data-stats-panel="grupos"] .grupo-slots {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  [data-stats-panel="grupos"] .g-slot {
    display: grid;
    grid-template-columns: auto auto auto minmax(2.4rem, 1fr) auto;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
  }

  [data-stats-panel="grupos"] .g-pos {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--pm-blue-700);
    font-size: 0.62rem;
    font-weight: 850;
  }

  [data-stats-panel="grupos"] .g-badge {
    display: inline-grid;
    place-items: center;
    width: 1.05rem;
    height: 1.05rem;
    border-radius: 50%;
    font-size: 0.6rem;
    font-weight: 900;
    color: var(--pm-white);
  }

  [data-stats-panel="grupos"] .g-badge[data-pos="1"] {
    background: var(--pm-blue-600, #126dff);
  }

  [data-stats-panel="grupos"] .g-badge[data-pos="2"] {
    background: var(--pm-purple-500, #7c3aed);
  }

  [data-stats-panel="grupos"] .g-pick,
  [data-stats-panel="grupos"] .g-current {
    font-family: var(--font-score, var(--font-display));
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    color: var(--pm-blue-900);
  }

  [data-stats-panel="grupos"] .g-arrow {
    color: var(--pm-blue-400, #60a5fa);
    font-weight: 900;
  }

  [data-stats-panel="grupos"] .g-current {
    color: var(--pm-blue-700);
  }

  [data-stats-panel="grupos"] .g-locked-current {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  [data-stats-panel="grupos"] .g-pts {
    justify-self: end;
    min-width: 1.6rem;
    padding: 0.05rem 0.35rem;
    border-radius: 0.4rem;
    text-align: center;
    font-family: var(--font-score, var(--font-display));
    font-size: 0.78rem;
    font-weight: 900;
    background: rgba(100, 116, 139, 0.14);
    color: #475569;
  }

  [data-stats-panel="grupos"] .g-pts[data-hit="true"] {
    background: color-mix(in srgb, var(--pm-mint-600, #16a34a) 18%, transparent);
    color: var(--pm-mint-700, #15803d);
  }

  [data-stats-panel="grupos"] .g-pts-locked {
    background: transparent;
    color: #94a3b8;
  }

  [data-stats-panel="grupos"] .g-slot[data-hit="true"] .g-current {
    color: var(--pm-mint-700, #15803d);
  }

  [data-stats-panel="grupos"] .grupo-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.35rem;
    border-top: 1px dashed rgba(7, 23, 53, 0.12);
  }

  [data-stats-panel="grupos"] .grupo-foot span {
    color: var(--pm-blue-700);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  [data-stats-panel="grupos"] .grupo-total {
    font-family: var(--font-score, var(--font-display));
    font-size: 1rem;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
    color: var(--pm-blue-900);
  }

  @media (max-width: 620px) {
    [data-stats-panel="grupos"] .grupos-grid {
      grid-template-columns: 1fr;
    }

    [data-stats-panel="grupos"] .grupos-totals {
      width: 100%;
    }
  }
</style>
