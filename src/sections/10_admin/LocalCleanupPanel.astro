---
import AdminActionButton from "./AdminActionButton.astro";
---

<section class="panel" data-admin-panel="local-cleanup" aria-labelledby="local-cleanup-title">
  <header class="panel-head">
    <h2 id="local-cleanup-title">LIMPIEZA LOCAL</h2>
  </header>
  <p>
    Reinicia seleccion, predicciones, favoritos y version local de este navegador.
  </p>
  <div class="actions">
    <AdminActionButton label="Limpiar este navegador" action="danger-reset-local" variant="danger" />
  </div>
</section>

<style>
  .panel {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.65rem;
    padding: 0.85rem;
    border: 1px solid var(--pm-red-500);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.84);
  }

  h2,
  p {
    margin: 0;
  }

  h2 {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.86rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  p {
    color: var(--color-muted);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
  }
</style>
