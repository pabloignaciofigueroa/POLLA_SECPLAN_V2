---
import AdminActionButton from "./AdminActionButton.astro";
import type { AdminDashboardViewModel } from "./admin.logic";

interface Props {
  predictions: AdminDashboardViewModel["predictions"];
  submissions: Array<{
    playerId: string;
    displayName: string;
    submittedAt: string;
    checksum: string;
  }>;
}

const { predictions, submissions } = Astro.props;

const rows = [
  ["Partidos disponibles", predictions.availableMatches],
  ["Cartones confirmados", predictions.confirmedCards],
  ["Cartones incompletos", predictions.incompleteCards],
  ["Con errores", predictions.withErrors],
  ["Total predicciones", `${predictions.loadedPredictions} / ${predictions.totalPredictions}`],
  ["Última importación", predictions.lastImportLabel],
];
---

<section class="panel" data-admin-panel="predictions" aria-labelledby="predictions-title">
  <header class="panel-head">
    <h2 id="predictions-title">PREDICCIONES CARGADAS</h2>
  </header>
  <dl class="rows">
    {rows.map(([label, value]) => (
      <div>
        <dt>{label}</dt>
        <dd>{value}</dd>
      </div>
    ))}
  </dl>
  <div class="player-state">
    <p><strong>Confirmados:</strong> {predictions.confirmedNames.join(", ") || "Ninguno"}</p>
    <p><strong>Pendientes:</strong> {predictions.pendingNames.join(", ") || "Ninguno"}</p>
  </div>
  <div class="edit-access" data-prediction-edit-admin>
    <div class="edit-access-head">
      <div>
        <strong>EDICIÓN TEMPORAL</strong>
        <p>Códigos de un solo uso · 30 min para canjear · 2 h de sesión</p>
      </div>
      <span data-edit-access-summary>Sin permisos activos</span>
    </div>

    <div class="edit-access-list">
      {submissions.map((submission) => (
        <article
          class="edit-player"
          data-edit-player
          data-player-id={submission.playerId}
          data-player-name={submission.displayName}
        >
          <div class="edit-player-copy">
            <strong>{submission.displayName}</strong>
            <small data-edit-player-status>Cartón protegido</small>
          </div>
          <div class="edit-player-actions">
            <button type="button" data-edit-code-generate>Generar código</button>
            <button type="button" data-edit-code-revoke disabled>Revocar</button>
          </div>
          <div class="edit-code-result" data-edit-code-result hidden>
            <code data-edit-code-value></code>
            <button type="button" data-edit-code-copy>Copiar</button>
            <small data-edit-code-expiry></small>
          </div>
        </article>
      ))}
    </div>
  </div>
  <div class="actions">
    <AdminActionButton label="Cargar resultados" action="load-results" />
    <AdminActionButton label="Ver inconsistencias" action="view-inconsistencies" />
  </div>
</section>

<style>
  .panel { display:flex; flex-direction:column; gap:.65rem; min-width:0; padding:.85rem; border:1px solid var(--color-line); border-radius:var(--radius-md); background:rgba(255,255,255,.78); }
  h2 { margin:0; color:var(--color-text); font-family:var(--font-display); font-size:.86rem; font-weight:950; letter-spacing:.04em; text-transform:uppercase; }
  .rows { display:flex; flex-direction:column; margin:0; border-top:1px solid var(--color-line); }
  .rows div { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:.75rem; padding:.42rem 0; border-bottom:1px solid var(--color-line); }
  dt, dd { margin:0; font-size:.7rem; font-weight:800; }
  dt { color:var(--color-muted); }
  dd { color:var(--color-text); text-align:right; }
  .actions { display:flex; flex-wrap:wrap; gap:.45rem; margin-top:auto; }
  .player-state { display:flex; flex-direction:column; gap:.25rem; padding:.55rem; border-radius:.5rem; background:rgba(18,109,255,.07); }
  .player-state p { margin:0; color:var(--color-muted); font-size:.64rem; line-height:1.35; }
  .player-state strong { color:var(--color-text); }
  .edit-access { display:grid; gap:.55rem; padding:.65rem; border:1px solid color-mix(in srgb, var(--pm-purple-500) 28%, transparent); border-radius:.6rem; background:color-mix(in srgb, var(--pm-purple-500) 7%, white); }
  .edit-access-head { display:flex; align-items:flex-start; justify-content:space-between; gap:.6rem; }
  .edit-access-head strong { color:var(--pm-purple-700); font-family:var(--font-display); font-size:.72rem; font-weight:950; }
  .edit-access-head p { margin:.15rem 0 0; color:var(--color-muted); font-size:.58rem; font-weight:750; }
  .edit-access-head > span { flex:0 0 auto; padding:.2rem .42rem; border-radius:999px; background:white; color:var(--pm-blue-700); font-size:.56rem; font-weight:900; }
  .edit-access-list { display:grid; gap:.38rem; }
  .edit-player { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:.4rem .55rem; align-items:center; padding:.48rem; border:1px solid var(--color-line); border-radius:.5rem; background:rgba(255,255,255,.88); }
  .edit-player-copy { display:grid; gap:.12rem; min-width:0; }
  .edit-player-copy strong { color:var(--color-text); font-size:.68rem; font-weight:950; text-transform:uppercase; }
  .edit-player-copy small { color:var(--color-muted); font-size:.56rem; font-weight:800; }
  .edit-player[data-access-status="session"] .edit-player-copy small { color:var(--pm-green-700); }
  .edit-player[data-access-status="code"] .edit-player-copy small { color:var(--pm-purple-700); }
  .edit-player-actions { display:flex; flex-wrap:wrap; justify-content:flex-end; gap:.3rem; }
  .edit-player button { min-height:1.9rem; padding:.35rem .5rem; border:1px solid var(--pm-blue-400); border-radius:.4rem; background:white; color:var(--pm-blue-700); font-size:.56rem; font-weight:950; cursor:pointer; text-transform:uppercase; transition:transform 140ms cubic-bezier(.23,1,.32,1); }
  .edit-player button[data-edit-code-generate] { border-color:var(--pm-purple-500); color:var(--pm-purple-700); }
  .edit-player button[data-edit-code-revoke] { border-color:var(--pm-red-400); color:var(--pm-red-600); }
  .edit-player button:disabled { cursor:not-allowed; opacity:.45; }
  .edit-player button:not(:disabled):active { transform:scale(.97); }
  .edit-player button:focus-visible { outline:none; box-shadow:var(--pm-focus-ring-pink); }
  .edit-code-result { grid-column:1 / -1; display:grid; grid-template-columns:minmax(0,1fr) auto; gap:.3rem; align-items:center; padding:.42rem; border-radius:.42rem; background:var(--pm-blue-950); color:white; }
  .edit-code-result[hidden] { display:none; }
  .edit-code-result code { font-family:var(--font-score); font-size:1rem; font-weight:950; letter-spacing:.15em; text-align:center; }
  .edit-code-result small { grid-column:1 / -1; color:rgba(255,255,255,.72); font-size:.54rem; text-align:center; }
  @media (max-width:520px) { .edit-player { grid-template-columns:1fr; } .edit-player-actions { justify-content:flex-start; } }
  @media (prefers-reduced-motion:reduce) { .edit-player button { transition:none; } }
</style>
