---
import AdminActionButton from "./AdminActionButton.astro";
import type { AdminDashboardViewModel } from "./admin.logic";

interface Props {
  predictions: AdminDashboardViewModel["predictions"];
}

const { predictions } = Astro.props;

const rows = [
  ["Partidos disponibles", predictions.availableMatches],
  ["Cartones confirmados", predictions.confirmedCards],
  ["Cartones incompletos", predictions.incompleteCards],
  ["Con errores", predictions.withErrors],
  ["Total predicciones", `0 / ${predictions.totalPredictions}`],
];
---

<section class="panel" data-admin-panel="predictions" aria-labelledby="predictions-title">
  <header class="panel-head">
    <h2 id="predictions-title">PREDICCIONES CARGADAS</h2>
  </header>
  <dl class="rows">
    {rows.map(([label, value]) => (
      <div>
        <dt>{label}</dt>
        <dd>{value}</dd>
      </div>
    ))}
  </dl>
  <div class="actions">
    <AdminActionButton label="Cargar resultados" action="load-results" />
    <AdminActionButton label="Ver inconsistencias" action="view-inconsistencies" />
  </div>
</section>

<style>
  .panel { display:flex; flex-direction:column; gap:.65rem; min-width:0; padding:.85rem; border:1px solid var(--color-line); border-radius:var(--radius-md); background:rgba(255,255,255,.78); }
  h2 { margin:0; color:var(--color-text); font-family:var(--font-display); font-size:.86rem; font-weight:950; letter-spacing:.04em; text-transform:uppercase; }
  .rows { display:flex; flex-direction:column; margin:0; border-top:1px solid var(--color-line); }
  .rows div { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:.75rem; padding:.42rem 0; border-bottom:1px solid var(--color-line); }
  dt, dd { margin:0; font-size:.7rem; font-weight:800; }
  dt { color:var(--color-muted); }
  dd { color:var(--color-text); text-align:right; }
  .actions { display:flex; flex-wrap:wrap; gap:.45rem; margin-top:auto; }
</style>
