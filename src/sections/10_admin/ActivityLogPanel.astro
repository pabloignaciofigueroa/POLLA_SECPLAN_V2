---
import AdminActionButton from "./AdminActionButton.astro";
import type { AdminDashboardViewModel } from "./admin.logic";

interface Props {
  entries: AdminDashboardViewModel["activityLog"];
}

const { entries } = Astro.props;
---

<section class="activity-log" data-admin-panel="activity" aria-labelledby="activity-title">
  <header>
    <h2 id="activity-title">BITÁCORA DE ACTIVIDAD</h2>
    <AdminActionButton label="Ver bitácora completa" action="view-full-log" />
  </header>
  <div class="entries">
    {entries.map((entry) => (
      <article>
        <time>{entry.date}, {entry.time}</time>
        <strong>{entry.event}</strong>
        <span>{entry.user}</span>
      </article>
    ))}
  </div>
</section>

<style>
  .activity-log { display:flex; flex-direction:column; gap:.65rem; min-width:0; padding:.85rem; border:1px solid color-mix(in srgb, var(--pm-sec-admin-a) 30%, transparent); border-radius:var(--radius-md); background:linear-gradient(135deg, color-mix(in srgb, var(--pm-sec-admin-a) 16%, transparent), color-mix(in srgb, var(--pm-cyan-500) 18%, transparent)), var(--pm-panel-soft); }
  header { display:flex; justify-content:space-between; gap:.75rem; align-items:center; }
  h2 { margin:0; color:var(--color-text); font-family:var(--font-display); font-size:.86rem; font-weight:950; letter-spacing:.04em; text-transform:uppercase; }
  .entries { display:flex; flex-direction:column; gap:.45rem; }
  article { display:grid; grid-template-columns:minmax(8rem,.75fr) minmax(0,1fr) minmax(8rem,.8fr); gap:.75rem; align-items:center; padding:.55rem 0; border-top:1px solid var(--color-line); }
  time, span { color:var(--color-muted); font-size:.72rem; font-weight:800; }
  strong { color:var(--color-text); font-size:.78rem; font-weight:850; }
  @media (max-width: 680px) {
    header, article { display:flex; flex-direction:column; align-items:flex-start; }
  }
</style>
