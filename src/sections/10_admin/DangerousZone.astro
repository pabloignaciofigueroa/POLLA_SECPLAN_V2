---
import AdminActionButton from "./AdminActionButton.astro";
---

<section class="danger-zone" aria-labelledby="danger-zone-title">
  <h3 id="danger-zone-title">
    <span class="dz-icon" aria-hidden="true">
      <img src="/assets/polla-mundialera/sections/10_admin/11-badge-alert-orange-circle.webp" alt="" width="355" height="357" loading="lazy" decoding="async" />
    </span>
    ZONA PELIGROSA
  </h3>
  <div class="actions">
    <AdminActionButton label="Reset local" action="danger-reset-local" variant="danger" />
    <AdminActionButton label="Limpiar caché" action="danger-clear-cache" variant="danger" />
    <AdminActionButton label="Forzar recálculo" action="danger-recalculate" variant="danger" />
  </div>
</section>

<style>
  .danger-zone {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.75rem;
    border: 1px solid var(--pm-red-500);
    border-radius: var(--pm-radius-md);
    background: rgba(255, 64, 88, 0.08);
  }

  h3 {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--pm-red-400);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .dz-icon {
    display: grid;
    width: 1.25rem;
    height: 1.25rem;
    place-items: center;
    flex-shrink: 0;
  }

  .dz-icon img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
</style>
