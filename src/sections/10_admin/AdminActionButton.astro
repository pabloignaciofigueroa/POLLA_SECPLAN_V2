---
interface Props {
  label: string;
  action: string;
  variant?: "default" | "danger" | "success" | "info";
}

const { label, action, variant = "default" } = Astro.props;
---

<button class="action-button" type="button" data-admin-action={action} data-variant={variant}>
  {label}
</button>

<style>
  .action-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.1rem;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--btn-border, var(--pm-blue-500));
    border-radius: var(--pm-radius-sm);
    background: var(--btn-bg, var(--pm-white));
    color: var(--btn-text, var(--pm-blue-700));
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--pm-transition-fast),
      color var(--pm-transition-fast),
      border-color var(--pm-transition-fast),
      transform var(--pm-transition-fast),
      box-shadow var(--pm-transition-fast);
  }

  .action-button:hover {
    background: var(--btn-hover-bg, var(--pm-blue-500));
    color: var(--btn-hover-text, var(--pm-white));
    transform: translateY(-1px);
  }

  .action-button:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  /* DEFAULT (azul/cian) */
  .action-button[data-variant="default"] {
    --btn-border: var(--pm-blue-500);
    --btn-text: var(--pm-blue-700);
    --btn-hover-bg: linear-gradient(135deg, var(--pm-blue-500), var(--pm-cyan-500));
    --btn-hover-text: var(--pm-white);
  }

  /* DANGER (coral) */
  .action-button[data-variant="danger"] {
    --btn-border: var(--pm-red-500);
    --btn-text: var(--pm-red-600);
    --btn-bg: var(--pm-white);
    --btn-hover-bg: var(--pm-red-500);
    --btn-hover-text: var(--pm-white);
  }

  /* SUCCESS (verde) */
  .action-button[data-variant="success"] {
    --btn-border: var(--pm-green-600);
    --btn-text: var(--pm-green-700);
    --btn-hover-bg: var(--pm-green-500);
    --btn-hover-text: var(--pm-blue-900);
  }

  /* INFO (cian) */
  .action-button[data-variant="info"] {
    --btn-border: var(--pm-cyan-600);
    --btn-text: var(--pm-cyan-600);
    --btn-hover-bg: var(--pm-cyan-500);
    --btn-hover-text: var(--pm-blue-900);
  }

  .action-button[data-pending="true"] {
    opacity: 0.7;
    cursor: progress;
  }

  .action-button[data-confirming="true"] {
    background: var(--pm-red-500);
    color: var(--pm-white);
    box-shadow: 0 0 0 3px rgba(255, 64, 88, 0.18);
  }

  @media (prefers-reduced-motion: reduce) {
    .action-button:hover {
      transform: none;
    }
  }
</style>
