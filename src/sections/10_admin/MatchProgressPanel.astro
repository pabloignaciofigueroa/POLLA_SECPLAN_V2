---
// Avance de partidos con puntos, traido de Estadisticas al Admin pero ADMINISTRABLE:
// permite editar el marcador de un partido finalizado y des-finalizarlo (volverlo a
// pendiente) ante un error humano. Nunca toca predicciones de jugadores (biblia).
// El contenido lo pinta match-progress.client.js (por eso los estilos van is:global
// anclados a [data-match-progress]: el DOM nace en runtime y no recibe el scope Astro).
---

<section class="match-progress" data-match-progress data-animate="fade-up" aria-labelledby="match-progress-title">
  <header class="mp-head">
    <div>
      <span class="mp-eyebrow">RESULTADOS OFICIALES</span>
      <h2 id="match-progress-title">Avance de partidos</h2>
      <p class="mp-sub">Orden correlativo por dia y hora. Aqui puedes corregir o des-finalizar un resultado si te equivocaste.</p>
    </div>
    <p class="mp-feedback" data-match-progress-feedback role="status" aria-live="polite"></p>
  </header>

  <div class="mp-body" data-match-progress-body>
    <p class="mp-loading">Cargando avance de partidos...</p>
  </div>
</section>

<style is:global>
  [data-match-progress] {
    margin-top: 1rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--pm-border-soft, rgba(7, 26, 53, 0.18));
    border-radius: var(--pm-radius-lg, 16px);
    background: var(--pm-white, #fff);
  }
  [data-match-progress] .mp-head {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.8rem;
  }
  [data-match-progress] .mp-eyebrow {
    color: var(--pm-pink-600, #d6246e);
    font-family: var(--font-display, sans-serif);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }
  [data-match-progress] h2 {
    margin: 0.1rem 0;
    font-family: var(--font-display, sans-serif);
    font-size: 1.1rem;
    font-weight: 950;
    color: var(--pm-blue-900, #0b2545);
  }
  [data-match-progress] .mp-sub {
    margin: 0;
    font-size: 0.78rem;
    color: var(--pm-text-soft, #4a5a72);
  }
  [data-match-progress] .mp-feedback {
    margin: 0;
    min-height: 1rem;
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--pm-green-700, #1f7a52);
  }
  [data-match-progress] .mp-grid {
    display: grid;
    grid-template-columns: minmax(0, 18rem) minmax(0, 1fr);
    gap: 0.8rem;
  }
  @media (max-width: 820px) {
    [data-match-progress] .mp-grid { grid-template-columns: 1fr; }
  }

  /* Lista de partidos */
  [data-match-progress] .mp-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    max-height: 26rem;
    overflow-y: auto;
    padding-right: 0.2rem;
  }
  [data-match-progress] .mp-item {
    display: grid;
    grid-template-columns: 2.1rem minmax(0, 1fr) auto;
    gap: 0.5rem;
    align-items: center;
    width: 100%;
    padding: 0.45rem 0.55rem;
    border: 1px solid var(--pm-border-soft, rgba(7, 26, 53, 0.18));
    border-radius: 0.6rem;
    background: var(--pm-white, #fff);
    text-align: left;
    cursor: pointer;
  }
  [data-match-progress] .mp-item:hover { background: var(--pm-panel-soft, #eef2f8); }
  [data-match-progress] .mp-item[aria-pressed="true"] {
    border-color: var(--pm-blue-500, #2f72d6);
    box-shadow: 0 0 0 1px var(--pm-blue-500, #2f72d6) inset;
    background: var(--pm-blue-100, #e3effb);
  }
  [data-match-progress] .mp-item .mp-num {
    font-family: var(--font-display, sans-serif);
    font-size: 0.8rem;
    font-weight: 950;
    color: var(--pm-blue-700, #1f5fa6);
  }
  [data-match-progress] .mp-item .mp-teams {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.74rem;
    font-weight: 800;
    color: var(--pm-blue-900, #0b2545);
  }
  [data-match-progress] .mp-item .mp-state {
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    font-family: var(--font-display, sans-serif);
    font-size: 0.52rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  [data-match-progress] .mp-item .mp-state[data-state="finished"] { background: var(--pm-state-finished-bg, #e7f6ec); color: var(--pm-state-finished-text, #1f7a52); }
  [data-match-progress] .mp-item .mp-state[data-state="live"] { background: var(--pm-state-live-bg, #ffe1e6); color: var(--pm-state-live-text, #c81e3a); }
  [data-match-progress] .mp-item .mp-state[data-state="pending"] { background: var(--pm-panel-soft, #eef2f8); color: var(--pm-text-soft, #4a5a72); }

  /* Detalle */
  [data-match-progress] .mp-detail {
    border: 1px solid var(--pm-border-soft, rgba(7, 26, 53, 0.18));
    border-radius: 0.7rem;
    padding: 0.75rem 0.85rem;
    background: var(--pm-panel-soft, #f5f8fc);
  }
  [data-match-progress] .mp-detail h3 {
    margin: 0 0 0.15rem;
    font-family: var(--font-display, sans-serif);
    font-size: 0.95rem;
    font-weight: 950;
    color: var(--pm-blue-900, #0b2545);
  }
  [data-match-progress] .mp-detail .mp-summary {
    margin: 0 0 0.6rem;
    font-size: 0.74rem;
    color: var(--pm-text-soft, #4a5a72);
  }
  [data-match-progress] table { width: 100%; border-collapse: collapse; }
  [data-match-progress] th, [data-match-progress] td {
    padding: 0.28rem 0.4rem;
    font-size: 0.72rem;
    text-align: left;
    border-bottom: 1px solid var(--pm-border-soft, rgba(7, 26, 53, 0.12));
  }
  [data-match-progress] th {
    font-family: var(--font-display, sans-serif);
    font-weight: 900;
    color: var(--pm-blue-700, #1f5fa6);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.58rem;
  }
  [data-match-progress] td.mp-suma { text-align: right; font-weight: 900; font-variant-numeric: tabular-nums; }
  [data-match-progress] .mp-dot {
    display: inline-block;
    width: 0.5rem; height: 0.5rem;
    margin-right: 0.3rem;
    border-radius: 999px;
    background: var(--pm-panel-soft, #e8edf5);
    vertical-align: middle;
  }
  [data-match-progress] .mp-dot[data-hit-type="lone_wolf"] { background: var(--pm-purple-500, #7c35ff); }
  [data-match-progress] .mp-dot[data-hit-type="exact"] { background: var(--pm-blue-500, #2f72d6); }
  [data-match-progress] .mp-dot[data-hit-type="tendency"] { background: var(--pm-green-500, #16a34a); }

  /* Acciones / editor */
  [data-match-progress] .mp-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.7rem;
  }
  [data-match-progress] .mp-actions button {
    min-height: 2.1rem;
    padding: 0.4rem 0.75rem;
    border-radius: var(--pm-radius-sm, 10px);
    font-family: var(--font-display, sans-serif);
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
  }
  [data-match-progress] .mp-btn-edit { border: 1px solid var(--pm-blue-500, #2f72d6); background: var(--pm-white, #fff); color: var(--pm-blue-700, #1f5fa6); }
  [data-match-progress] .mp-btn-undo { border: 1px solid var(--pm-pink-600, #d6246e); background: var(--pm-white, #fff); color: var(--pm-pink-600, #d6246e); }
  [data-match-progress] .mp-btn-save { border: 1px solid var(--pm-mint-500, #21d99a); background: linear-gradient(135deg, var(--pm-mint-500, #21d99a), var(--pm-cyan-500, #18ddf2)); color: #fff; }
  [data-match-progress] .mp-btn-cancel { border: 1px solid var(--pm-border-soft, rgba(7,26,53,.18)); background: var(--pm-white, #fff); color: var(--pm-text-soft, #4a5a72); }
  [data-match-progress] .mp-actions button:focus-visible { outline: none; box-shadow: var(--pm-focus-ring, 0 0 0 3px rgba(24,221,242,.6)); }

  [data-match-progress] .mp-editor {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.7rem;
    padding: 0.5rem 0.6rem;
    border: 1px dashed var(--pm-blue-500, #2f72d6);
    border-radius: 0.6rem;
  }
  [data-match-progress] .mp-editor .mp-team-edit { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
  [data-match-progress] .mp-editor .mp-stepper { display: flex; align-items: center; gap: 0.3rem; }
  [data-match-progress] .mp-editor .mp-score { min-width: 1.4rem; text-align: center; font-family: var(--font-display, sans-serif); font-size: 1.2rem; font-weight: 950; }
  [data-match-progress] .mp-editor .mp-step {
    width: 1.5rem; height: 1.5rem;
    border: 1px solid var(--pm-blue-500, #2f72d6);
    border-radius: 8px; background: var(--pm-white, #fff);
    color: var(--pm-blue-700, #1f5fa6); font-weight: 950; cursor: pointer;
  }
  [data-match-progress] .mp-editor .mp-step:disabled { opacity: 0.4; cursor: not-allowed; }
  [data-match-progress] .mp-name {
    font-family: var(--font-display, sans-serif);
    font-size: 0.62rem;
    font-weight: 900;
    color: var(--pm-blue-900, #0b2545);
  }
  [data-match-progress] .mp-empty, [data-match-progress] .mp-loading {
    margin: 0; padding: 1rem; font-size: 0.78rem; color: var(--pm-text-soft, #4a5a72);
  }
</style>

<script>
  import "./match-progress.client.js";
</script>
