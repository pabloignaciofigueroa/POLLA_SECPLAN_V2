---
import AdminActionButton from "./AdminActionButton.astro";
import type { AdminDashboardViewModel } from "./admin.logic";

interface Props {
  players: AdminDashboardViewModel["players"];
}

const { players } = Astro.props;

const rows = [
  ["Total registrados", players.totalRegistered],
  ["Confirmados", players.confirmed],
  ["Pendientes", players.pending],
  ["Incompletos", players.incomplete],
];
---

<section class="panel" data-admin-panel="players" aria-labelledby="players-title">
  <header class="panel-head">
    <h2 id="players-title">JUGADORES REGISTRADOS</h2>
  </header>
  <div class="chips" aria-label="Jugadores">
    {players.chips.map((chip) => <span>{chip}</span>)}
    <span>+6</span>
  </div>
  <dl class="rows">
    {rows.map(([label, value]) => (
      <div>
        <dt>{label}</dt>
        <dd>{value}</dd>
      </div>
    ))}
  </dl>
  <div class="actions">
    <AdminActionButton label="Ver jugadores" action="view-players" />
    <AdminActionButton label="Recordar pendientes" action="remind-pending" />
  </div>
</section>

<style>
  .panel { display:flex; flex-direction:column; gap:.65rem; min-width:0; padding:.85rem; border:1px solid var(--color-line); border-radius:var(--radius-md); background:rgba(255,255,255,.78); }
  h2 { margin:0; color:var(--color-text); font-family:var(--font-display); font-size:.86rem; font-weight:950; letter-spacing:.04em; text-transform:uppercase; }
  .chips { display:flex; flex-wrap:wrap; gap:.35rem; }
  .chips span { display:grid; place-items:center; width:1.8rem; height:1.8rem; border:1px solid var(--color-line); border-radius:50%; background:rgba(255,255,255,.72); color:var(--color-text); font-size:.58rem; font-weight:950; }
  .rows { display:flex; flex-direction:column; margin:0; border-top:1px solid var(--color-line); }
  .rows div { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:.75rem; padding:.38rem 0; border-bottom:1px solid var(--color-line); }
  dt, dd { margin:0; font-size:.7rem; font-weight:800; }
  dt { color:var(--color-muted); }
  dd { color:var(--color-text); text-align:right; }
  .actions { display:flex; flex-wrap:wrap; gap:.45rem; margin-top:auto; }
</style>
