---
import type { AdminDashboardViewModel } from "./admin.logic";

interface Props {
  session: AdminDashboardViewModel["session"];
}

const { session } = Astro.props;
---

<article class="session-card" aria-label="Estado de sesión">
  <span class="status-dot" aria-hidden="true"></span>
  <div class="session-copy">
    <span class="status-label">{session.statusLabel}</span>
    <strong class="email">{session.email}</strong>
  </div>
  <div class="avatar" aria-hidden="true">A</div>
  <div class="profile">
    <strong class="name">{session.name}</strong>
    <span class="role">{session.role}</span>
  </div>
</article>

<style>
  /* ANTI-CLS: conservar min-height del session card */
  .session-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    padding: 0.85rem 0.95rem;
    border: 1px solid var(--pm-mint-500);
    border-radius: var(--pm-radius-lg);
    background: linear-gradient(135deg, var(--pm-white), var(--pm-panel-soft));
    min-width: 0;
    min-height: 4.4rem;
    box-shadow: 0 12px 30px rgba(33, 217, 154, 0.18);
  }

  .status-dot {
    width: 0.8rem;
    height: 0.8rem;
    border: 2px solid var(--pm-mint-500);
    border-radius: 50%;
    background: var(--pm-mint-500);
    box-shadow: 0 0 10px var(--pm-mint-500);
    animation: pulseDot 1.6s ease-in-out infinite;
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.85); }
  }

  .session-copy,
  .profile {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .status-label {
    color: var(--pm-green-700);
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .email,
  .name {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .avatar {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--pm-blue-500), var(--pm-cyan-500));
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 950;
    box-shadow: 0 4px 12px rgba(18, 109, 255, 0.32);
  }

  .role {
    color: var(--pm-text-soft);
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 560px) {
    .session-card {
      grid-template-columns: auto minmax(0, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-dot {
      animation: none;
    }
  }
</style>
