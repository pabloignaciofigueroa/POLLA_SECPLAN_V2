---
import AdminActionButton from "./AdminActionButton.astro";

interface Props {
  count: number;
}

const { count } = Astro.props;
---

<section class="panel empty-panel" data-admin-panel="requests" aria-labelledby="requests-title">
  <header class="panel-head">
    <h2 id="requests-title">SOLICITUDES PENDIENTES</h2>
  </header>
  <div class="empty">
    <strong>{count}</strong>
    <p>No hay solicitudes pendientes</p>
    <span>Cuando lleguen aparecerán aquí.</span>
  </div>
  <AdminActionButton label="Ver bandeja" action="view-requests" />
</section>

<style>
  .panel { display:flex; flex-direction:column; gap:.65rem; min-width:0; padding:.85rem; border:1px solid var(--color-line); border-radius:var(--radius-md); background:rgba(255,255,255,.78); }
  h2 { margin:0; color:var(--color-text); font-family:var(--font-display); font-size:.86rem; font-weight:950; letter-spacing:.04em; text-transform:uppercase; }
  .empty { display:grid; place-items:center; gap:.25rem; min-height:8rem; text-align:center; }
  .empty strong { color:var(--color-text); font-family:var(--font-display); font-size:2.4rem; font-weight:950; line-height:1; }
  .empty p, .empty span { margin:0; font-size:.76rem; font-weight:800; }
  .empty span { color:var(--color-muted); }
</style>
