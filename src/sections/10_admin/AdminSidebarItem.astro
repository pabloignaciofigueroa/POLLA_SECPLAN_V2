---
interface Props {
  label: string;
  icon: string;
  active?: boolean;
}

const { label, icon, active = false } = Astro.props;
---

<button
  class="sidebar-item"
  type="button"
  data-admin-tab={label}
  data-active={active ? "true" : "false"}
  aria-pressed={active ? "true" : "false"}
>
  <span class="icon" aria-hidden="true">{icon}</span>
  <span>{label}</span>
</button>

<style>
  .sidebar-item {
    display: grid;
    grid-template-columns: 1.55rem minmax(0, 1fr);
    gap: 0.55rem;
    align-items: center;
    width: 100%;
    min-height: 2.45rem;
    padding: 0.45rem 0.65rem;
    border: 1px solid transparent;
    border-radius: var(--pm-radius-sm);
    background: transparent;
    color: rgba(255, 255, 255, 0.78);
    font: inherit;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-align: left;
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--pm-transition-fast),
      border-color var(--pm-transition-fast),
      color var(--pm-transition-fast);
  }

  .sidebar-item:hover {
    background: rgba(24, 221, 242, 0.1);
    border-color: rgba(24, 221, 242, 0.4);
    color: var(--pm-white);
  }

  .sidebar-item:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  .sidebar-item[data-active="true"] {
    background: var(--pm-yellow-500);
    border-color: var(--pm-yellow-600);
    color: var(--pm-blue-900);
    box-shadow: 0 0 14px var(--pm-gold-glow);
  }

  .icon {
    display: grid;
    place-items: center;
    width: 1.55rem;
    height: 1.55rem;
    border-radius: var(--pm-radius-sm);
    background: rgba(255, 255, 255, 0.08);
    color: var(--pm-cyan-400);
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 950;
  }

  .sidebar-item[data-active="true"] .icon {
    background: rgba(7, 23, 53, 0.18);
    color: var(--pm-blue-900);
  }
</style>
