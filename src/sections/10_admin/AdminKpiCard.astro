---
interface Props {
  icon: string;
  title: string;
  value: string | number;
  helper: string;
}

const { icon, title, value, helper } = Astro.props;
---

<article class="kpi-card" data-kpi-card data-icon={icon}>
  <div class="icon" aria-hidden="true">{icon}</div>
  <h3>{title}</h3>
  <p class="value">{value}</p>
  <p class="helper">{helper}</p>
</article>

<style>
  .kpi-card {
    position: relative;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.45rem;
    min-width: 0;
    min-height: 7.5rem;
    padding: 0.75rem 0.75rem 0.7rem;
    border: 1px solid var(--kpi-border, var(--pm-blue-100));
    border-radius: var(--pm-radius-md);
    background: var(--pm-white);
    overflow: hidden;
    box-shadow: var(--pm-shadow-soft);
    transition: transform var(--pm-transition-fast), box-shadow var(--pm-transition-fast);
  }

  .kpi-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--kpi-accent, var(--pm-blue-500));
  }

  .kpi-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--kpi-glow, var(--pm-shadow-blue));
  }

  /* Categorias por icono */
  .kpi-card[data-icon="JG"] { --kpi-accent: var(--pm-blue-500);   --kpi-border: var(--pm-blue-100);   --kpi-glow: var(--pm-shadow-blue); }
  .kpi-card[data-icon="CT"] { --kpi-accent: var(--pm-green-500);  --kpi-border: var(--pm-green-100);  --kpi-glow: 0 16px 36px rgba(34, 197, 94, 0.28); }
  .kpi-card[data-icon="PR"] { --kpi-accent: var(--pm-cyan-500);   --kpi-border: var(--pm-cyan-200);   --kpi-glow: var(--pm-shadow-cyan); }
  .kpi-card[data-icon="SO"] { --kpi-accent: var(--pm-purple-500); --kpi-border: var(--pm-purple-200); --kpi-glow: var(--pm-shadow-purple); }
  .kpi-card[data-icon="RO"] { --kpi-accent: var(--pm-orange-500); --kpi-border: var(--pm-orange-100); --kpi-glow: var(--pm-shadow-orange); }
  .kpi-card[data-icon="OK"] { --kpi-accent: var(--pm-mint-500);   --kpi-border: rgba(33, 217, 154, 0.28); --kpi-glow: 0 16px 36px rgba(33, 217, 154, 0.28); }

  .icon {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: var(--pm-radius-sm);
    background: var(--kpi-accent, var(--pm-blue-500));
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 950;
  }

  .kpi-card[data-icon="RO"] .icon,
  .kpi-card[data-icon="CT"] .icon,
  .kpi-card[data-icon="OK"] .icon {
    color: var(--pm-blue-900);
  }

  h3 {
    margin: 0;
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 950;
    line-height: 1.15;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .value {
    margin: 0;
    color: var(--kpi-accent, var(--pm-blue-500));
    font-family: var(--font-score);
    font-variant-numeric: tabular-nums;
    font-size: clamp(1.5rem, 2.4vw, 2.1rem);
    font-weight: 800;
    line-height: 1;
  }

  .helper {
    margin: 0;
    color: var(--pm-text-soft);
    font-size: 0.68rem;
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .kpi-card:hover {
      transform: none;
    }
  }
</style>
