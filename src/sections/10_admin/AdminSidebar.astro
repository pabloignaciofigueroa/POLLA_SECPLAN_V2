---
import AdminSidebarItem from "./AdminSidebarItem.astro";
import DangerousZone from "./DangerousZone.astro";

const items = [
  ["Dashboard", "DB"],
  ["Jugadores", "JG"],
  ["Predicciones", "PR"],
  ["Solicitudes", "SO"],
  ["Resultados oficiales", "RO"],
  ["Base de datos", "BD"],
  ["Exportar / Backup", "BK"],
  ["Bitácora", "BT"],
  ["Sistema", "SY"],
];
---

<aside class="admin-sidebar" aria-label="Administración">
  <div class="sidebar-head">
    <p>ADMINISTRACIÓN</p>
  </div>

  <nav class="sidebar-nav" aria-label="Menú administrativo">
    {items.map(([label, icon], index) => (
      <AdminSidebarItem label={label} icon={icon} active={index === 0} />
    ))}
  </nav>

  <DangerousZone />

  <div class="sidebar-footer">
    <div class="brand-mark" aria-hidden="true">
      <img src="/assets/polla-mundialera/sections/10_admin/19-shield-secplan-blue-gold-star.webp" alt="" width="1254" height="1254" loading="lazy" decoding="async" />
    </div>
    <div>
      <strong>Polla Mundialera SECPLAN 2026</strong>
      <span>Centro de control administrativo</span>
    </div>
  </div>

  <p class="connection"><span aria-hidden="true"></span> Conexión estable</p>
</aside>

<style>
  .admin-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-width: 0;
    padding: clamp(0.85rem, 1.4vw, 1.1rem);
    border: 1px solid var(--pm-navbar-border);
    border-radius: var(--pm-radius-lg);
    background: linear-gradient(180deg, var(--pm-navbar-bg), var(--pm-navbar-bg-2));
    color: var(--pm-white);
    box-shadow: var(--pm-shadow-blue);
  }

  .sidebar-head p {
    margin: 0;
    color: var(--pm-cyan-400);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .sidebar-footer {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.55rem;
    align-items: center;
    margin-top: auto;
    padding: 0.75rem;
    border: 1px solid rgba(24, 221, 242, 0.28);
    border-radius: var(--pm-radius-md);
    background: rgba(255, 255, 255, 0.06);
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
  }

  .brand-mark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 4px 10px rgba(7, 23, 53, 0.35));
  }

  .sidebar-footer strong,
  .sidebar-footer span {
    display: block;
  }

  .sidebar-footer strong {
    color: var(--pm-white);
    font-family: var(--font-display);
    font-size: 0.72rem;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .sidebar-footer span {
    margin-top: 0.25rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.68rem;
    font-weight: 700;
  }

  .connection {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    color: var(--pm-mint-500);
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .connection span {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--pm-mint-500);
    box-shadow: 0 0 8px var(--pm-mint-500);
    animation: pulseDot 1.6s ease-in-out infinite;
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.55; transform: scale(0.85); }
  }

  @media (max-width: 980px) {
    .sidebar-nav {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .sidebar-nav {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .connection span {
      animation: none;
    }
  }
</style>
