---
// Seccion 12_admin — ADMIN LOCAL de la llave eliminatoria. Sin red, sin login (modo local).
// Permite: (1) ASIGNAR los clasificados de placeholders (1L/2K/3CEFHI -> equipo real) y
// (2) CARGAR resultados (marcador + quien avanza). Escribe en localStorage (polla:knockoutResults);
// /fixture, /predicciones y /tabla reaccionan en vivo. El seed commiteado es knockout-results.json.
import knockoutData from "../../data/knockout-matches.json";
import knockoutTeams from "../../data/knockout-teams.json";
import teamsData from "../../data/teams.json";
import seed from "../../data/knockout-results.json";
import { sortBySlot } from "../../lib/knockout/model";
import type { KnockoutMatch } from "../../lib/knockout/model";

const allMatches = sortBySlot(knockoutData.matches as KnockoutMatch[]);
const rounds = knockoutData.rounds as { round: string; roundLabel: string }[];

// Placeholders asignables = slots no concretos de knockout-teams.json.
const placeholders = (knockoutTeams.slots as any[]).filter((s) => !s.concrete);
// Equipos concretos (opciones de asignacion).
const teamOptions = (knockoutTeams.slots as any[])
  .filter((s) => s.concrete)
  .map((s) => ({ code: s.code, name: s.name }));

const teamsLite = (teamsData as any[]).map((t) => ({ code: t.shortCode, name: t.name, shortCode: t.shortCode, flag: t.flag }));
const clientPayload = {
  matches: allMatches,
  teams: teamsLite,
  seedAssignments: (seed as any).slotAssignments ?? {},
  seedResults: (seed as any).results ?? [],
};
---

<section class="adm" id="admin" data-section="admin">
  <!-- Candado: el panel no se muestra hasta validar la contraseña (hash en cliente). -->
  <div class="adm-gate" data-admin-gate>
    <form class="adm-gate-card" data-admin-gate-form novalidate>
      <p class="adm-gate-eyebrow">admin · secplan 2026</p>
      <h1 class="adm-gate-title">Acceso protegido</h1>
      <input
        class="adm-gate-input"
        type="password"
        data-admin-pass
        autocomplete="current-password"
        placeholder="Contraseña"
        aria-label="Contraseña de admin"
      />
      <button type="submit" class="adm-gate-btn">Entrar</button>
      <p class="adm-gate-error" data-admin-error role="alert" hidden></p>
    </form>
  </div>

  <div class="adm-shell" data-admin-panel hidden>
    <header class="adm-hero">
      <p class="adm-eyebrow" data-adm-mode>admin · modo local</p>
      <h1 class="adm-title">Resultados de la llave</h1>
      <div class="adm-hero-actions">
        <button type="button" class="adm-clear" data-adm-clear>Borrar resultados locales</button>
        <button type="button" class="adm-logout" data-admin-logout>Cerrar sesión</button>
      </div>
    </header>

    <section class="adm-block">
      <h2 class="adm-block-title">1 · Asignar clasificados (plazas por definir)</h2>
      <div class="adm-assign-grid">
        {placeholders.map((ph) => (
          <label class="adm-assign">
            <span class="adm-assign-code">{ph.name}</span>
            <select data-adm-assign={ph.code}>
              <option value="">— sin asignar —</option>
              {teamOptions.map((t) => <option value={t.code}>{t.name}</option>)}
            </select>
          </label>
        ))}
      </div>
    </section>

    <section class="adm-block">
      <h2 class="adm-block-title">2 · Cargar resultados</h2>
      {rounds.map((rnd) => {
        const matchEls = allMatches.filter((m) => m.round === rnd.round).map((m) => (
          <div class="adm-match" data-adm-match={m.id}>
            <span class="adm-match-id">{m.id}</span>
            <span class="adm-team" data-adm-name="home">—</span>
            <span class="adm-stepper">
              <button type="button" class="adm-step" data-adm-step="home" data-dir="-1" aria-label={`Menos gol local ${m.id}`}>−</button>
              <input class="adm-score" type="number" inputmode="numeric" min="0" data-adm-score="home" aria-label={`Goles local ${m.id}`} />
              <button type="button" class="adm-step" data-adm-step="home" data-dir="1" aria-label={`Más gol local ${m.id}`}>+</button>
            </span>
            <span class="adm-vs">-</span>
            <span class="adm-stepper">
              <button type="button" class="adm-step" data-adm-step="away" data-dir="-1" aria-label={`Menos gol visita ${m.id}`}>−</button>
              <input class="adm-score" type="number" inputmode="numeric" min="0" data-adm-score="away" aria-label={`Goles visita ${m.id}`} />
              <button type="button" class="adm-step" data-adm-step="away" data-dir="1" aria-label={`Más gol visita ${m.id}`}>+</button>
            </span>
            <span class="adm-team adm-team-away" data-adm-name="away">—</span>
            <span class="adm-adv">
              <span class="adm-adv-label" data-adm-adv-label hidden>⚖ Avanza por penales:</span>
              <button type="button" class="adm-adv-btn" data-adm-winner="home" aria-pressed="false"><span data-adm-pick="home">LOC</span></button>
              <button type="button" class="adm-adv-btn" data-adm-winner="away" aria-pressed="false"><span data-adm-pick="away">VIS</span></button>
            </span>
            <span class="adm-actions">
              <button type="button" class="adm-update" data-adm-update>Actualizar</button>
              <button type="button" class="adm-finish" data-adm-finish>Finalizar</button>
              <span class="adm-state" data-adm-state hidden>En vivo</span>
            </span>
          </div>
        ));
        // 16avos (R32) y octavos (R16) ya se jugaron: se colapsan por defecto para enfocar cuartos.
        // El resto queda expandido. Los data-adm-match siguen en el DOM (el cliente los hidrata).
        return (rnd.round === "R32" || rnd.round === "R16") ? (
          <details class="adm-round adm-round--collapsible">
            <summary class="adm-round-summary">
              {rnd.roundLabel}
              <span class="adm-round-hint">ya jugados · toca para ver/ocultar</span>
            </summary>
            <div class="adm-matches">{matchEls}</div>
          </details>
        ) : (
          <div class="adm-round">
            <h3 class="adm-round-title">{rnd.roundLabel}</h3>
            <div class="adm-matches">{matchEls}</div>
          </div>
        );
      })}
    </section>
  </div>

  <script type="application/json" data-admin-payload set:html={JSON.stringify(clientPayload)} />
  <script>
    import "./admin.gate.client.js";
    import "./admin.knockout.client.js";
  </script>
</section>

<style>
  .adm {
    --section-accent: var(--pm-sec-admin-a);
    --section-accent-2: var(--pm-sec-admin-b);
    position: relative;
    min-height: calc(100svh - var(--layout-header-height));
    padding: clamp(1.2rem, 3vw, 2.4rem);
    background-image: image-set(
      url("/assets/backgrounds/avif/10_admin_background.avif") type("image/avif"),
      url("/assets/backgrounds/webp/10_admin_background.webp") type("image/webp"));
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--pm-text-main);
    font-family: var(--font-ui);
  }
  .adm-shell { max-width: 70rem; margin-inline: auto; display: flex; flex-direction: column; gap: clamp(1.2rem, 3vw, 2rem); }
  .adm-hero { display: flex; flex-direction: column; align-items: flex-start; gap: 0.4rem; }
  .adm-eyebrow { margin: 0; padding: 0.25rem 0.8rem; border-radius: 999px; background: color-mix(in srgb, var(--section-accent) 16%, var(--pm-white)); color: var(--pm-text-main); border: 1px solid color-mix(in srgb, var(--section-accent) 38%, var(--pm-white)); font-size: 0.66rem; font-weight: 850; letter-spacing: 0.08em; text-transform: uppercase; }
  .adm-title { margin: 0; font-family: var(--font-display); font-weight: 950; font-size: clamp(1.8rem, 4.4vw, 3rem); text-transform: uppercase; color: var(--pm-blue-900); }
  .adm-hero-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.2rem; }
  .adm-clear { padding: 0.45rem 0.9rem; border: 1px solid var(--pm-state-error-border, #ef4444); border-radius: var(--pm-radius-pill); background: var(--pm-white); color: var(--pm-state-error-soft-text, #b91c1c); font-family: var(--font-display); font-weight: 800; font-size: 0.78rem; cursor: pointer; }
  .adm-logout { padding: 0.45rem 0.9rem; border: 1px solid var(--pm-border-blue); border-radius: var(--pm-radius-pill); background: var(--pm-white); color: var(--pm-blue-800); font-family: var(--font-display); font-weight: 800; font-size: 0.78rem; cursor: pointer; }
  .adm-logout:hover { border-color: var(--pm-cyan-500); }

  /* ===== Candado de acceso (cubre el panel hasta validar) ===== */
  .adm-gate { position: absolute; inset: 0; z-index: 5; display: grid; place-items: center; padding: 1.5rem; }
  .adm-gate[hidden] { display: none; }
  .adm-gate-card { display: flex; flex-direction: column; gap: 0.7rem; width: min(100%, 22rem); padding: clamp(1.4rem, 3vw, 2.2rem); border: 1px solid var(--pm-border-soft); border-radius: var(--pm-radius-lg, 18px); background: var(--pm-white); box-shadow: 0 18px 50px rgba(7, 23, 53, 0.22); text-align: center; }
  .adm-gate-eyebrow { margin: 0; font-family: var(--font-display); font-weight: 850; font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--pm-text-soft); }
  .adm-gate-title { margin: 0 0 0.3rem; font-family: var(--font-display); font-weight: 950; font-size: clamp(1.4rem, 3.2vw, 2rem); text-transform: uppercase; color: var(--pm-blue-900); }
  .adm-gate-input { width: 100%; padding: 0.65rem 0.9rem; border: 2px solid var(--pm-border-blue); border-radius: var(--pm-radius-md); background: var(--pm-white); color: var(--pm-blue-900); font-family: var(--font-display); font-weight: 700; font-size: 1rem; text-align: center; }
  .adm-gate-input:focus-visible { outline: none; box-shadow: var(--pm-focus-ring, 0 0 0 3px rgba(18, 109, 255, 0.4)); }
  .adm-gate-btn { padding: 0.65rem 1rem; border: none; border-radius: var(--pm-radius-pill); background: linear-gradient(135deg, var(--pm-yellow-500, #facc15), var(--pm-orange-500, #fb923c)); color: var(--pm-blue-950, #06122a); font-family: var(--font-display); font-weight: 900; font-size: 0.9rem; letter-spacing: 0.04em; text-transform: uppercase; cursor: pointer; transition: transform var(--pm-transition-fast); }
  .adm-gate-btn:hover { transform: translateY(-1px); }
  .adm-gate-btn:focus-visible { outline: none; box-shadow: var(--pm-focus-ring-yellow, 0 0 0 3px rgba(250, 204, 21, 0.5)); }
  .adm-gate-error { margin: 0; color: var(--pm-state-error-soft-text, #b91c1c); font-family: var(--font-display); font-weight: 800; font-size: 0.78rem; }
  .adm-shell[hidden] { display: none; }
  .adm-block { display: flex; flex-direction: column; gap: 0.8rem; padding: clamp(0.9rem, 2vw, 1.4rem); border: 1px solid var(--pm-border-soft); border-radius: var(--pm-radius-md); background: var(--pm-panel-soft, #f8fbff); }
  .adm-block-title { margin: 0; font-family: var(--font-display); font-weight: 900; font-size: 1rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--pm-blue-900); }
  .adm-assign-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr)); gap: 0.6rem; }
  .adm-assign { display: flex; flex-direction: column; gap: 0.2rem; }
  .adm-assign-code { font-family: var(--font-display); font-weight: 800; font-size: 0.72rem; color: var(--pm-text-soft); text-transform: uppercase; }
  .adm-assign select, .adm-score { border: 2px solid var(--pm-border-blue); border-radius: var(--pm-radius-sm); background: var(--pm-white); color: var(--pm-blue-900); font-family: var(--font-display); font-weight: 700; }
  .adm-assign select { padding: 0.4rem 0.5rem; }
  .adm-round { display: flex; flex-direction: column; gap: 0.4rem; margin-top: 0.6rem; }
  .adm-round-title { margin: 0; font-family: var(--font-display); font-weight: 800; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--pm-purple-700, #6d28d9); }
  /* 16avos (R32) + octavos (R16) colapsables: <details> cerrado por defecto para enfocar cuartos. */
  .adm-round--collapsible[open] { gap: 0.4rem; }
  .adm-round-summary {
    cursor: pointer; list-style: none; display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-display); font-weight: 800; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--pm-purple-700, #6d28d9);
    padding: 0.5rem 0.7rem; border-radius: var(--pm-radius-sm);
    background: var(--pm-purple-100, #f1ecff); border: 1px dashed var(--pm-purple-300, #c9b8ff);
  }
  .adm-round-summary::-webkit-details-marker { display: none; }
  .adm-round-summary::before { content: "▸"; font-size: 0.8rem; transition: transform var(--pm-transition-fast); }
  .adm-round--collapsible[open] .adm-round-summary::before { transform: rotate(90deg); }
  .adm-round-summary:hover { border-color: var(--pm-purple-500, #7c3aed); }
  .adm-round-summary:focus-visible { outline: none; box-shadow: var(--pm-focus-ring, 0 0 0 3px rgba(18, 109, 255, 0.4)); }
  .adm-round-hint { font-weight: 700; font-size: 0.62rem; letter-spacing: 0.02em; text-transform: none; color: var(--pm-text-soft); }
  .adm-round--collapsible .adm-matches { margin-top: 0.4rem; }
  .adm-matches { display: flex; flex-direction: column; gap: 0.35rem; }
  .adm-match { display: flex; flex-wrap: wrap; align-items: center; gap: 0.45rem; padding: 0.4rem 0.6rem; border: 1px solid var(--pm-border-soft); border-radius: var(--pm-radius-sm); background: var(--pm-white); }
  .adm-match[data-played="true"] { border-color: var(--pm-state-completed-border, #16a34a); }
  .adm-match-id { flex: 0 0 2.4rem; font-family: var(--font-display); font-weight: 900; font-size: 0.7rem; color: var(--pm-blue-700); }
  .adm-team { flex: 1 1 5rem; min-width: 3.5rem; font-family: var(--font-display); font-weight: 800; font-size: 0.82rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--pm-blue-900); text-align: right; }
  .adm-team-away { text-align: left; }
  /* Stepper de marcador: −  [input]  + */
  .adm-stepper { display: inline-flex; align-items: center; gap: 0.2rem; flex: 0 0 auto; }
  .adm-step { width: 1.55rem; height: 2.1rem; display: grid; place-items: center; border: 1px solid var(--pm-border-blue); border-radius: var(--pm-radius-sm); background: var(--pm-white); color: var(--pm-blue-700); font-family: var(--font-display); font-weight: 900; font-size: 1.05rem; line-height: 1; cursor: pointer; }
  .adm-step:hover:not(:disabled) { border-color: var(--pm-cyan-500); background: color-mix(in srgb, var(--pm-cyan-500) 12%, #fff); }
  .adm-step:active:not(:disabled) { transform: scale(0.94); }
  .adm-step:disabled { opacity: 0.4; cursor: not-allowed; }
  /* Acciones: Actualizar (cian; resalta si hay cambios sin guardar) + Finalizar (verde) + estado. */
  .adm-actions { display: inline-flex; align-items: center; gap: 0.35rem; flex-wrap: wrap; }
  .adm-update, .adm-finish { padding: 0.34rem 0.75rem; border-radius: var(--pm-radius-pill); border: 2px solid; font-family: var(--font-display); font-weight: 900; font-size: 0.66rem; letter-spacing: 0.05em; text-transform: uppercase; cursor: pointer; transition: transform var(--pm-transition-fast), box-shadow var(--pm-transition-fast), background var(--pm-transition-fast); }
  .adm-update { border-color: var(--pm-cyan-600); background: var(--pm-white); color: var(--pm-cyan-700, #0e7490); }
  .adm-update[data-dirty="true"] { background: var(--pm-yellow-400, #fbbf24); border-color: var(--pm-yellow-600, #d97706); color: var(--pm-blue-950, #06122a); box-shadow: 0 0 0 3px rgba(250, 204, 21, 0.3); }
  .adm-finish { border-color: var(--pm-green-600, #16a34a); background: var(--pm-green-500, #22c55e); color: #fff; }
  .adm-finish:hover:not(:disabled) { filter: brightness(1.06); }
  .adm-update:active:not(:disabled), .adm-finish:active:not(:disabled) { transform: scale(0.97); }
  .adm-update:disabled, .adm-finish:disabled { opacity: 0.45; cursor: not-allowed; }
  .adm-update:focus-visible, .adm-finish:focus-visible, .adm-step:focus-visible { outline: none; box-shadow: var(--pm-focus-ring, 0 0 0 3px rgba(18, 109, 255, 0.4)); }
  .adm-score { width: 2.8rem; height: 2.2rem; text-align: center; font-family: var(--font-score); font-size: 1.05rem; font-weight: 800; }
  .adm-vs { text-align: center; color: var(--pm-text-soft); font-weight: 800; }
  .adm-adv { display: inline-flex; align-items: center; gap: 0.25rem; flex-wrap: wrap; }
  .adm-adv-label { font-family: var(--font-display); font-weight: 900; font-size: 0.58rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--pm-orange-600, #c2410c); }
  .adm-adv-label[hidden] { display: none; }
  .adm-adv-btn { padding: 0.2rem 0.5rem; border: 2px solid var(--pm-border-blue); border-radius: var(--pm-radius-pill); background: var(--pm-white); color: var(--pm-blue-800); font-family: var(--font-display); font-weight: 800; font-size: 0.66rem; cursor: pointer; }
  .adm-adv-btn[data-active="true"] { background: var(--pm-cyan-500); border-color: var(--pm-cyan-600); color: var(--pm-blue-900); }
  .adm-adv-btn:disabled { opacity: 0.45; cursor: not-allowed; }
  /* Empate (penales) sin definir: resalta el bloque para que el admin elija quién avanza. */
  .adm-match[data-adm-tie="true"] .adm-adv { padding: 0.12rem 0.3rem; border-radius: var(--pm-radius-pill); background: color-mix(in srgb, var(--pm-orange-500, #fb923c) 14%, #fff); box-shadow: 0 0 0 2px color-mix(in srgb, var(--pm-orange-500, #fb923c) 42%, transparent); }
  /* Estado del cruce: EN VIVO (rojo) / FINALIZADO (verde). Visible solo con marcador cargado. */
  .adm-state { padding: 0.22rem 0.6rem; border-radius: var(--pm-radius-pill); border: 1px solid var(--pm-border-soft); background: var(--pm-white); font-family: var(--font-display); font-weight: 900; font-size: 0.6rem; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; white-space: nowrap; }
  .adm-state[hidden] { display: none; }
  .adm-state[data-state="live"] { color: #fff; background: var(--pm-red-500); border-color: var(--pm-red-500); }
  .adm-state[data-state="final"] { color: var(--pm-green-700); background: var(--pm-green-100); border-color: var(--pm-state-completed-border, #16a34a); }
  /* Estados completos (DESIGN.md §4) */
  .adm-adv-btn:hover:not(:disabled) { border-color: var(--pm-cyan-500); }
  .adm-adv-btn:active:not(:disabled) { transform: scale(0.97); }
  .adm-clear:hover { background: var(--pm-state-error-soft-bg, #fee2e2); }
  .adm-clear:active { transform: scale(0.97); }
  .adm-clear:focus-visible, .adm-adv-btn:focus-visible, .adm-assign select:focus-visible, .adm-score:focus-visible { outline: none; box-shadow: var(--pm-focus-ring, 0 0 0 3px rgba(18,109,255,0.4)); }
  @media (prefers-reduced-motion: reduce) { .adm-adv-btn, .adm-clear { transition: none; } }
  @media (max-width: 720px) {
    .adm-match { justify-content: center; }
    .adm-team { flex-basis: 4rem; }
  }
</style>
