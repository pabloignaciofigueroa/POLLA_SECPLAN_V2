---
import BaseLayout from "../layouts/BaseLayout.astro";
import WireframeBox from "../components/wireframe/WireframeBox.astro";
import WireframeGrid from "../components/wireframe/WireframeGrid.astro";
import WireframeLabel from "../components/wireframe/WireframeLabel.astro";

const sections = [
  {
    code: "01_inicio",
    label: "Inicio",
    state: "skeleton",
    zones: ["section-shell", "background-energy-layer", "hero-copy-block", "trophy-stage", "cta-cluster", "bottom-status-bar"],
    components: ["HeroCopy", "TrophyStage", "ArcadeButton"],
    assets: ["background_inicio_clean.webp", "trophy_worldcup.png"],
    data: [],
  },
  {
    code: "02_reglas",
    label: "Reglas",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-stadium-layer", "rules-hero-header", "rules-cards-grid", "scoring-panel", "challenge-message-panel", "action-panel", "fair-play-footer"],
    components: ["RulesHeroHeader", "RulesCardsGrid", "RuleCard", "ScoringPanel", "ChallengeMessage", "RulesActionPanel", "FairPlayFooter"],
    assets: ["backgrounds/bg-02-reglas-clean.webp", "ui/rules-icons/*"],
    data: ["rules local array", "scoringRules local array"],
  },
  {
    code: "03_jugador",
    label: "Jugador",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-energy-layer", "player-hero-panel", "selected-player-card-large", "identity-message-card", "players-grid-panel", "action-zone", "warning-note"],
    components: ["PlayerHeroPanel", "SelectedPlayerCard", "IdentityMessageCard", "PlayersGrid", "PlayerCard", "PlayerSelectionCTA", "PlayerWarningNote"],
    assets: ["players/* (15 avatars)", "backgrounds/bg-03-jugador-clean.webp"],
    data: ["players.json"],
  },
  {
    code: "04_predicciones",
    label: "Predicciones",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-energy-layer", "prediction-hero-header", "progress-summary-grid", "group-tabs-navigation", "matches-panel", "qualified-panel", "helper-actions-panel", "bottom-navigation-bar"],
    components: ["PredictionHeroHeader", "ProgressSummaryGrid", "GroupTabs", "MatchesPanel", "MatchPredictionRow", "ScoreInput", "QualifiedPanel", "PredictionBottomBar"],
    assets: ["flags/", "backgrounds/bg-04-predicciones-clean.webp"],
    data: ["fixture.json", "groups.json", "players.json", "predictions.json"],
  },
  {
    code: "05_tabla",
    label: "Tabla",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-energy-layer", "tabla-hero", "ranking-table", "live-match-card", "player-predictions-panel", "next-match-card", "accuracy-legend"],
    components: ["TablaHero", "RankingTable", "RankingRow", "MovementIndicator", "LiveMatchCard", "PlayerPredictionsPanel", "AccuracyBar", "NextMatchCard", "AccuracyLegend"],
    assets: ["players/", "flags/", "backgrounds/bg-05-tabla-clean.webp"],
    data: ["players.json", "fixture.json", "results.json", "scoring-rules.json", "predictions.json"],
  },
  {
    code: "06_proximo_partido",
    label: "Próximo Partido",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-energy-layer", "match-hero-header", "match-meta-strip", "featured-match-layout", "team-match-card", "versus-center", "match-reading-panel", "match-context-panel", "next-action-panel", "deadline-notice"],
    components: ["MatchHeroHeader", "MatchMetaStrip", "FeaturedMatchLayout", "TeamMatchCard", "VersusCenter", "HistoricalMatchupCard", "MatchReadingPanel", "MatchContextPanel", "NextActionPanel", "PredictionDeadlineNotice"],
    assets: ["flags/", "backgrounds/bg-06-proximo-partido-clean.webp"],
    data: ["fixture.json", "teams.json", "match-h2h-fifa-wikipedia.json", "getRelevantMatches()"],
  },
  {
    code: "07_fixture",
    label: "Fixture",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-energy-layer", "fixture-hero", "fixture-summary-cards", "fixture-filters", "fixture-list-panel", "selected-match-panel", "day-agenda-panel", "match-info-panel", "timezone-notice", "notification-cta"],
    components: ["FixtureHero", "FixtureSummaryCards", "FixtureFilters", "FixtureListPanel", "FixtureDayGroup", "FixtureMatchRow", "SelectedMatchPanel", "SelectedMatchHero", "DayAgendaPanel", "MatchInfoPanel", "TimezoneNotice", "NotificationCTA"],
    assets: ["flags/", "backgrounds/07_fixture_background.png"],
    data: ["fixture.json", "groups.json", "getRelevantMatches()"],
  },
  {
    code: "08_equipos",
    label: "Equipos",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-energy-layer", "equipos-hero", "teams-summary-strip", "group-filter-chips", "teams-album", "group-section", "team-card", "confederation-strip", "team-detail-modal"],
    components: ["EquiposHero", "TeamsSummaryStrip", "GroupFilterChips", "TeamsAlbum", "GroupSection", "TeamCard", "ConfederationStrip", "TeamDetailModal"],
    assets: ["flags/", "players/", "backgrounds/08_equipos_background.png"],
    data: ["teams.json", "equipos-info.json", "polla:favoriteTeams (localStorage)"],
  },
  {
    code: "09_estadisticas",
    label: "Estadísticas",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-energy-layer", "unlocked-banner", "stats-hero-locked", "lock-orb-visual", "stats-progress-card", "unlock-benefits-panel", "locked-preview-panel", "anti-copy-notice"],
    components: ["StatsHeroLocked", "LockOrbVisual", "StatsProgressCard", "UnlockBenefitsPanel", "UnlockBenefitCard", "LockedPreviewPanel", "LockedPreviewCard", "AntiCopyNotice", "UnlockedBanner"],
    assets: ["backgrounds/09_estadisticas_background.png", "trophy/lock-orb (futuro)"],
    data: ["polla:predictions (localStorage)", "polla:selectedPlayerId (localStorage)", "TOTAL_PREDICTIONS=72"],
  },
  {
    code: "10_admin",
    label: "Admin",
    state: "wireframe-implemented",
    zones: ["section-shell", "background-energy-layer", "admin-sidebar", "dangerous-zone", "admin-hero-header", "session-status-card", "summary-kpi-grid", "management-grid", "activity-log"],
    components: ["AdminSidebar", "AdminSidebarItem", "DangerousZone", "AdminHeroHeader", "SessionStatusCard", "AdminKpiGrid", "AdminKpiCard", "SystemStatusPanel", "RegisteredPlayersPanel", "PredictionsLoadedPanel", "PendingRequestsPanel", "OfficialResultsPanel", "BackupExportPanel", "ActivityLogPanel"],
    assets: ["backgrounds/10_admin_background.png"],
    data: ["players.json", "fixture.json", "admin-dashboard.json"],
  },
];
---

<BaseLayout title="Wireframe — Polla Mundialera SECPLAN 2026">
  <div class="wireframe-page">
    <header class="wireframe-header">
      <p class="eyebrow">/wireframe</p>
      <h1>Wireframe técnico — Clean V2 Alpha 01</h1>
      <p class="subtitle">
        Anatomía de las 10 secciones. Estado: skeleton. Arte final pendiente.
      </p>
      <p class="warning">
        <strong>Vista técnica.</strong> No representa la navegación final.
        La navegación final usa una ruta independiente por sección
        (<code>/</code>, <code>/reglas</code>, <code>/jugador</code>,
        <code>/predicciones</code>, <code>/tabla</code>,
        <code>/proximo-partido</code>, <code>/fixture</code>,
        <code>/equipos</code>, <code>/estadisticas</code>,
        <code>/admin</code>).
      </p>
    </header>

    <WireframeGrid columns={1}>
      {sections.map((section) => (
        <WireframeBox label={section.code}>
          <p class="section-title">{section.label}</p>

          <p class="block-label">Estado</p>
          <div class="row">
            <WireframeLabel variant="note">{section.state}</WireframeLabel>
          </div>

          <p class="block-label">Zonas principales</p>
          <div class="row">
            {section.zones.map((z) => <WireframeLabel>{z}</WireframeLabel>)}
          </div>

          <p class="block-label">Componentes futuros</p>
          <div class="row">
            {section.components.map((c) => <WireframeLabel variant="component">{c}</WireframeLabel>)}
          </div>

          {section.assets.length > 0 && (
            <>
              <p class="block-label">Assets pendientes</p>
              <div class="row">
                {section.assets.map((a) => <WireframeLabel variant="note">{a}</WireframeLabel>)}
              </div>
            </>
          )}

          {section.data.length > 0 && (
            <>
              <p class="block-label">Data pendiente</p>
              <div class="row">
                {section.data.map((d) => <WireframeLabel variant="note">{d}</WireframeLabel>)}
              </div>
            </>
          )}
        </WireframeBox>
      ))}
    </WireframeGrid>
  </div>

  <style>
    .wireframe-page {
      padding: clamp(2rem, 4vw, 4rem);
      display: flex;
      flex-direction: column;
      gap: var(--space-lg);
    }

    .wireframe-header {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
      margin-bottom: var(--space-md);
    }

    .eyebrow {
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-muted);
    }

    .subtitle {
      color: var(--color-muted);
      max-width: 60ch;
    }

    .warning {
      max-width: 70ch;
      padding: var(--space-sm) var(--space-md);
      border-left: 3px solid var(--color-text);
      background: var(--color-line);
      font-size: 0.875rem;
      margin-top: var(--space-sm);
    }

    .warning code {
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      font-size: 0.85em;
      padding: 0 0.25em;
      background: var(--color-bg);
      border-radius: var(--radius-sm);
    }

    .section-title {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.125rem;
      margin-bottom: var(--space-sm);
    }

    .block-label {
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-muted);
      margin-top: var(--space-sm);
      margin-bottom: var(--space-xs);
    }

    .row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
    }
  </style>
</BaseLayout>
