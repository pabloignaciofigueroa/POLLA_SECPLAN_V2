---
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

import "../styles/reset.css";
import "../styles/tokens.css";
import "../styles/fonts.css";
import "../styles/accessibility.css";
import "../styles/animations.css";

interface Props {
  title?: string;
  description?: string;
  backgroundPreloadHref?: string;
}

const {
  title = "Polla SECPLAN 2026",
  description = "Polla Mundialera SECPLAN 2026 - Clean V2 Alpha 01",
  backgroundPreloadHref,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      /* Activa la capa de entrada sin FOUC: solo oculta [data-animate] si el
         usuario permite movimiento. Sin JS / reduced-motion → todo visible. */
      (function () {
        try {
          if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            document.documentElement.classList.add("motion-ready");
          }
        } catch (e) {}
      })();
    </script>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon_copa_mundialera.ico" />
    <link rel="preload" href="/fonts/barlow-condensed-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/barlow-condensed-800.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/barlow-condensed-900.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />
    {
      backgroundPreloadHref && (
        <link rel="preload" href={backgroundPreloadHref} as="image" type="image/avif" fetchpriority="high" />
      )
    }
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import "../scripts/motion.js";
    </script>
  </body>
</html>
