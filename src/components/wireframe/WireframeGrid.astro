---
interface Props {
  columns?: number;
}

const { columns = 1 } = Astro.props;
---

<div class="wf-grid" style={`--cols: ${columns};`}>
  <slot />
</div>

<style>
  .wf-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 1), minmax(0, 1fr));
    gap: var(--space-md);
  }

  @media (max-width: 700px) {
    .wf-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
