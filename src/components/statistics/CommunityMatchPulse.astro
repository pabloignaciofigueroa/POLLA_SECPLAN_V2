---
interface Props {
  matchId: string;
  compact?: boolean;
}

const { matchId, compact = false } = Astro.props;
---

<aside
  class:list={["community-pulse", { compact }]}
  data-community-pulse
  data-community-match-id={matchId}
  data-unlocked="false"
  aria-label="Pulso de predicciones de la comunidad"
>
  <div class="pulse-copy">
    <span>Pronóstico coral</span>
    <strong data-pulse-title>DATA CENTER BLOQUEADO</strong>
    <p data-pulse-copy>Completa tus 72 predicciones para revelar cómo votó la oficina.</p>
  </div>
  <div class="pulse-bars" data-pulse-bars aria-hidden="true">
    <i></i><i></i><i></i>
  </div>
  <a href={`/estadisticas?tab=partidos&match=${matchId}`}>Abrir análisis <span aria-hidden="true">-&gt;</span></a>
</aside>

<style>
  .community-pulse {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(8rem, 0.72fr) auto;
    gap: 0.8rem;
    align-items: center;
    min-width: 0;
    padding: 0.78rem;
    border: 1px solid color-mix(in srgb, var(--pm-cyan-500) 32%, transparent);
    border-radius: 0.78rem;
    background:
      radial-gradient(circle at 82% 15%, rgba(24, 221, 242, 0.16), transparent 30%),
      rgba(255, 255, 255, 0.94);
    box-shadow: 0 10px 25px rgba(7, 23, 53, 0.09);
  }

  .pulse-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 0.08rem;
  }

  .pulse-copy span {
    color: var(--pm-blue-500);
    font-family: var(--font-display);
    font-size: 0.58rem;
    font-weight: 950;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .pulse-copy strong {
    color: var(--pm-blue-900);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .pulse-copy p {
    margin: 0;
    color: var(--pm-blue-700);
    font-size: 0.65rem;
    font-weight: 700;
  }

  .pulse-bars {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.24rem;
    align-items: end;
    height: 2.6rem;
  }

  .pulse-bars i {
    display: block;
    height: 28%;
    border-radius: 0.25rem 0.25rem 0 0;
    background: var(--pm-blue-500);
    opacity: 0.26;
    transition: height 180ms var(--ease-out, ease-out),
      opacity 180ms var(--ease-out, ease-out);
  }

  .pulse-bars i:nth-child(2) {
    height: 52%;
    background: var(--pm-purple-500);
  }

  .pulse-bars i:nth-child(3) {
    height: 38%;
    background: var(--pm-pink-500);
  }

  .community-pulse[data-unlocked="true"] .pulse-bars i {
    opacity: 1;
  }

  .community-pulse a {
    display: inline-flex;
    gap: 0.32rem;
    align-items: center;
    color: var(--pm-blue-600);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 950;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .community-pulse a:hover {
    color: var(--pm-purple-600);
  }

  .community-pulse a:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  .community-pulse.compact {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .community-pulse.compact .pulse-bars {
    display: none;
  }

  @media (max-width: 680px) {
    .community-pulse {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse-bars i {
      transition: none;
    }
  }
</style>
