---
import MobileMenu from "./MobileMenu.astro";

const normalizePath = (path: string) => {
  if (path === "/") return "/";
  return path.replace(/\/$/, "");
};

const currentPath = normalizePath(Astro.url.pathname);

// Polla de ELIMINATORIAS — todas las secciones activas.
const links = [
  { href: "/", label: "Inicio" },
  { href: "/reglas", label: "Reglas" },
  { href: "/jugador", label: "Jugador" },
  { href: "/predicciones", label: "Predicciones" },
  { href: "/proximo-partido", label: "Próximo" },
  { href: "/tabla", label: "Tabla" },
  { href: "/fixture", label: "Llave" },
  { href: "/equipos", label: "Equipos" },
  { href: "/estadisticas", label: "Estadísticas" },
  { href: "/admin", label: "Admin" },
].map((link) => ({
  ...link,
  isActive: normalizePath(link.href) === currentPath,
}));
---

<header class="header" data-section="header">
  <a class="brand" href="/" data-astro-prefetch="viewport">Polla SECPLAN 2026</a>

  <nav class="nav-desktop" aria-label="Navegación principal">
    <ul>
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={link.isActive ? "page" : undefined}
            data-astro-prefetch="viewport"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <MobileMenu links={links} />
</header>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--pm-navbar-border);
    background: linear-gradient(90deg, var(--pm-navbar-bg), var(--pm-navbar-bg-2));
    color: var(--pm-white);
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    box-shadow: 0 10px 28px rgba(6, 19, 38, 0.22);
    /* Persiste/morfea entre páginas durante el view-transition cross-document
       (el resto del contenido hace el wipe/punch como grupo "root"). */
    view-transition-name: site-header;
  }

  .brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1rem, 1.1vw, 1.15rem);
    letter-spacing: 0.045em;
    text-transform: uppercase;
    color: var(--pm-white);
  }

  .nav-desktop ul {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--space-sm);
    max-width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .nav-desktop ul::-webkit-scrollbar { display: none; }

  .nav-desktop a {
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.92rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--pm-navbar-text);
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid transparent;
    border-radius: var(--pm-radius-pill);
    transition: color var(--pm-transition-fast), background var(--pm-transition-fast),
      border-color var(--pm-transition-fast), box-shadow var(--pm-transition-fast);
  }

  .admin-lock {
    display: inline-grid;
    width: 0.9rem;
    height: 0.9rem;
    place-items: center;
    flex-shrink: 0;
  }

  .admin-lock svg {
    display: block;
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .nav-desktop a:hover {
    color: var(--pm-navbar-text-hover);
    border-color: var(--pm-cyan-500);
    background: rgba(24, 221, 242, 0.08);
  }

  .nav-desktop a:focus-visible {
    outline: none;
    box-shadow: var(--pm-focus-ring);
  }

  .nav-desktop a[aria-current="page"] {
    color: var(--pm-navbar-active-text);
    background: var(--pm-navbar-active-bg);
    border-color: var(--pm-yellow-600);
    font-weight: 800;
    box-shadow: 0 0 18px var(--pm-gold-glow);
  }

  .nav-desktop a[aria-current="page"]:focus-visible {
    box-shadow: 0 0 18px var(--pm-gold-glow), var(--pm-focus-ring-yellow);
  }

  /* Tablet: encoge la nav para que los 10 links quepan en UNA fila (header de alto estable). */
  @media (max-width: 1180px) {
    .nav-desktop a { font-size: 0.74rem; padding: var(--space-xs) 0.5rem; letter-spacing: 0.03em; }
    .nav-desktop ul { gap: 0.3rem; }
  }

  @media (max-width: 900px) {
    .nav-desktop {
      display: none;
    }
  }
</style>
