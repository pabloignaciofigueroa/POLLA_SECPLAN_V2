---
interface Props {
  message?: string;
}

const { message = "Sección bloqueada — pendiente de fases posteriores." } = Astro.props;
---

<div class="locked-panel">
  <p class="locked-message">
    <span class="lock-icon" aria-hidden="true">🔒</span>
    <span>{message}</span>
  </p>
  <div class="locked-content">
    <slot />
  </div>
</div>

<style>
  .locked-panel {
    position: relative;
    padding: var(--space-lg);
    border: 1px solid var(--pm-state-locked-border);
    border-radius: var(--pm-radius-md);
    background: var(--pm-state-locked-bg);
    color: var(--pm-state-locked-text);
    box-shadow: var(--pm-shadow-purple);
    overflow: hidden;
  }

  .locked-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(24, 221, 242, 0.25), transparent 45%),
      radial-gradient(circle at 80% 70%, rgba(255, 47, 179, 0.18), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .locked-panel > * {
    position: relative;
    z-index: 1;
  }

  .locked-message {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pm-white);
    margin-bottom: var(--space-md);
  }

  .lock-icon {
    font-size: 1.1rem;
    filter: drop-shadow(0 0 6px var(--pm-cyan-glow));
  }

  .locked-content {
    opacity: 0.75;
    pointer-events: none;
  }
</style>
