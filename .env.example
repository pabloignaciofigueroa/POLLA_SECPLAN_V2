# ============================================================================
# Supabase — Polla ELIMINATORIAS. Copiá este archivo a .env.local y completá.
# .env.local está gitignoreado (la secret key NUNCA se commitea ni se imprime).
# Sin estas variables, la web sigue 100% local (lee los JSON commiteados).
# ============================================================================

# --- WEB (browser): lectura pública. Se exponen al cliente. ---
PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- SCRIPT de carga (server): escribe directo. SECRETO, no usar PUBLIC_. ---
SUPABASE_SECRET_KEY=sb_secret_...

# --- Admin (separado de Supabase; para el login de /admin) ---
ADMIN_PASSWORD=tu_admin_password

# Carpeta con los .json que mandan los jugadores (relativa a site/). Opcional.
CARTONES_DIR=../cartones
